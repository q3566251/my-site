var ans={};

function buildQuestions(){
  var c=document.getElementById('questions');
  c.innerHTML='';
  QS.forEach(function(q,i){
    c.innerHTML+='<div class="qcard">'
      +'<div class="qcard-top"><div class="qnum">'+(i+1)+'</div><div class="qtext">'+q.q+'</div></div>'
      +'<div class="choice-row">'
      +'<button class="choice-btn" id="opt_'+i+'_L" onclick="setAns('+i+',\'L\')">'+q.L.t+'</button>'
      +'<div class="vs-mid"><span class="vs-label">VS</span></div>'
      +'<button class="choice-btn" id="opt_'+i+'_R" onclick="setAns('+i+',\'R\')">'+q.R.t+'</button>'
      +'</div></div>';
  });
}

function setAns(qi,side){
  ans[qi]=side;
  var L=document.getElementById('opt_'+qi+'_L');
  var R=document.getElementById('opt_'+qi+'_R');
  if(side==='L'){L.className='choice-btn sel';R.className='choice-btn dim';}
  else{R.className='choice-btn sel';L.className='choice-btn dim';}
  var done=Object.keys(ans).length;
  document.getElementById('qcount').textContent=done+' / 25';
  document.getElementById('qbar').style.width=(done/25*100)+'%';
  var btn=document.getElementById('qnext');
  btn.disabled=done<25;
  btn.textContent=done<25?'还有 '+(25-done)+' 题未选':'查看结果 →';
}

function goTo(n){
  document.querySelectorAll('.page').forEach(function(p){p.classList.remove('active');});
  document.getElementById('p'+n).classList.add('active');
  window.scrollTo(0,0);
}

function renderInterpBlock(k,role,score,isStar){
  var s=SYS[k];
  var d=INTERP[k][role];
  var hi=(role==='primary');
  var bg=hi?s.bg:'#fafaf8';
  var borderColor=hi?(s.color+'55'):'#eeebe5';
  var textColor=hi?s.tc:'#444';
  var bulletsHtml=d.bullets.map(function(b){
    return '<li style="color:'+textColor+'">'
      +'<span style="color:'+s.color+';font-weight:700;flex-shrink:0">·</span>'
      +'<span>'+b+'</span>'
      +'</li>';
  }).join('');
  var noteHtml=d.note?'<div class="interp-note" style="color:'+textColor+';border-color:rgba(0,0,0,.07)">'+d.note+'</div>':'';
  return '<div class="interp-block" style="background:'+bg+';border-color:'+borderColor+'">'
    +'<div class="interp-head">'
    +'<span style="font-size:17px">'+s.icon+'</span>'
    +'<span style="font-size:13.5px;font-weight:700;color:'+s.tc+'">'+s.zh+'</span>'
    +'<span style="font-size:10px;font-weight:700;padding:2px 8px;border-radius:5px;background:'+(hi?'rgba(255,255,255,.6)':'#eeebe5')+';color:'+s.tc+'">'
    +score+'pt'+(isStar?' ★':'')+'</span>'
    +'</div>'
    +'<div class="interp-body" style="color:'+textColor+'">'
    +'<p>'+d.intro+'</p>'
    +'<div class="interp-section" style="color:'+s.tc+'">'+d.sectionA+'</div>'
    +'<ul class="interp-bullets">'+bulletsHtml+'</ul>'
    +noteHtml
    +'</div></div>';
}

function renderTagsAndFigures(pk,isDual,sk){
  var keys=isDual?[pk,sk]:[pk];
  var html='';
  keys.forEach(function(k){
    var p=PROFILE[k];
    var s=SYS[k];
    var tagsHtml=p.tags.map(function(t){
      return '<span class="tag-pill" style="background:'+s.bg+';color:'+s.tc+'">'
        +'<span class="tag-hash">#</span>'+t+'</span>';
    }).join('');
    var figuresHtml=p.figures.map(function(f){
      return '<div class="figure-card">'
        +'<div class="figure-avatar" style="background:'+s.bg+'">'+f.emoji+'</div>'
        +'<div style="flex:1">'
        +'<div class="figure-name">'+f.name+'</div>'
        +'<div class="figure-role">'+f.role+'</div>'
        +'<div class="figure-why">'+f.why+'</div>'
        +'</div></div>';
    }).join('');
    html+='<div style="margin-bottom:'+(isDual?'1.75rem':'0')+'">'
      +(isDual?'<div style="font-size:12px;font-weight:700;color:'+s.tc+';margin-bottom:.75rem;display:flex;align-items:center;gap:6px">'+s.icon+' '+s.zh+'</div>':'')
      +'<div class="tags-wrap">'+tagsHtml+'</div>'
      +'<div style="font-size:12px;color:#aaa;margin-bottom:.4rem;font-weight:600;letter-spacing:.04em;text-transform:uppercase">与你相似的人</div>'
      +'<div class="figures-row">'+figuresHtml+'</div>'
      +'</div>';
  });
  return html;
}

function showResults(){
  var scores={A:0,B:0,C:0,D:0,E:0};
  QS.forEach(function(q,i){
    if(ans[i]!==undefined) scores[q[ans[i]].s]++;
  });

  // Sort by score desc, then alphabetically for stable ties
  var sorted=Object.keys(scores).sort(function(a,b){
    return scores[b]-scores[a]||a.localeCompare(b);
  });
  var pk=sorted[0],sk=sorted[1];
  var pv=scores[pk],sv=scores[sk];
  // Dual if difference ≤ 1 (includes exact ties)
  var isDual=(pv-sv)<=1;
  var structLabel=isDual?SYS[pk].zh+' + '+SYS[sk].zh:SYS[pk].zh;

  var barsHtml=sorted.map(function(k,i){
    var v=scores[k];
    var label='';
    if(i===0) label='<span style="font-size:11px;color:#bbb;font-weight:400;margin-left:5px">主导</span>';
    else if(isDual&&i===1) label='<span style="font-size:11px;color:#bbb;font-weight:400;margin-left:5px">主导</span>';
    else if(!isDual&&i===1) label='<span style="font-size:11px;color:#bbb;font-weight:400;margin-left:5px">副系统</span>';
    return '<div class="bar-row">'
      +'<div class="bar-head">'
      +'<span style="font-size:13px;font-weight:600;color:'+SYS[k].color+'">'+SYS[k].icon+' '+SYS[k].zh+label+'</span>'
      +'<span style="font-size:13px;color:#999;font-weight:500">'+v+'<span style="font-size:11px;color:#bbb"> / '+MAX+'</span></span>'
      +'</div>'
      +'<div class="bar-track"><div class="bar-fill" data-w="'+Math.round(v/MAX*100)+'" style="background:'+SYS[k].color+'"></div></div>'
      +'</div>';
  }).join('');

  // Assign roles to all 5 systems
  var interpHtml=sorted.map(function(k,i){
    var role,isStar=false;
    if(i===0){role='primary';isStar=true;}
    else if(isDual&&i===1){role='primary';isStar=true;}
    else if(scores[k]<=3){role='low';}
    else if(i===1&&!isDual){role='secondary';}
    else{role='background';}
    return renderInterpBlock(k,role,scores[k],isStar);
  }).join('');

  var chipsHtml=isDual
    ?'<div style="display:flex;gap:7px;flex-wrap:wrap">'
      +'<span style="background:'+SYS[pk].bg+';color:'+SYS[pk].tc+';padding:4px 13px;border-radius:20px;font-size:12px;font-weight:600">'+SYS[pk].icon+' '+SYS[pk].zh+' '+pv+'pt</span>'
      +'<span style="background:'+SYS[sk].bg+';color:'+SYS[sk].tc+';padding:4px 13px;border-radius:20px;font-size:12px;font-weight:600">'+SYS[sk].icon+' '+SYS[sk].zh+' '+sv+'pt</span>'
      +'</div>'
    :'<div style="font-size:13px;color:#888">Secondary: <strong style="color:'+SYS[sk].tc+'">'+SYS[sk].zh+'</strong> &nbsp;·&nbsp; '+sv+'pt</div>';

  // Dual icon: two separate spans side by side
  var iconHtml=isDual
    ?'<span>'+SYS[pk].icon+'</span><span>'+SYS[sk].icon+'</span>'
    :SYS[pk].icon;

  var sysGridHtml=Object.entries(SYS).map(function(entry){
    var k=entry[0],s=entry[1];
    var hi=(k===sorted[0])||(isDual&&k===sorted[1]);
    return '<div class="sys-item" style="background:'+s.bg+';'+(hi?'outline:2px solid '+s.color+';outline-offset:1px':'')+'">'
      +'<div style="font-size:13px;font-weight:700;color:'+s.tc+';margin-bottom:3px">'+s.icon+' '+s.zh+(hi?' ★':'')+'</div>'
      +'<div style="font-size:11px;color:'+s.tc+';opacity:.8;line-height:1.4">'+s.desc+'</div>'
      +'</div>';
  }).join('');

  var tagsHtml=renderTagsAndFigures(pk,isDual,sk);

  document.getElementById('results').innerHTML=
    '<div style="border-bottom:1px solid #f0eeea;padding-bottom:1.5rem;margin-bottom:1.5rem">'
    +'<div style="font-size:11px;color:#aaa;letter-spacing:.07em;text-transform:uppercase;font-weight:600;margin-bottom:.35rem">Z5S Measure · V2 结果</div>'
    +'<h2 style="font-size:24px;font-weight:700;margin-bottom:.4rem">你的人格系统图谱</h2>'
    +'<p style="font-size:13px;color:#888">基于 25 组对比选择</p>'
    +'</div>'

    +'<div class="rcard" style="border-left:4px solid '+SYS[pk].color+'">'
    +'<div class="card-label">'+(isDual?'Dual System · 双系统':'Primary System · 主导系统')+'</div>'
    +'<div class="primary-row">'
    +'<div class="p-icon" style="background:'+SYS[pk].bg+'">'+iconHtml+'</div>'
    +'<div style="flex:1">'
    +'<div class="p-name" style="color:'+SYS[pk].tc+'">'+structLabel+'</div>'
    +'<div class="p-desc">'+(isDual?SYS[pk].name+' + '+SYS[sk].name+' · 差距 '+(pv-sv)+' 分，双系统判定':SYS[pk].name+' · 领先 '+(pv-sv)+' 分')+'</div>'
    +'</div>'
    +'<div class="p-score" style="color:'+SYS[pk].color+'">'+pv+'<span style="font-size:13px;font-weight:400;color:#aaa">pt</span></div>'
    +'</div>'
    +'<div style="margin-top:1rem;padding-top:1rem;border-top:1px solid #f0eeea">'+chipsHtml+'</div>'
    +'</div>'

    +'<div class="rcard">'
    +'<div class="card-label">五系统得分分布</div>'
    +'<div class="card-sub">每个系统最多出现 10 次，得分越高代表该系统在你的应对结构中激活度越高</div>'
    +barsHtml+'</div>'

    +'<div class="rcard"><div class="card-label">系统解读</div>'+interpHtml+'</div>'

    +'<div class="rcard"><div class="card-label">五个系统</div>'
    +'<p style="font-size:13px;color:#999;margin-bottom:1rem;line-height:1.6">每个人都同时拥有这五种系统，只是主导的优先级不同。</p>'
    +'<div class="sys-grid">'+sysGridHtml+'</div></div>'

    +'<div class="rcard"><div class="card-label">你的标签 &amp; 相似的人</div>'+tagsHtml+'</div>'

    +'<div style="text-align:center;margin-top:1.5rem;padding-bottom:2.5rem">'
    +'<button onclick="resetAll()" style="background:#fff;color:#666;border:1px solid #ddd;border-radius:10px;padding:.85rem 2.5rem;font-size:14px;cursor:pointer;font-family:-apple-system,BlinkMacSystemFont,\'PingFang SC\',\'Hiragino Sans GB\',sans-serif">重新测评</button>'
    +'</div>';

  goTo(2);
  requestAnimationFrame(function(){requestAnimationFrame(function(){
    document.querySelectorAll('.bar-fill[data-w]').forEach(function(b){b.style.width=b.dataset.w+'%';});
  });});
}

function resetAll(){
  Object.keys(ans).forEach(function(k){delete ans[k];});
  buildQuestions();
  document.getElementById('qcount').textContent='0 / 25';
  document.getElementById('qbar').style.width='0%';
  document.getElementById('qnext').disabled=true;
  document.getElementById('qnext').textContent='还有 25 题未选';
  goTo(0);
}

buildQuestions();
</script>
</body>
</html>
