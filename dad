/* ============================================================
   RULES
============================================================ */
function canLift(ci,idx){
  const c=G.cols[ci];if(!c[idx]?.up)return false;
  for(let i=idx;i<c.length-1;i++){if(c[i].r!==c[i+1].r+1||c[i].s!==c[i+1].s)return false;}
  return true;
}
function canPlace(fc,fi,tc){
  if(fc===tc)return false;
  const t=G.cols[tc];if(!t.length)return true;
  const top=t.at(-1);return top.up&&top.r===G.cols[fc][fi].r+1;
}
function flipTop(ci){const c=G.cols[ci];if(c.length&&!c.at(-1).up){c.at(-1).up=true;sndFlip();}}

function doMove(fc,fi,tc,silent=false){
  if(!silent)snap();
  const mv=G.cols[fc].splice(fi);G.cols[tc].push(...mv);
  flipTop(fc);G.moves++;G.score=Math.max(0,G.score-1);
  if(!silent){G.hint=null;sndMove();}
}
function removeSeqs(){
  let n=0;
  for(let c=0;c<10;c++){
    const col=G.cols[c];if(col.length<13)continue;
    const s=col.length-13;if(col[s].r!==13)continue;
    let ok=true;for(let i=s;i<col.length-1;i++){if(col[i].r!==col[i+1].r+1||col[i].s!==col[i+1].s){ok=false;break;}}
    if(ok){col.splice(s,13);G.done++;G.score+=100;flipTop(c);updStats();sndDone();n++;}
  }
  return n;
}
function afterMove(){
  let r=1;while(r>0)r=removeSeqs();
  updStats();renderDonePile();render();checkWin();
}
function dealStock(){
  if(!G.stock.length)return;snap();
  for(let c=0;c<10;c++){if(!G.stock.length)break;const cd=G.stock.pop();cd.up=true;G.cols[c].push(cd);}
  G.moves++;G.score=Math.max(0,G.score-5);sndDeal();afterMove();
}
function autoComplete(){
  snap();let changed=true,iters=0;
  while(changed&&iters<800){
    changed=false;iters++;
    if(removeSeqs()>0){changed=true;continue;}
    let best=null,bestScore=-1;
    for(let fc=0;fc<10;fc++){
      const col=G.cols[fc];
      for(let fi=col.length-1;fi>=0;fi--){
        if(!canLift(fc,fi))break;
        for(let tc=0;tc<10;tc++){
          if(!canPlace(fc,fi,tc))continue;
          const toCol=G.cols[tc];if(!toCol.length)continue;
          if(toCol.at(-1).s===col[fi].s){const score=(col.length-fi)*10+(13-col[fi].r);if(score>bestScore){bestScore=score;best={fc,fi,tc};}}
        }
      }
    }
    if(best){doMove(best.fc,best.fi,best.tc,true);changed=true;continue;}
    for(let fc=0;fc<10;fc++){
      const col=G.cols[fc];if(!col.length)continue;
      const fi=col.length-1;if(!canLift(fc,fi)||fi===0||col[fi-1].up)continue;
      for(let tc=0;tc<10;tc++){if(!canPlace(fc,fi,tc))continue;doMove(fc,fi,tc,true);changed=true;break;}
      if(changed)break;
    }
  }
  let r=1;while(r>0)r=removeSeqs();
  updStats();renderDonePile();render();checkWin();
}

/* ============================================================
   HINT
============================================================ */
let hintTmr=null;
function showHint(){
  clearTimeout(hintTmr);G.hint=null;
  const pairs=[];
  for(let fc=0;fc<10;fc++){
    const col=G.cols[fc];
    let lowestFi=-1;
    for(let fi=0;fi<col.length;fi++){if(canLift(fc,fi)){lowestFi=fi;break;}}
    if(lowestFi<0)continue;
    for(let tc=0;tc<10;tc++){
      if(!canPlace(fc,lowestFi,tc))continue;
      const ss=G.cols[tc].length&&G.cols[tc].at(-1).s===col[lowestFi].s;
      pairs.push({fc,fi:lowestFi,tc,ss});
    }
  }
  if(!pairs.length)return;
  pairs.sort((a,b)=>b.ss-a.ss);
  const best=pairs[0];
  const hc=HCOLS[hintCI%HCOLS.length];hintCI++;
  G.hint={fc:best.fc,fi:best.fi,tc:best.tc,di:G.cols[best.tc].length-1,hc};
  render();
  hintTmr=setTimeout(()=>{G.hint=null;render();},2800);
}

/* ============================================================
   UNDO
============================================================ */
function snap(){
  G.hist.push(JSON.stringify({cols:G.cols,stock:G.stock,done:G.done,score:G.score,moves:G.moves}));
  if(G.hist.length>60)G.hist.shift();
}
function undo(){
  if(!G.hist.length)return;
  const p=JSON.parse(G.hist.pop());
  G.cols=p.cols;G.stock=p.stock;G.done=p.done;
  G.score=Math.max(0,p.score-3);G.moves=p.moves;
  G.sel=null;G.drag=null;G.hint=null;
  updStats();renderDonePile();render();
}

