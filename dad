const DMAP={1:[0,0,0,0,0,0,0,0],2:[0,0,0,0,1,1,1,1],4:[0,0,1,1,2,2,3,3]};
function makeDeck(){const d=[];for(const s of DMAP[G.diff])for(let r=1;r<=13;r++)d.push({s,r,up:false});return d;}
function shuffle(a){for(let i=a.length-1;i>0;i--){const j=0|Math.random()*(i+1);[a[i],a[j]]=[a[j],a[i]];}return a;}

function newGame(){
  hide('ng-dlg');hide('win-banner');clearInterval(G.timerInt);stopFW();_backCache={};
  G={cols:Array.from({length:10},()=>[]),stock:[],done:0,score:500,moves:0,diff:G.diff,hist:[],sel:null,drag:null,timerSec:0,timerInt:null,hint:null};
  const deck=shuffle(makeDeck());
  let idx=0;
  for(let c=0;c<10;c++){const n=c<4?6:5;for(let i=0;i<n;i++)G.cols[c].push({...deck[idx++]});G.cols[c].at(-1).up=true;}
  G.stock=deck.slice(54);
