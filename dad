function calcSizes(){
  const availW = window.innerWidth  - 12;
  const availH = window.innerHeight - 40 - 12;
  const gap  = Math.max(2, Math.floor(availW * 0.007));
  const cw   = Math.floor((availW - gap*9 - gap*2) / 11);
  const ch   = Math.round(cw * 1.25);
  const maxCards = 20;
  const ov = Math.min(Math.round(ch*0.26), Math.max(14, Math.floor((availH-ch)/(maxCards-1))));
  const rk = Math.max(7,  Math.round(cw*0.185));
  const ss = Math.max(6,  Math.round(cw*0.148));
  const cc = Math.max(11, Math.round(cw*0.35));
  return {gap, cw, ch, ov, rk, ss, cc};
}
