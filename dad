  for(let i=0;i<G.done;i++){
    const d=document.createElement('div');d.className='done-card';
    d.style.cssText=`width:${cw}px;height:${ch}px;top:${i*off}px;left:0;z-index:${i+1}`;
    const si=Math.round(cw*.36);
    d.innerHTML=`<div class="done-suit ${cls[i]}" style="font-size:${si}px">${suits[i]}</div><div class="done-label">完成</div>`;
    stack.appendChild(d);
  }
  ct.textContent=`${G.done}/8`;
}

/* ============================================================
   CARD BUILDERS
============================================================ */
function mkBack(cw,ch){
  const d=document.createElement('div');d.className='card';
  d.style.cssText=`width:${cw}px;height:${ch}px;border-radius:5px;overflow:hidden;box-shadow:1px 1px 4px rgba(0,0,0,.5)`;
  const img=document.createElement('img');
  img.src=getBackSVG(cw,ch);
  img.style.cssText=`width:100%;height:100%;display:block`;
  d.appendChild(img);
  return d;
}

function mkFace(card,ci,idx,xtra,hintStyle,cw,ch,rk,ss,cc){
  const s=SUITS[card.s],cl=SCLS[card.s],r=RANKS[card.r];
  const d=document.createElement('div');
  d.className='card cf'+(xtra?' '+xtra:'');
  d.dataset.ci=ci;d.dataset.idx=idx;
  d.style.cssText=`width:${cw}px;height:${ch}px`;
  // Apply hint inline style (same color for src and dst)
  if(hintStyle){
    d.style.setProperty('--hc', hintStyle.c);
    d.style.setProperty('--hc-glow', hintStyle.glow);
    d.style.setProperty('--hc-bg', hintStyle.bg);
    d.style.background=hintStyle.bg;
    d.style.boxShadow=`0 0 0 3px ${hintStyle.c}, 0 0 14px ${hintStyle.glow}`;
    d.style.animation='hint-pulse 0.6s ease-in-out infinite alternate';
    d.style.zIndex=9000;
  }
  d.innerHTML=`<div class="cbody"><div class="cn ${cl}"><div class="rk" style="font-size:${rk}px">${r}</div><div class="ss" style="font-size:${ss}px">${s}</div></div><div class="cc ${cl}" style="font-size:${cc}px">${s}</div><div class="cn bot ${cl}"><div class="rk" style="font-size:${rk}px">${r}</div><div class="ss" style="font-size:${ss}px">${s}</div></div></div>`;
  return d;
}

/* ============================================================
   RENDER
============================================================ */
function render(){
  SZ=calcSizes();
  const {cw,ch,ov,gap,rk,ss,cc}=SZ;
  $('sidebar').style.width=(cw+6)+'px';

  const sp=$('stockp');sp.innerHTML='';
  sp.style.cssText=`width:${cw}px;height:${ch}px;border-radius:5px;position:relative;cursor:${G.stock.length?'pointer':'default'};flex-shrink:0`;
  if(G.stock.length){
    const n=Math.min(3,Math.ceil(G.stock.length/10));
    for(let i=0;i<n;i++){const b=mkBack(cw,ch);b.style.cssText+=`;position:absolute;top:${-i*2}px;left:${i*2}px`;sp.appendChild(b);}
  } else {
    sp.style.cssText+=`;border:2px dashed rgba(255,255,255,.15);display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,.18);font-size:22px`;
    sp.textContent='✗';
  }
  $('stockct').textContent=G.stock.length+'张';
  renderDonePile();
  renderTab(cw,ch,ov,gap,rk,ss,cc);
}

function canDrop(tc){const src=G.drag||G.sel;return src&&canPlace(src.ci,src.idx,tc);}

function renderTab(cw,ch,ov,gap,rk,ss,cc){
  const tab=$('tab');tab.innerHTML='';

  // Hint keys
  let hintSrcKey=null,hintDstKey=null,hintDstEmpty=false;
  if(G.hint){
    hintSrcKey=`${G.hint.fc}-${G.hint.fi}`;
    if(G.hint.di>=0) hintDstKey=`${G.hint.tc}-${G.hint.di}`;
    else hintDstEmpty=true;
  }

  for(let c=0;c<10;c++){
    const col=G.cols[c];
    const colD=document.createElement('div');colD.className='col';colD.dataset.ci=c;
    const mr=c<9?gap:0;
    colD.style.cssText=`width:${cw}px;flex-shrink:0;margin-right:${mr}px;position:relative;height:100%`;
    const inn=document.createElement('div');inn.className='coli';

    if(!col.length){
      inn.style.cssText=`width:${cw}px;height:${ch}px`;
      const isDrop=canDrop(c);
      const isHintDst=hintDstEmpty&&G.hint&&G.hint.tc===c;
      const ep=document.createElement('div');
      ep.dataset.ci=c;
      ep.style.cssText=`width:${cw}px;height:${ch}px;border-radius:5px;transition:border-color .15s`;
      if(isDrop){
        ep.className='ecol dt';
      } else if(isHintDst){
        ep.className='ecol hint-pair';
        ep.style.setProperty('--hc', G.hint.col);
        ep.style.setProperty('--hc-glow', G.hint.glow);
        ep.style.border=`2px solid ${G.hint.col}`;
        ep.style.boxShadow=`0 0 14px ${G.hint.glow}`;
        ep.style.animation='hint-border-pulse 0.6s ease-in-out infinite alternate';
      } else {
        ep.className='ecol';
      }
      inn.appendChild(ep);
    } else {
      // Per-column overlap so all columns share the same visual height
      const fixedH = ch + 5*ov; // height of a 6-card column = reference
      const colOv = col.length <= 1 ? 0 : Math.min(ov, Math.floor((fixedH - ch) / (col.length - 1)));
      const totalH = ch + (col.length-1)*colOv;
      inn.style.cssText=`width:${cw}px;height:${totalH}px;position:relative`;
      for(let i=0;i<col.length;i++){
        const card=col[i];
        const w=document.createElement('div');
        w.style.cssText=`position:absolute;top:${i*colOv}px;width:${cw}px;z-index:${i+1}`;
        const isDrag=G.drag&&G.drag.ci===c&&i>=G.drag.idx;
        const isSel=G.sel&&G.sel.ci===c&&i>=G.sel.idx;
        const key=`${c}-${i}`;
        const isHintSrc=!isDrag&&!isSel&&key===hintSrcKey;
        const isHintDst=!isDrag&&key===hintDstKey;
        if(!card.up){
          w.appendChild(mkBack(cw,ch));
        } else {
          let cls=isDrag?'gh':isSel?'sel':'';
          const hs=(isHintSrc||isHintDst)?G.hint:null;
          w.appendChild(mkFace(card,c,i,cls,hs,cw,ch,rk,ss,cc));
        }
        inn.appendChild(w);
      }
      if(canDrop(c)){
        const hl=document.createElement('div');
        hl.style.cssText=`position:absolute;top:${(col.length-1)*colOv}px;width:${cw}px;height:${ch}px;border-radius:5px;border:2px solid rgba(0,229,255,.8);pointer-events:none;z-index:${col.length+10};box-shadow:0 0 10px rgba(0,229,255,.4)`;
        inn.appendChild(hl);
      }
    }
    colD.appendChild(inn);tab.appendChild(colD);
  }
}

/* ============================================================
   CARD BACK PICKER UI
============================================================ */
function buildBackPicker(){
  const menu=$('back-menu');menu.innerHTML='';
  BACKS.forEach((b,i)=>{
    const row=document.createElement('div');
    row.className='back-opt'+(i===currentBack?' sel-back':'');
    row.onclick=()=>{
      currentBack=i;_backCache={};
      buildBackPicker();
      render();
      $('back-menu').classList.remove('open');
    };
    const prev=document.createElement('div');prev.className='back-preview';
    const img=document.createElement('img');
    img.src='data:image/svg+xml;utf8,'+encodeURIComponent(b.make(32,44));
    img.style.cssText='width:100%;height:100%;display:block';
    prev.appendChild(img);
    const name=document.createElement('div');name.className='back-name';name.textContent=b.name;
    row.appendChild(prev);row.appendChild(name);
    menu.appendChild(row);
  });
}

$('back-toggle').addEventListener('click',e=>{
  e.stopPropagation();
  $('back-menu').classList.toggle('open');
});
document.addEventListener('click',()=>$('back-menu').classList.remove('open'));
$('back-menu').addEventListener('click',e=>e.stopPropagation());

/* ============================================================
   CLICK
============================================================ */
$('tab').addEventListener('click',e=>{
  if(G.drag)return;resumeAC();
  const ce=e.target.closest('.cf'),ee=e.target.closest('.ecol'),co=e.target.closest('.col');
  const tc=+((ee||co)?.dataset.ci);
  if(G.sel){
    const{ci:fc,idx:fi}=G.sel;
    if(!isNaN(tc)&&canPlace(fc,fi,tc)){G.sel=null;doMove(fc,fi,tc);afterMove();return;}
    if(ce){
      const c2=+ce.dataset.ci,i2=+ce.dataset.idx;
      if(c2===fc&&i2===fi){G.sel=null;render();return;}
      if(canLift(c2,i2)){G.sel={ci:c2,idx:i2};render();return;}
    }
    G.sel=null;render();return;
  }
  if(ce){const ci=+ce.dataset.ci,idx=+ce.dataset.idx;if(canLift(ci,idx)){G.sel={ci,idx};render();}}
});

$('stockp').addEventListener('click',()=>{resumeAC();dealStock();});
$('btn-new').addEventListener('click',()=>$('ng-dlg').style.display='flex');
$('btn-auto').addEventListener('click',()=>{resumeAC();autoComplete();});
$('fab-undo').addEventListener('click',()=>{resumeAC();undo();});
$('fab-hint').addEventListener('click',()=>{resumeAC();showHint();});
document.querySelectorAll('[data-d]').forEach(b=>b.addEventListener('click',function(){G.diff=+this.dataset.d;newGame();}));

/* ============================================================
   DRAG
============================================================ */
let dObj=null;
function begDrag(ci,idx,x,y){
  if(!canLift(ci,idx))return;resumeAC();G.sel=null;
  const{cw,ch,ov,rk,ss,cc}=SZ;
  const cards=G.cols[ci].slice(idx);
  const g=$('ghost');g.innerHTML='';
  g.style.cssText=`display:block;width:${cw}px;height:${ch+(cards.length-1)*ov}px`;
  cards.forEach((card,i)=>{
    const w=document.createElement('div');w.style.cssText=`position:absolute;top:${i*ov}px;width:${cw}px`;
    w.appendChild(mkFace(card,ci,idx+i,'',null,cw,ch,rk,ss,cc));g.appendChild(w);
  });
  dObj={ci,idx,ox:cw/2,oy:24};G.drag={ci,idx};mvG(x,y);render();
}
function mvG(x,y){const g=$('ghost');g.style.left=(x-dObj.ox)+'px';g.style.top=(y-dObj.oy)+'px';}
function endDrag(x,y){
  $('ghost').style.display='none';if(!dObj)return;
  const{ci:fc,idx:fi}=dObj;dObj=null;G.drag=null;
  const el=document.elementFromPoint(x,y);
  const co=el?.closest('.col')||el?.closest('[data-ci]');
  const tc=co?+co.dataset.ci:NaN;
  if(!isNaN(tc)&&canPlace(fc,fi,tc)){doMove(fc,fi,tc);afterMove();}
  else render();
}
$('tab').addEventListener('mousedown',e=>{const ce=e.target.closest('.cf');if(!ce)return;e.preventDefault();begDrag(+ce.dataset.ci,+ce.dataset.idx,e.clientX,e.clientY);});
document.addEventListener('mousemove',e=>{if(dObj)mvG(e.clientX,e.clientY);});
document.addEventListener('mouseup',e=>{if(dObj)endDrag(e.clientX,e.clientY);});
$('tab').addEventListener('touchstart',e=>{const ce=e.target.closest('.cf');if(!ce)return;const t=e.touches[0];begDrag(+ce.dataset.ci,+ce.dataset.idx,t.clientX,t.clientY);},{passive:true});
document.addEventListener('touchmove',e=>{if(!dObj)return;e.preventDefault();const t=e.touches[0];mvG(t.clientX,t.clientY);},{passive:false});
document.addEventListener('touchend',e=>{if(!dObj)return;const t=e.changedTouches[0];endDrag(t.clientX,t.clientY);});

document.addEventListener('keydown',e=>{
  if(e.key==='z'||e.key==='Z')undo();
  if(e.key==='h'||e.key==='H')showHint();
  if(e.key==='d'||e.key==='D')dealStock();
  if(e.key==='Escape'){G.sel=null;render();}
});

window.addEventListener('resize',()=>{
  _backCache={};SZ=calcSizes();render();
  if(fwC.style.display!=='none'){fwC.width=window.innerWidth;fwC.height=window.innerHeight;}
});

buildBackPicker();
newGame();
</script>
