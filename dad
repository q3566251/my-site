/* ============================================================
   SIZING  — card width capped, never gets too big or too small
============================================================ */
function calcSizes(){
  const barH = window.innerHeight > 420 ? 44 : 36;
  // Use actual inner dimensions; safe-area handled by CSS
  const W = window.innerWidth - 12; // 6px l+r margin in #game
  const H = window.innerHeight - barH - 12;

  const GAP = Math.max(2, Math.floor(W * 0.005));
  // 10 tab cols + 1 sidebar col + 10 gaps — fill all available width, scaled by zoom
  const cwBase = Math.floor((W - GAP*10) / 11);
  const CW = Math.max(28, Math.round(cwBase * zoomFactor));
  const CH = Math.round(CW * 1.38);

  // Base overlap for 6-card reference column
  const OV = Math.round(CH * 0.19);

  const RK = Math.max(7,  Math.round(CW*0.19));
  const SS = Math.max(6,  Math.round(CW*0.15));
  const CC = Math.max(11, Math.round(CW*0.37));

  return {W, H, GAP, CW, CH, OV, RK, SS, CC, barH};
}
let zoomFactor = 1.0; // user-controlled zoom
let SZ=calcSizes();

