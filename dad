<!DOCTYPE html>
<html lang="zh">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
<title>蜘蛛纸牌</title>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html,body{
  width:100%;height:100%;
  overflow:hidden;
  font-family:Arial,sans-serif;
  touch-action:none;
  -webkit-tap-highlight-color:transparent;
  -webkit-touch-callout:none;
  -webkit-user-select:none;
  user-select:none;
  background:#2a6b22;
  padding-left:env(safe-area-inset-left);
  padding-right:env(safe-area-inset-right);
}

/* ===== TOOLBAR ===== */
#bar{
  position:fixed;
  top:0;left:0;right:0;
  height:44px;
  padding-top:env(safe-area-inset-top);
  background:linear-gradient(180deg,#4a7a3d,#2d5a26);
  border-bottom:2px solid #1a3a10;
  display:flex;align-items:center;
  padding-left:max(8px, env(safe-area-inset-left));
  padding-right:8px;
  gap:5px;z-index:600;
  box-shadow:0 2px 8px rgba(0,0,0,.4);
}
.logo{color:#fff;font-size:14px;font-weight:bold;white-space:nowrap;flex-shrink:0;}
.sep{width:1px;height:24px;background:#1a3a10;border-right:1px solid rgba(255,255,255,.15);flex-shrink:0;}
.tb{
  background:linear-gradient(180deg,#5a8a4d,#3d6a32);
  border:1px solid #1a3a10;border-bottom-color:#0a2008;
  color:#fff;padding:3px 10px;border-radius:3px;cursor:pointer;
  font-size:12px;font-weight:bold;white-space:nowrap;
  text-shadow:0 1px 1px rgba(0,0,0,.5);flex-shrink:0;
  transition:background .1s,transform .08s;
  -webkit-user-select:none;user-select:none;
}
.tb:hover{background:linear-gradient(180deg,#6a9a5d,#4d7a42);}
/* Zoom slider */
#zoom-wrap{display:flex;align-items:center;gap:5px;flex-shrink:0;}
#zoom-wrap label{color:rgba(255,255,255,.7);font-size:11px;white-space:nowrap;}
#zoom-slider{
  -webkit-appearance:none;appearance:none;
  width:80px;height:4px;border-radius:2px;
  background:rgba(255,255,255,.25);outline:none;cursor:pointer;
}
#zoom-slider::-webkit-slider-thumb{
  -webkit-appearance:none;width:14px;height:14px;border-radius:50%;
  background:#c8a000;cursor:pointer;box-shadow:0 1px 3px rgba(0,0,0,.5);
}
#zoom-slider::-moz-range-thumb{
  width:14px;height:14px;border-radius:50%;border:none;
  background:#c8a000;cursor:pointer;
}
#zoom-val{color:#ffdd80;font-size:11px;min-width:28px;text-align:center;}
.tb:active,.tb.on{background:linear-gradient(180deg,#3d6a32,#2a4d20);transform:scale(.95);}
#stats{color:#e8f0e8;font-size:12px;margin-left:auto;display:flex;gap:8px;align-items:center;flex-shrink:0;}
#tv{color:#ffff80;font-weight:bold;}
#sv{color:#80ff80;font-weight:bold;}
#mv2{color:#80d0ff;font-weight:bold;}

/* ===== GAME WRAPPER ===== */
#game{
  position:fixed;
  -webkit-touch-callout:none;
  top:44px;
  left:max(6px, env(safe-area-inset-left));
  right:6px;
  bottom:max(6px, env(safe-area-inset-bottom));
  display:flex;
  flex-direction:row;
  gap:0;
  overflow:hidden;
}
#sidebar{
  flex-shrink:0;
  display:flex;flex-direction:column;
  align-items:center;gap:5px;
  padding-left:5px;
}
#stockp{border-radius:5px;cursor:pointer;position:relative;flex-shrink:0;transition:filter .15s,transform .12s;}
#stockp:hover{filter:brightness(1.1);}
#stockp:active{transform:scale(.96);}
#stockct{color:rgba(255,255,255,.55);font-size:10px;text-align:center;}
#done-pile{display:flex;flex-direction:column;align-items:center;gap:2px;margin-top:auto;padding-bottom:4px;}
#done-stack{position:relative;}
#done-ct{color:rgba(255,255,255,.5);font-size:10px;text-align:center;}
.done-card{position:absolute;border-radius:4px;background:#fff;border:1px solid #aaa;box-shadow:1px 2px 5px rgba(0,0,0,.5);display:flex;align-items:center;justify-content:center;flex-direction:column;animation:flyIn .3s ease;}
@keyframes flyIn{from{transform:scale(.5);opacity:0}to{transform:scale(1);opacity:1}}
.done-suit{line-height:1;}
.done-label{font-size:7px;color:rgba(0,0,0,.4);}

/* ===== TABLEAU ===== */
#tab{
  flex:1;
  min-width:0;
  display:flex;
  align-items:flex-start;
  justify-content:center;
  overflow:hidden;
  height:100%;
  touch-action:none;
}
.col{position:relative;flex-shrink:0;height:100%;}
.coli{position:relative;}
.ecol{border:2px dashed rgba(255,255,255,.16);border-radius:4px;}
.ecol.dt{border-color:rgba(0,229,255,.8)!important;background:rgba(0,229,255,.05)!important;}

/* ===== CARDS ===== */
.card{position:absolute;border-radius:4px;}
.cb{
  background:#1a3a8a;
  border:2px solid rgba(255,255,255,.28);
  box-shadow:1px 1px 3px rgba(0,0,0,.5);
  overflow:hidden;
}
.cb::before{
  content:'';position:absolute;inset:3px;border-radius:3px;
  border:1px solid rgba(255,255,255,.1);
  background:
    repeating-linear-gradient(45deg,rgba(255,255,255,.05) 0,rgba(255,255,255,.05) 1px,transparent 1px,transparent 7px),
    repeating-linear-gradient(-45deg,rgba(255,255,255,.05) 0,rgba(255,255,255,.05) 1px,transparent 1px,transparent 7px);
}
.cf{
  background:#fff;border:1px solid #bbb;
  box-shadow:1px 2px 4px rgba(0,0,0,.3);
  cursor:pointer;
  -webkit-user-select:none;user-select:none;
  -webkit-touch-callout:none;
}
.cf:hover{box-shadow:1px 2px 8px rgba(0,0,0,.5);}
.cf.sel{background:#f0ffff!important;box-shadow:0 0 0 3px #00e5ff,0 0 12px rgba(0,229,255,.6)!important;}
.cf.gh{opacity:.25;}

/* Hint: same colour, pulsing */
.cf.hint-on{animation:hpulse .6s ease-in-out infinite alternate;z-index:9000!important;}
@keyframes hpulse{
  from{box-shadow:0 0 0 3px var(--hc),0 0 10px var(--hc);}
  to  {box-shadow:0 0 0 4px var(--hc),0 0 22px var(--hc);}
}
.ecol.hint-on{animation:hborder .6s ease-in-out infinite alternate;}
@keyframes hborder{
  from{border-color:var(--hc)!important;box-shadow:0 0 8px var(--hc);}
  to  {border-color:var(--hc)!important;box-shadow:0 0 20px var(--hc);}
}

.cbody{width:100%;height:100%;padding:2px 2px 2px 3px;display:flex;flex-direction:column;justify-content:space-between;pointer-events:none;}
.cn{display:flex;flex-direction:column;align-items:flex-start;line-height:1.1;}
.bot{transform:rotate(180deg);align-self:flex-end;}
.rk{font-weight:bold;line-height:1;}
.ss{line-height:1;}
.cc{text-align:center;line-height:1;align-self:center;margin:auto 0;}
.rd{color:#cc0000;}.bk{color:#111;}

/* ===== GHOST (drag) ===== */
#ghost{
  position:fixed;z-index:9999;pointer-events:none;display:none;
  filter:drop-shadow(3px 6px 14px rgba(0,0,0,.7));
}
#ghost .card{position:relative;}

/* ===== FAB ===== */
#fab{
  position:fixed;
  bottom:max(14px, env(safe-area-inset-bottom));
  left:max(14px, env(safe-area-inset-left));
  display:flex;gap:10px;z-index:700;
}
.fab-btn{
  width:52px;height:52px;border-radius:50%;border:none;cursor:pointer;
  display:flex;align-items:center;justify-content:center;flex-direction:column;gap:1px;
  font-size:9px;font-weight:bold;color:#fff;
  box-shadow:0 4px 14px rgba(0,0,0,.55);
  transition:transform .12s;
  -webkit-user-select:none;user-select:none;
  touch-action:manipulation;
}
.fab-btn:active{transform:scale(.88);}
#fab-undo{background:radial-gradient(circle at 35% 35%,#5a8a4d,#2d5a26);}
#fab-hint{background:radial-gradient(circle at 35% 35%,#4a7ab0,#1d4070);}
.fab-icon{font-size:20px;line-height:1;}

/* ===== CARD BACK PICKER ===== */
#back-picker{
  position:fixed;
  bottom:max(14px, env(safe-area-inset-bottom));
  right:max(14px, env(safe-area-inset-right));
  display:flex;flex-direction:column;align-items:flex-end;gap:6px;z-index:700;
}
#back-toggle{
  background:radial-gradient(circle at 35% 35%,#7a4ab0,#3d1d70);
  border:none;color:#fff;width:52px;height:52px;border-radius:50%;cursor:pointer;
  display:flex;align-items:center;justify-content:center;flex-direction:column;gap:1px;
  font-size:9px;font-weight:bold;box-shadow:0 4px 14px rgba(0,0,0,.55);
  touch-action:manipulation;-webkit-user-select:none;user-select:none;
}
#back-toggle:active{transform:scale(.88);}
#back-menu{
  display:none;flex-direction:column;gap:5px;align-items:flex-end;
  background:rgba(0,0,0,.82);border-radius:10px;padding:8px;
  border:1px solid rgba(255,255,255,.12);
}
#back-menu.open{display:flex;}
.back-opt{display:flex;align-items:center;gap:8px;cursor:pointer;padding:4px 6px;border-radius:6px;touch-action:manipulation;}
.back-opt:active{background:rgba(255,255,255,.1);}
.back-opt.sel-back{background:rgba(255,220,0,.15);outline:1px solid rgba(255,220,0,.4);}
.back-preview{width:30px;height:42px;border-radius:4px;flex-shrink:0;border:1px solid rgba(255,255,255,.3);overflow:hidden;}
.back-preview img{width:100%;height:100%;display:block;}
.back-name{color:#fff;font-size:11px;font-weight:bold;white-space:nowrap;}

/* ===== WIN BANNER ===== */
#win-banner{
  position:fixed;top:52px;left:50%;transform:translateX(-50%);
  background:linear-gradient(135deg,#1a4a10ee,#2d6a20ee);
  border:2px solid #c8a000;border-radius:12px;
  padding:10px 22px;z-index:8000;
  display:none;flex-direction:column;align-items:center;gap:6px;
  box-shadow:0 4px 24px rgba(0,0,0,.5);
  animation:bannerIn .4s ease;pointer-events:auto;
  white-space:nowrap;
}
@keyframes bannerIn{from{transform:translateX(-50%) translateY(-20px);opacity:0}to{transform:translateX(-50%) translateY(0);opacity:1}}
#win-banner h2{color:#ffdd60;font-size:18px;}
#win-banner p{color:#cce8cc;font-size:12px;}

/* ===== DIALOG ===== */
.ov{position:fixed;inset:0;background:rgba(0,0,0,.72);z-index:8000;display:flex;align-items:center;justify-content:center;}
.dlg{background:linear-gradient(180deg,#5a8a4d,#2d5a26);border:3px solid #1a3a10;border-radius:10px;padding:20px 26px;color:#fff;text-align:center;min-width:240px;box-shadow:0 8px 32px rgba(0,0,0,.6);}
.dlg h2{font-size:20px;margin-bottom:8px;}
.dlg p{font-size:13px;color:#cce0cc;margin-bottom:14px;}
.dbs{display:flex;gap:9px;justify-content:center;flex-wrap:wrap;}
.dbs .tb{font-size:12px;padding:5px 16px;}

/* ===== FIREWORKS ===== */
#fw-canvas{position:fixed;inset:0;z-index:7900;pointer-events:none;display:none;}

/* Landscape phone tweaks */
@media (max-height:420px){
  #bar{height:36px;}
  #game{top:36px;}
  .fab-btn,#back-toggle{width:42px;height:42px;}.fab-icon{font-size:16px;}
}
</style>
</head>
<body>

<div id="bar">
  <div class="logo">♠ 蜘蛛纸牌</div>
  <div class="sep"></div>
  <button class="tb" id="btn-new">新游戏</button>
  <button class="tb" id="btn-auto">自动完成</button>
  <div class="sep"></div>
  <button class="tb on" data-d="1">1色</button>
  <button class="tb" data-d="2">2色</button>
  <button class="tb" data-d="4">4色</button>
  <div id="zoom-wrap">
    <label>缩放</label>
    <input type="range" id="zoom-slider" min="50" max="150" value="100" step="5">
    <span id="zoom-val">100%</span>
  </div>
  <div id="stats">
    <span>⏱<span id="tv">0:00</span></span>
    <span>分<span id="sv">500</span></span>
    <span>步<span id="mv2">0</span></span>
  </div>
</div>

<div id="game">
  <div id="tab"></div>
  <div id="sidebar">
    <div id="stockp"></div>
    <div id="stockct">50张</div>
    <div id="done-pile">
      <div id="done-stack"></div>
      <div id="done-ct"></div>
    </div>
  </div>
</div>

<div id="fab">
  <button class="fab-btn" id="fab-undo"><div class="fab-icon">↩</div><div>撤销</div></button>
  <button class="fab-btn" id="fab-hint"><div class="fab-icon">💡</div><div>提示</div></button>
</div>

<div id="back-picker">
  <div id="back-menu"></div>
  <button id="back-toggle"><div style="font-size:18px">🎴</div><div>牌背</div></button>
</div>

<div id="win-banner">
  <h2>🎉 恭喜胜利！</h2>
  <p id="win-msg"></p>
  <button class="tb" onclick="hide('win-banner')">关闭</button>
</div>

<canvas id="fw-canvas"></canvas>
<div id="ghost"></div>

<div class="ov" id="ng-dlg" style="display:none">
  <div class="dlg"><h2>♠ 新游戏</h2><p>选择难度：</p>
    <div class="dbs">
      <button class="tb" onclick="startNew(1)">1色 简单</button>
      <button class="tb" onclick="startNew(2)">2色 中等</button>
      <button class="tb" onclick="startNew(4)">4色 困难</button>
      <button class="tb" onclick="hide('ng-dlg')">取消</button>
    </div>
  </div>
</div>

<script>
/* ============================================================
   CARD BACK DESIGNS
============================================================ */
const BACKS=[
  {id:'palace',name:'故宫红',make(w,h){
    return `<svg xmlns="http://www.w3.org/2000/svg" width="${w}" height="${h}">
    <defs><pattern id="L${w}" patternUnits="userSpaceOnUse" width="8" height="8">
    <rect width="8" height="8" fill="#8B0000"/>
    <line x1="0" y1="0" x2="8" y2="8" stroke="#a01010" stroke-width="0.5"/>
    <line x1="8" y1="0" x2="0" y2="8" stroke="#a01010" stroke-width="0.5"/>
    </pattern></defs>
    <rect width="${w}" height="${h}" rx="4" fill="url(#L${w})"/>
    <rect x="2" y="2" width="${w-4}" height="${h-4}" rx="3" fill="none" stroke="#c8a000" stroke-width="1.8"/>
    <rect x="5" y="5" width="${w-10}" height="${h-10}" rx="2" fill="none" stroke="#c8a000" stroke-width="0.7" opacity="0.6"/>
    ${[[8,8],[w-8,8],[8,h-8],[w-8,h-8]].map(([cx,cy])=>{const s=Math.round(Math.min(w,h)*.09);return `<circle cx="${cx}" cy="${cy}" r="${s}" fill="#c8a000" opacity="0.3"/><circle cx="${cx}" cy="${cy}" r="${s*.5}" fill="#8B0000"/><circle cx="${cx}" cy="${cy}" r="${s*.25}" fill="#c8a000" opacity="0.8"/>`;}).join('')}
    ${(()=>{const mid=w/2,rh=Math.round(h*.16),ry=Math.round(h*.08),rw=Math.round(w*.68),rx=(w-rw)/2;return `<polygon points="${rx+rw*.12},${ry+rh} ${rx},${ry+rh} ${rx+rw*.18},${ry+rh*.4} ${mid},${ry} ${rx+rw*.82},${ry+rh*.4} ${rx+rw},${ry+rh} ${rx+rw*.88},${ry+rh}" fill="#c8a000" opacity="0.5"/><line x1="${rx}" y1="${ry+rh}" x2="${rx+rw}" y2="${ry+rh}" stroke="#c8a000" stroke-width="1.2" opacity="0.8"/><polygon points="${mid},${ry-3} ${mid-3},${ry+4} ${mid+3},${ry+4}" fill="#c8a000" opacity="0.8"/>`;})()}
    ${(()=>{const cx=w/2,cy=h/2,r=Math.round(Math.min(w,h)*.19);let p='';for(let i=0;i<8;i++){const a=i*Math.PI/4;p+=`<ellipse cx="${(cx+Math.cos(a)*r*.62).toFixed(1)}" cy="${(cy+Math.sin(a)*r*.62).toFixed(1)}" rx="${(r*.3).toFixed(1)}" ry="${(r*.15).toFixed(1)}" transform="rotate(${i*45} ${(cx+Math.cos(a)*r*.62).toFixed(1)} ${(cy+Math.sin(a)*r*.62).toFixed(1)})" fill="#c8a000" opacity="0.4"/>`;}return `<circle cx="${cx}" cy="${cy}" r="${r}" fill="none" stroke="#c8a000" stroke-width="1" opacity="0.5"/>${p}<circle cx="${cx}" cy="${cy}" r="${r*.68}" fill="#7a0000" stroke="#c8a000" stroke-width="0.9"/><text x="${cx}" y="${cy+r*.35}" text-anchor="middle" font-family="serif" font-size="${r}" fill="#c8a000" opacity="0.95">福</text>`;})()}
    </svg>`;
  }},
  {id:'dragon',name:'金龙黑',make(w,h){
    return `<svg xmlns="http://www.w3.org/2000/svg" width="${w}" height="${h}">
    <rect width="${w}" height="${h}" rx="4" fill="#0d0d1a"/>
    <rect x="2" y="2" width="${w-4}" height="${h-4}" rx="3" fill="none" stroke="#b89000" stroke-width="1.8"/>
    <path d="M${w*.2},${h*.25} Q${w*.55},${h*.18} ${w*.75},${h*.35} Q${w*.9},${h*.5} ${w*.7},${h*.65} Q${w*.5},${h*.82} ${w*.25},${h*.72} Q${w*.08},${h*.6} ${w*.15},${h*.42}" fill="none" stroke="#b89000" stroke-width="${Math.max(2,w*.045)}" opacity="0.55" stroke-linecap="round"/>
    <circle cx="${w*.2}" cy="${h*.25}" r="${w*.07}" fill="#b89000" opacity="0.5"/>
    <circle cx="${w*.18}" cy="${h*.22}" r="${w*.025}" fill="#ffdd00" opacity="0.8"/>
    ${[[8,8],[w-8,8],[8,h-8],[w-8,h-8]].map(([x,y])=>`<polygon points="${x},${y-5} ${x+4},${y} ${x},${y+5} ${x-4},${y}" fill="#b89000" opacity="0.5"/>`).join('')}
    <text x="${w/2}" y="${h*.94}" text-anchor="middle" font-family="serif" font-size="${w*.12}" fill="#b89000" opacity="0.4">龙</text>
    </svg>`;
  }},
  {id:'porcelain',name:'青花瓷',make(w,h){
    const cx=w/2,cy=h/2;
    return `<svg xmlns="http://www.w3.org/2000/svg" width="${w}" height="${h}">
    <rect width="${w}" height="${h}" rx="4" fill="#e8f0f8"/>
    ${Array.from({length:7},(_,i)=>`<path d="M0,${(i+.5)*h/7} Q${w/4},${i*h/7} ${w/2},${(i+.5)*h/7} Q${w*3/4},${(i+1)*h/7} ${w},${(i+.5)*h/7}" fill="none" stroke="#1a3a7a" stroke-width="0.5" opacity="0.18"/>`).join('')}
    <rect x="2" y="2" width="${w-4}" height="${h-4}" rx="3" fill="none" stroke="#1a3a7a" stroke-width="2"/>
    ${[[10,10],[w-10,10],[10,h-10],[w-10,h-10]].map(([fx,fy])=>`<circle cx="${fx}" cy="${fy}" r="${w*.07}" fill="none" stroke="#1a3a7a" stroke-width="0.8" opacity="0.5"/><circle cx="${fx}" cy="${fy}" r="${w*.03}" fill="#1a3a7a" opacity="0.5"/>`).join('')}
    <ellipse cx="${cx}" cy="${cy-.1*h}" rx="${w*.13}" ry="${h*.09}" fill="none" stroke="#1a3a7a" stroke-width="1.2" opacity="0.7"/>
    <line x1="${cx-w*.13}" y1="${cy-.1*h}" x2="${cx-w*.09}" y2="${cy+h*.12}" stroke="#1a3a7a" stroke-width="1.2" opacity="0.7"/>
    <line x1="${cx+w*.13}" y1="${cy-.1*h}" x2="${cx+w*.09}" y2="${cy+h*.12}" stroke="#1a3a7a" stroke-width="1.2" opacity="0.7"/>
    <line x1="${cx-w*.09}" y1="${cy+h*.12}" x2="${cx+w*.09}" y2="${cy+h*.12}" stroke="#1a3a7a" stroke-width="1.2" opacity="0.7"/>
    ${Array.from({length:5},(_,k)=>{const a=k*2*Math.PI/5;return `<circle cx="${(cx+Math.cos(a)*w*.07).toFixed(1)}" cy="${(cy+Math.sin(a)*h*.05-.05*h).toFixed(1)}" r="${(w*.03).toFixed(1)}" fill="#1a3a7a" opacity="0.55"/>`;}).join('')}
    </svg>`;
  }},
  {id:'koi',name:'锦鲤金',make(w,h){
    const cx=w/2,cy=h/2;
    return `<svg xmlns="http://www.w3.org/2000/svg" width="${w}" height="${h}">
    <defs><radialGradient id="P${w}" cx="50%" cy="50%" r="50%"><stop offset="0%" stop-color="#1a4a6a"/><stop offset="100%" stop-color="#0a1e2e"/></radialGradient></defs>
    <rect width="${w}" height="${h}" rx="4" fill="url(#P${w})"/>
    ${[.18,.32,.46].map(r=>`<ellipse cx="${cx}" cy="${cy}" rx="${w*r}" ry="${h*r*.7}" fill="none" stroke="#4a8aaa" stroke-width="0.6" opacity="0.25"/>`).join('')}
    <rect x="2" y="2" width="${w-4}" height="${h-4}" rx="3" fill="none" stroke="#d4a000" stroke-width="1.8"/>
    <ellipse cx="${cx-w*.1}" cy="${cy-h*.1}" rx="${w*.2}" ry="${h*.08}" fill="#e07820" opacity="0.85" transform="rotate(-20 ${cx-w*.1} ${cy-h*.1})"/>
    <ellipse cx="${cx+w*.08}" cy="${cy+h*.1}" rx="${w*.18}" ry="${h*.07}" fill="#d0d8e0" opacity="0.8" transform="rotate(15 ${cx+w*.08} ${cy+h*.1})"/>
