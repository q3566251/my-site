function canDrop(tc){const src=G.drag||G.sel;return src&&canPlace(src.ci,src.idx,tc);}

function renderTab(CW,CH,OV,GAP,RK,SS,CC){
  const tab=$('tab');tab.innerHTML='';

  let hSrcKey=null,hDstKey=null,hDstEmpty=false,hc=null;
  if(G.hint){
    hSrcKey=`${G.hint.fc}-${G.hint.fi}`;
    hc=G.hint.hc;
    if(G.hint.di>=0)hDstKey=`${G.hint.tc}-${G.hint.di}`;
    else hDstEmpty=true;
  }

  // Reference height: 6-card column (cols 0-3)
  const REF_H = CH + 5*OV;

  for(let c=0;c<10;c++){
    const col=G.cols[c];
    const colD=document.createElement('div');
    colD.className='col';colD.dataset.ci=c;
    colD.style.cssText=`width:${CW}px;flex-shrink:0;margin-right:${c<9?GAP:0}px;position:relative;height:100%`;
    const inn=document.createElement('div');inn.className='coli';

    if(!col.length){
      inn.style.cssText=`width:${CW}px;height:${CH}px`;
      const ep=document.createElement('div');
      ep.dataset.ci=c;
      const isDrop=canDrop(c);
      const isHintDst=hDstEmpty&&G.hint&&G.hint.tc===c;
      ep.style.cssText=`width:${CW}px;height:${CH}px;border-radius:4px;border:2px dashed rgba(255,255,255,.16)`;
      if(isDrop){ep.style.borderColor='rgba(0,229,255,.8)';ep.style.background='rgba(0,229,255,.05)';}
      else if(isHintDst){ep.style.setProperty('--hc',hc);ep.style.borderColor=hc;ep.style.boxShadow=`0 0 14px ${hc}88`;ep.style.animation='hborder .6s ease-in-out infinite alternate';}
      ep.dataset.ci=c;inn.appendChild(ep);
    }else{
      // Overlap rules:
      // 1. Never let totalH exceed available column space (SZ.H - 16)
      // 2. Always show at least RK+4 px of each card (rank visible)
      // 3. Try to keep all columns same visual height (REF_H)
      const maxH   = SZ.H - 16;             // hard cap — never overflows screen
      const minVis = Math.max(RK + 4, 16);  // always show rank number
      const refOv  = col.length <= 1 ? 0 : Math.floor((REF_H - CH) / (col.length - 1));
      const maxOv  = col.length <= 1 ? 0 : Math.floor((maxH  - CH) / (col.length - 1));
      // clamp: at least minVis, at most maxOv so nothing overflows
      const colOv  = col.length <= 1 ? 0 : Math.min(maxOv, Math.max(minVis, refOv));
      const totalH = CH + (col.length-1)*colOv;
      inn.style.cssText=`width:${CW}px;height:${totalH}px;position:relative`;

      for(let i=0;i<col.length;i++){
        const card=col[i];
        const w=document.createElement('div');
        w.style.cssText=`position:absolute;top:${i*colOv}px;width:${CW}px;z-index:${i+1}`;
        const isDrag=G.drag&&G.drag.ci===c&&i>=G.drag.idx;
        const isSel=G.sel&&G.sel.ci===c&&i>=G.sel.idx;
        const key=`${c}-${i}`;
        const isHintSrc=!isDrag&&!isSel&&key===hSrcKey;
        const isHintDst=!isDrag&&key===hDstKey;
        if(!card.up){w.appendChild(mkBack(CW,CH));}
        else{
          const cls=isDrag?'gh':isSel?'sel':'';
          const hs=(isHintSrc||isHintDst)?hc:null;
          w.appendChild(mkFace(card,c,i,cls,hs,CW,CH,RK,SS,CC));
        }
        inn.appendChild(w);
      }
      if(canDrop(c)){
        const hl=document.createElement('div');
        hl.style.cssText=`position:absolute;top:${(col.length-1)*colOv}px;width:${CW}px;height:${CH}px;border-radius:4px;border:2px solid rgba(0,229,255,.8);pointer-events:none;z-index:${col.length+10};box-shadow:0 0 10px rgba(0,229,255,.4)`;
        inn.appendChild(hl);
      }
    }
    colD.appendChild(inn);tab.appendChild(colD);
  }
}

/* ============================================================
   CLICK
============================================================ */
$('tab').addEventListener('click',e=>{
  if(G.drag)return;
  if(Date.now()-lastTouchEnd<350)return;
  resumeAC();
  // Find what was clicked: a face-up card or a column target
  const ce = e.target.closest('.cf');       // face-up card
  const co = e.target.closest('.col');      // any column area
  const tc = co ? +co.dataset.ci : NaN;

  if(G.sel){
    const{ci:fc,idx:fi}=G.sel;
    // Drop onto column (empty slot or top of stack)
    if(!isNaN(tc) && canPlace(fc,fi,tc)){
      G.sel=null; doMove(fc,fi,tc); afterMove(); return;
    }
    // Click on a face-up card
    if(ce){
      const c2=+ce.dataset.ci, i2=+ce.dataset.idx;
      if(c2===fc && i2===fi){ G.sel=null; render(); return; } // deselect
      if(canLift(c2,i2)){ G.sel={ci:c2,idx:i2}; render(); return; } // re-select
    }
    // Clicked empty space — deselect
    G.sel=null; render(); return;
  }
  // No selection: select clicked card
  if(ce){
    const ci=+ce.dataset.ci, idx=+ce.dataset.idx;
    if(canLift(ci,idx)){ G.sel={ci,idx}; render(); }
  }
});

$('stockp').addEventListener('click',()=>{if(drag)return;resumeAC();dealStock();});
$('btn-new').addEventListener('click',()=>$('ng-dlg').style.display='flex');
$('btn-auto').addEventListener('click',()=>{if(drag)return;resumeAC();autoComplete();});
$('fab-undo').addEventListener('click',()=>{if(drag)return;resumeAC();undo();});
$('fab-hint').addEventListener('click',()=>{if(drag)return;resumeAC();showHint();});
document.querySelectorAll('[data-d]').forEach(b=>b.addEventListener('click',function(){G.diff=+this.dataset.d;newGame();}));

