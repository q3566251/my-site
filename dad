   BACK PICKER
============================================================ */
function buildBackPicker(){
  const menu=$('back-menu');menu.innerHTML='';
  BACKS.forEach((b,i)=>{
    const row=document.createElement('div');
    row.className='back-opt'+(i===currentBack?' sel-back':'');
    row.addEventListener('click',e=>{e.stopPropagation();currentBack=i;_backCache={};buildBackPicker();render();$('back-menu').classList.remove('open');});
    const prev=document.createElement('div');prev.className='back-preview';
    const img=document.createElement('img');img.src='data:image/svg+xml;utf8,'+encodeURIComponent(b.make(30,42));
    img.style.cssText='width:100%;height:100%;display:block';
    prev.appendChild(img);
    const name=document.createElement('div');name.className='back-name';name.textContent=b.name;
    row.appendChild(prev);row.appendChild(name);menu.appendChild(row);
  });
}
$('back-toggle').addEventListener('click',e=>{e.stopPropagation();$('back-menu').classList.toggle('open');});
document.addEventListener('click',()=>$('back-menu').classList.remove('open'));
$('back-menu').addEventListener('click',e=>e.stopPropagation());

