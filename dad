<!DOCTYPE html>
<html lang="zh">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>蜘蛛纸牌</title>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html,body{width:100%;height:100%;overflow:hidden;font-family:Arial,sans-serif;touch-action:none;-webkit-tap-highlight-color:transparent;background:#2a6b22;}

#bar{
  position:fixed;top:0;left:0;right:0;height:40px;
  background:linear-gradient(180deg,#4a7a3d,#2d5a26);
  border-bottom:2px solid #1a3a10;
  display:flex;align-items:center;padding:0 8px;gap:5px;z-index:600;
  box-shadow:0 2px 8px rgba(0,0,0,.4);overflow:hidden;
}
.logo{color:#fff;font-size:14px;font-weight:bold;white-space:nowrap;flex-shrink:0;}
.sep{width:1px;height:24px;background:#1a3a10;border-right:1px solid rgba(255,255,255,.15);flex-shrink:0;}
.tb{
  background:linear-gradient(180deg,#5a8a4d,#3d6a32);
  border:1px solid #1a3a10;border-bottom-color:#0a2008;
  color:#fff;padding:2px 9px;border-radius:3px;cursor:pointer;
  font-size:12px;font-weight:bold;white-space:nowrap;
  text-shadow:0 1px 1px rgba(0,0,0,.5);flex-shrink:0;
  transition:background .1s,transform .08s;
}
.tb:hover{background:linear-gradient(180deg,#6a9a5d,#4d7a42);}
.tb:active,.tb.on{background:linear-gradient(180deg,#3d6a32,#2a4d20);box-shadow:inset 0 1px 3px rgba(0,0,0,.4);transform:scale(.95);}
#stats{color:#e8f0e8;font-size:12px;margin-left:auto;display:flex;gap:8px;align-items:center;flex-shrink:0;}
#tv{color:#ffff80;font-weight:bold;}
#sv{color:#80ff80;font-weight:bold;}
#mv2{color:#80d0ff;font-weight:bold;}

#game{position:fixed;top:40px;left:0;right:0;bottom:0;display:flex;gap:0;padding:6px;}
#sidebar{display:flex;flex-direction:column;align-items:center;gap:6px;flex-shrink:0;padding-left:6px;}
#stockp{border-radius:5px;cursor:pointer;position:relative;flex-shrink:0;transition:filter .15s,transform .12s;}
#stockp:hover{filter:brightness(1.1);transform:scale(1.04);}
#stockp:active{transform:scale(.95);}
#stockct{color:rgba(255,255,255,.55);font-size:10px;text-align:center;}
#done-pile{display:flex;flex-direction:column;align-items:center;gap:3px;margin-top:auto;}
#done-stack{position:relative;}
#done-ct{color:rgba(255,255,255,.55);font-size:10px;text-align:center;}
.done-card{position:absolute;border-radius:5px;background:#fff;border:1px solid #aaa;box-shadow:1px 2px 5px rgba(0,0,0,.5);display:flex;align-items:center;justify-content:center;flex-direction:column;animation:flyIn .35s cubic-bezier(.25,.46,.45,.94);}
@keyframes flyIn{from{transform:scale(.5) translateY(-20px);opacity:0}to{transform:scale(1) translateY(0);opacity:1}}
.done-suit{line-height:1;}.done-label{font-size:8px;color:rgba(0,0,0,.4);}

#tab{flex:1;display:flex;gap:0;align-items:flex-start;overflow:hidden;height:100%;}
.col{position:relative;flex-shrink:0;height:100%;}
.coli{position:relative;}
.ecol{border:2px dashed rgba(255,255,255,.16);border-radius:5px;transition:border-color .15s,background .15s;}
.ecol.dt{border-color:rgba(0,229,255,.8)!important;background:rgba(0,229,255,.05)!important;}

/* ===== CARDS ===== */
.card{position:absolute;border-radius:5px;}
.cf{background:#fff;border:1px solid #aaa;box-shadow:1px 2px 4px rgba(0,0,0,.35);cursor:pointer;}
.cf:hover{box-shadow:1px 2px 8px rgba(0,0,0,.5);}

/* ===== HINT: both source AND dest same color ===== */
.cf.hint-pair{
  animation: hint-pulse 0.6s ease-in-out infinite alternate;
  z-index:9000!important;
}
@keyframes hint-pulse{
  from{box-shadow:0 0 0 3px var(--hc),0 0 10px var(--hc-glow);background:var(--hc-bg);}
  to  {box-shadow:0 0 0 4px var(--hc),0 0 22px var(--hc-glow);background:var(--hc-bg);}
}
.ecol.hint-pair{
  animation: hint-border-pulse 0.6s ease-in-out infinite alternate;
}
@keyframes hint-border-pulse{
  from{border-color:var(--hc)!important;box-shadow:0 0 8px var(--hc-glow);}
  to  {border-color:var(--hc)!important;box-shadow:0 0 20px var(--hc-glow);}
}

/* Selected */
.cf.sel{background:#f0ffff!important;box-shadow:0 0 0 3px #00e5ff,0 0 12px rgba(0,229,255,.6)!important;}
.cf.gh{opacity:.28;}

.cbody{width:100%;height:100%;padding:2px 3px;display:flex;flex-direction:column;justify-content:space-between;pointer-events:none;}
.cn{display:flex;flex-direction:column;align-items:flex-start;line-height:1.1;}
.bot{transform:rotate(180deg);align-self:flex-end;}
.rk{font-weight:bold;line-height:1;}
.ss{line-height:1;}
.cc{text-align:center;line-height:1;align-self:center;margin:auto 0;}
.rd{color:#cc0000;}.bk{color:#111;}

#ghost{position:fixed;z-index:9999;pointer-events:none;display:none;filter:drop-shadow(3px 6px 14px rgba(0,0,0,.65));}
#ghost .card{position:relative;}

/* ===== FAB ===== */
#fab{position:fixed;bottom:16px;left:14px;display:flex;gap:10px;z-index:700;}
.fab-btn{
  width:50px;height:50px;border-radius:50%;border:none;cursor:pointer;
  display:flex;align-items:center;justify-content:center;flex-direction:column;gap:1px;
  font-size:9px;font-weight:bold;color:#fff;
  box-shadow:0 4px 12px rgba(0,0,0,.5);
  transition:transform .12s;text-shadow:0 1px 2px rgba(0,0,0,.5);
}
.fab-btn:hover{transform:scale(1.1);}
.fab-btn:active{transform:scale(.9);}
#fab-undo{background:radial-gradient(circle at 35% 35%,#5a8a4d,#2d5a26);}
#fab-hint{background:radial-gradient(circle at 35% 35%,#4a7ab0,#1d4070);}
.fab-icon{font-size:19px;line-height:1;}

/* ===== CARD BACK PICKER ===== */
#back-picker{
  position:fixed;bottom:16px;right:16px;z-index:700;
  display:flex;flex-direction:column;align-items:flex-end;gap:6px;
}
#back-toggle{
  background:radial-gradient(circle at 35% 35%,#7a4ab0,#3d1d70);
  border:none;color:#fff;width:50px;height:50px;border-radius:50%;cursor:pointer;
  display:flex;align-items:center;justify-content:center;flex-direction:column;gap:1px;
  font-size:9px;font-weight:bold;
  box-shadow:0 4px 12px rgba(0,0,0,.5);
  transition:transform .12s;text-shadow:0 1px 2px rgba(0,0,0,.5);
}
#back-toggle:hover{transform:scale(1.1);}
#back-toggle:active{transform:scale(.9);}
#back-menu{
  display:none;
  flex-direction:column;gap:5px;align-items:flex-end;
  background:rgba(0,0,0,.78);border-radius:10px;padding:8px;
  border:1px solid rgba(255,255,255,.12);
}
#back-menu.open{display:flex;}
.back-opt{
  display:flex;align-items:center;gap:8px;cursor:pointer;padding:4px 6px;border-radius:6px;
  transition:background .12s;
}
.back-opt:hover{background:rgba(255,255,255,.1);}
.back-opt.sel-back{background:rgba(255,220,0,.15);outline:1px solid rgba(255,220,0,.4);}
.back-preview{width:32px;height:44px;border-radius:4px;flex-shrink:0;border:1.5px solid rgba(255,255,255,.3);overflow:hidden;}
.back-preview img{width:100%;height:100%;display:block;}
.back-name{color:#fff;font-size:11px;font-weight:bold;white-space:nowrap;}

/* ===== WIN BANNER (no overlay, no darkening) ===== */
#win-banner{
  position:fixed;top:48px;left:50%;transform:translateX(-50%);
  background:linear-gradient(135deg,#1a4a10ee,#2d6a20ee);
  border:2px solid #c8a000;border-radius:12px;
  padding:10px 22px;z-index:8000;
  display:none;flex-direction:column;align-items:center;gap:6px;
  box-shadow:0 4px 24px rgba(0,0,0,.5);
  animation:bannerIn .4s cubic-bezier(.25,.46,.45,.94);
  pointer-events:auto;
}
@keyframes bannerIn{from{transform:translateX(-50%) translateY(-20px);opacity:0}to{transform:translateX(-50%) translateY(0);opacity:1}}
#win-banner h2{color:#ffdd60;font-size:18px;white-space:nowrap;}
#win-banner p{color:#cce8cc;font-size:12px;white-space:nowrap;}
#win-banner .tb{font-size:11px;padding:3px 12px;}

/* ===== DIALOGS (new game only) ===== */
.ov{position:fixed;inset:0;background:rgba(0,0,0,.72);z-index:8000;display:flex;align-items:center;justify-content:center;}
.dlg{background:linear-gradient(180deg,#5a8a4d,#2d5a26);border:3px solid #1a3a10;border-radius:10px;padding:20px 26px;color:#fff;text-align:center;min-width:240px;box-shadow:0 8px 32px rgba(0,0,0,.6);}
.dlg h2{font-size:20px;margin-bottom:8px;}
.dlg p{font-size:13px;color:#cce0cc;margin-bottom:14px;}
.dbs{display:flex;gap:9px;justify-content:center;flex-wrap:wrap;}
.dbs .tb{font-size:12px;padding:5px 16px;}

#fw-canvas{position:fixed;inset:0;z-index:7900;pointer-events:none;display:none;}

@media(max-height:380px){
  #bar{height:34px;}#game{top:34px;}
  .tb{padding:1px 7px;font-size:11px;}
  .fab-btn,#back-toggle{width:42px;height:42px;}.fab-icon{font-size:16px;}
}
</style>
</head>
<body>

<div id="bar">
  <div class="logo">♠ 蜘蛛纸牌</div>
  <div class="sep"></div>
  <button class="tb" id="btn-new">新游戏</button>
  <button class="tb" id="btn-auto">自动完成</button>
  <div class="sep"></div>
  <button class="tb on" data-d="1">1色</button>
  <button class="tb" data-d="2">2色</button>
  <button class="tb" data-d="4">4色</button>
  <div id="stats">
    <span>⏱<span id="tv">0:00</span></span>
    <span>分<span id="sv">500</span></span>
    <span>步<span id="mv2">0</span></span>
  </div>
</div>

<div id="game">
  <div id="tab"></div>
  <div id="sidebar">
    <div id="stockp"></div>
    <div id="stockct">50张</div>
    <div id="done-pile">
      <div id="done-stack"></div>
      <div id="done-ct"></div>
    </div>
  </div>
</div>

<div id="fab">
  <button class="fab-btn" id="fab-undo"><div class="fab-icon">↩</div><div>撤销</div></button>
  <button class="fab-btn" id="fab-hint"><div class="fab-icon">💡</div><div>提示</div></button>
</div>

<!-- Card back picker -->
<div id="back-picker">
  <div id="back-menu"></div>
  <button id="back-toggle"><div style="font-size:18px">🎴</div><div>牌背</div></button>
</div>

<canvas id="fw-canvas"></canvas>
<div id="ghost"></div>

<!-- Win banner: small, no overlay, fireworks keep going -->
<div id="win-banner">
  <h2>🎉 恭喜胜利！</h2>
  <p id="win-msg"></p>
  <button class="tb" onclick="hide('win-banner')">关闭</button>
</div>
<div class="ov" id="ng-dlg" style="display:none">
  <div class="dlg"><h2>♠ 新游戏</h2><p>选择难度：</p>
    <div class="dbs">
      <button class="tb" onclick="startNew(1)">1色 简单</button>
      <button class="tb" onclick="startNew(2)">2色 中等</button>
      <button class="tb" onclick="startNew(4)">4色 困难</button>
      <button class="tb" onclick="hide('ng-dlg')">取消</button>
    </div>
  </div>
</div>

<script>
/* ============================================================
   CARD BACK DESIGNS  — pure SVG, no network needed
============================================================ */
const BACKS = [
  {
    id:'palace',name:'故宫红',
    make(w,h){
      return `<svg xmlns="http://www.w3.org/2000/svg" width="${w}" height="${h}">
      <defs>
        <pattern id="latt${w}" patternUnits="userSpaceOnUse" width="8" height="8">
          <rect width="8" height="8" fill="#8B0000"/>
          <line x1="0" y1="0" x2="8" y2="8" stroke="#a01010" stroke-width="0.5"/>
          <line x1="8" y1="0" x2="0" y2="8" stroke="#a01010" stroke-width="0.5"/>
        </pattern>
      </defs>
      <rect width="${w}" height="${h}" rx="5" fill="url(#latt${w})"/>
      <rect x="2" y="2" width="${w-4}" height="${h-4}" rx="4" fill="none" stroke="#c8a000" stroke-width="1.8"/>
      <rect x="5" y="5" width="${w-10}" height="${h-10}" rx="3" fill="none" stroke="#c8a000" stroke-width="0.7" opacity="0.6"/>
      ${this._corners(w,h)}
      ${this._roof(w,h)}
      ${this._medallion(w,h)}
      </svg>`;
    },
    _corners(w,h){
      const s=Math.round(Math.min(w,h)*0.09);
      return [[9,9],[w-9,9],[9,h-9],[w-9,h-9]].map(([cx,cy])=>
        `<circle cx="${cx}" cy="${cy}" r="${s}" fill="#c8a000" opacity="0.3"/>
         <circle cx="${cx}" cy="${cy}" r="${s*.5}" fill="#8B0000"/>
         <circle cx="${cx}" cy="${cy}" r="${s*.25}" fill="#c8a000" opacity="0.8"/>`
      ).join('');
    },
    _roof(w,h){
      const mid=w/2, rh=Math.round(h*.17), ry=Math.round(h*.08), rw=Math.round(w*.68), rx=(w-rw)/2;
      return `
      <polygon points="${rx+rw*.12},${ry+rh} ${rx},${ry+rh} ${rx+rw*.18},${ry+rh*.4} ${mid},${ry} ${rx+rw*.82},${ry+rh*.4} ${rx+rw},${ry+rh} ${rx+rw*.88},${ry+rh}" fill="#c8a000" opacity="0.5"/>
      <line x1="${rx}" y1="${ry+rh}" x2="${rx+rw}" y2="${ry+rh}" stroke="#c8a000" stroke-width="1.2" opacity="0.8"/>
      <polygon points="${mid},${ry-3} ${mid-3},${ry+4} ${mid+3},${ry+4}" fill="#c8a000" opacity="0.8"/>
      <rect x="${rx+rw*.28}" y="${ry+rh}" width="${rw*.07}" height="${rh*.35}" fill="#c8a000" opacity="0.3"/>
      <rect x="${mid-rw*.035}" y="${ry+rh}" width="${rw*.07}" height="${rh*.35}" fill="#c8a000" opacity="0.3"/>
      <rect x="${rx+rw*.65}" y="${ry+rh}" width="${rw*.07}" height="${rh*.35}" fill="#c8a000" opacity="0.3"/>`;
    },
    _medallion(w,h){
      const cx=w/2,cy=h/2,r=Math.round(Math.min(w,h)*.19);
      let petals='';
      for(let i=0;i<8;i++){
        const a=i*Math.PI/4;
        petals+=`<ellipse cx="${(cx+Math.cos(a)*r*.62).toFixed(1)}" cy="${(cy+Math.sin(a)*r*.62).toFixed(1)}" rx="${(r*.3).toFixed(1)}" ry="${(r*.15).toFixed(1)}" transform="rotate(${i*45} ${(cx+Math.cos(a)*r*.62).toFixed(1)} ${(cy+Math.sin(a)*r*.62).toFixed(1)})" fill="#c8a000" opacity="0.4"/>`;
      }
      return `<circle cx="${cx}" cy="${cy}" r="${r}" fill="none" stroke="#c8a000" stroke-width="1" opacity="0.5"/>
      ${petals}
      <circle cx="${cx}" cy="${cy}" r="${r*.68}" fill="#7a0000" stroke="#c8a000" stroke-width="0.9"/>
      <circle cx="${cx}" cy="${cy}" r="${r*.38}" fill="none" stroke="#c8a000" stroke-width="0.7" opacity="0.6"/>
      <text x="${cx}" y="${cy+r*.32}" text-anchor="middle" font-family="serif" font-size="${r}" fill="#c8a000" opacity="0.95">福</text>`;
    }
  },
  {
    id:'dragon',name:'金龙黑',
    make(w,h){
      const cx=w/2, cy=h/2;
      const scales = Array.from({length:6},(_,row)=>
        Array.from({length:5},(_,col)=>{
          const x=(col-(4/2))*w*.22+cx+(row%2)*w*.11;
          const y=row*(h*.14)+h*.08;
          return `<ellipse cx="${x.toFixed(1)}" cy="${y.toFixed(1)}" rx="${(w*.09).toFixed(1)}" ry="${(h*.07).toFixed(1)}" fill="none" stroke="#b8900030" stroke-width="0.8"/>`;
        }).join('')
      ).join('');
      return `<svg xmlns="http://www.w3.org/2000/svg" width="${w}" height="${h}">
      <rect width="${w}" height="${h}" rx="5" fill="#0d0d1a"/>
      ${scales}
      <rect x="2" y="2" width="${w-4}" height="${h-4}" rx="4" fill="none" stroke="#b89000" stroke-width="1.8"/>
      <rect x="5" y="5" width="${w-10}" height="${h-10}" rx="3" fill="none" stroke="#b89000" stroke-width="0.6" opacity="0.5"/>
      <!-- Dragon body (simplified curvy) -->
      <path d="M${w*.2},${h*.25} Q${w*.55},${h*.18} ${w*.75},${h*.35} Q${w*.9},${h*.5} ${w*.7},${h*.65} Q${w*.5},${h*.82} ${w*.25},${h*.72} Q${w*.08},${h*.6} ${w*.15},${h*.42}" fill="none" stroke="#b89000" stroke-width="${Math.max(2,w*.045)}" opacity="0.55" stroke-linecap="round"/>
      <!-- Dragon head -->
      <circle cx="${w*.2}" cy="${h*.25}" r="${w*.07}" fill="#b89000" opacity="0.5"/>
      <circle cx="${w*.18}" cy="${h*.22}" r="${w*.025}" fill="#ffdd00" opacity="0.8"/>
      <!-- Whisker -->
      <line x1="${w*.2}" y1="${h*.25}" x2="${w*.08}" y2="${h*.15}" stroke="#b89000" stroke-width="1" opacity="0.5"/>
      <line x1="${w*.2}" y1="${h*.25}" x2="${w*.1}" y2="${h*.3}" stroke="#b89000" stroke-width="1" opacity="0.5"/>
      <!-- Claw marks -->
      <path d="M${w*.62},${h*.55} l${w*.05},-${h*.06} l${w*.02},${h*.07}" fill="none" stroke="#b89000" stroke-width="1" opacity="0.45"/>
      <path d="M${w*.68},${h*.53} l${w*.05},-${h*.06} l${w*.02},${h*.07}" fill="none" stroke="#b89000" stroke-width="1" opacity="0.45"/>
      <!-- Corner gems -->
      ${[[8,8],[w-8,8],[8,h-8],[w-8,h-8]].map(([x,y])=>`<polygon points="${x},${y-6} ${x+5},${y} ${x},${y+6} ${x-5},${y}" fill="#b89000" opacity="0.5"/>`).join('')}
      <text x="${cx}" y="${h*.94}" text-anchor="middle" font-family="serif" font-size="${w*.12}" fill="#b89000" opacity="0.4">龙</text>
      </svg>`;
    }
  },
  {
    id:'porcelain',name:'青花瓷',
    make(w,h){
      const cx=w/2, cy=h/2;
      return `<svg xmlns="http://www.w3.org/2000/svg" width="${w}" height="${h}">
      <rect width="${w}" height="${h}" rx="5" fill="#e8f0f8"/>
      <!-- Wave pattern background -->
      ${Array.from({length:8},(_,i)=>{
        const y=i*(h/8);
        return `<path d="M0,${y+h/16} Q${w/4},${y} ${w/2},${y+h/16} Q${w*3/4},${y+h/8} ${w},${y+h/16}" fill="none" stroke="#1a3a7a" stroke-width="0.6" opacity="0.2"/>`;
      }).join('')}
      <!-- Border -->
      <rect x="2" y="2" width="${w-4}" height="${h-4}" rx="4" fill="none" stroke="#1a3a7a" stroke-width="2"/>
      <rect x="5" y="5" width="${w-10}" height="${h-10}" rx="3" fill="none" stroke="#1a3a7a" stroke-width="0.8" opacity="0.5"/>
      <!-- Corner flowers -->
      ${[[10,10],[w-10,10],[10,h-10],[w-10,h-10]].map(([fx,fy])=>
        `<circle cx="${fx}" cy="${fy}" r="${w*.08}" fill="none" stroke="#1a3a7a" stroke-width="0.8" opacity="0.6"/>
         <circle cx="${fx}" cy="${fy}" r="${w*.035}" fill="#1a3a7a" opacity="0.5"/>
         ${Array.from({length:6},(_,k)=>{const a=k*Math.PI/3;return `<line x1="${fx}" y1="${fy}" x2="${(fx+Math.cos(a)*w*.08).toFixed(1)}" y2="${(fy+Math.sin(a)*w*.08).toFixed(1)}" stroke="#1a3a7a" stroke-width="0.6" opacity="0.5"/>`;}).join('')}`
      ).join('')}
      <!-- Center vase -->
      <ellipse cx="${cx}" cy="${cy-.1*h}" rx="${w*.14}" ry="${h*.1}" fill="none" stroke="#1a3a7a" stroke-width="1.2" opacity="0.7"/>
      <line x1="${cx-w*.14}" y1="${cy-.1*h}" x2="${cx-w*.1}" y2="${cy+h*.12}" stroke="#1a3a7a" stroke-width="1.2" opacity="0.7"/>
      <line x1="${cx+w*.14}" y1="${cy-.1*h}" x2="${cx+w*.1}" y2="${cy+h*.12}" stroke="#1a3a7a" stroke-width="1.2" opacity="0.7"/>
      <ellipse cx="${cx}" cy="${cy+h*.12}" rx="${w*.1}" ry="${h*.04}" fill="none" stroke="#1a3a7a" stroke-width="1.2" opacity="0.7"/>
      <line x1="${cx-w*.1}" y1="${cy+h*.12}" x2="${cx-w*.06}" y2="${cy+h*.18}" stroke="#1a3a7a" stroke-width="1.2" opacity="0.7"/>
      <line x1="${cx+w*.1}" y1="${cy+h*.12}" x2="${cx+w*.06}" y2="${cy+h*.18}" stroke="#1a3a7a" stroke-width="1.2" opacity="0.7"/>
      <line x1="${cx-w*.06}" y1="${cy+h*.18}" x2="${cx+w*.06}" y2="${cy+h*.18}" stroke="#1a3a7a" stroke-width="1.2" opacity="0.7"/>
      <!-- Plum blossom on vase -->
      ${Array.from({length:5},(_,k)=>{const a=k*2*Math.PI/5;return `<circle cx="${(cx+Math.cos(a)*w*.07).toFixed(1)}" cy="${(cy+Math.sin(a)*h*.05-.05*h).toFixed(1)}" r="${(w*.035).toFixed(1)}" fill="#1a3a7a" opacity="0.55"/>`;}).join('')}
      <circle cx="${cx}" cy="${cy-.05*h}" r="${w*.03}" fill="#1a3a7a" opacity="0.7"/>
      <text x="${cx}" y="${h*.93}" text-anchor="middle" font-family="serif" font-size="${w*.11}" fill="#1a3a7a" opacity="0.45">瓷</text>
      </svg>`;
    }
  },
  {
    id:'koi',name:'锦鲤金',
    make(w,h){
      const cx=w/2,cy=h/2;
