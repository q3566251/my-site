============================================================ */
let hintTmr=null;
function showHint(){
  clearTimeout(hintTmr);G.hint=null;
  const pairs=[];
  for(let fc=0;fc<10;fc++){
    const col=G.cols[fc];
    // Find lowest liftable index in this column
    let lowestFi=-1;
    for(let fi=0;fi<col.length;fi++){
      if(canLift(fc,fi)){lowestFi=fi;break;}
    }
    if(lowestFi<0)continue;
    for(let tc=0;tc<10;tc++){
      if(!canPlace(fc,lowestFi,tc))continue;
      const ss=G.cols[tc].length&&G.cols[tc].at(-1).s===col[lowestFi].s;
      pairs.push({fc,fi:lowestFi,tc,ss});
    }
  }
  if(!pairs.length)return;
  pairs.sort((a,b)=>b.ss-a.ss);
  const best=pairs[0];
  const col=HINT_COLORS[hintColorIdx % HINT_COLORS.length];
  hintColorIdx++;
  G.hint={fc:best.fc, fi:best.fi, tc:best.tc,
          di:G.cols[best.tc].length-1,
          col:col.c, glow:col.glow, bg:col.bg};
  render();
  hintTmr=setTimeout(()=>{G.hint=null;render();},2800);
}

