   DRAG — fixed for mobile: use capture phase, track by identifier
============================================================ */

/* ============================================================
   DRAG  — completely rewritten for reliable mobile touch
============================================================ */
/* ============================================================
   DRAG — iOS Safari compatible
   Key rules:
   1. NEVER call render()/renderTab() while a touch is active
      (rebuilding DOM kills the touch tracking on iOS)
   2. Manually dim source cards via direct style, not re-render
   3. Use e.touches (not changedTouches) for move tracking
   4. touchmove on document with passive:false to allow preventDefault
   5. Use requestAnimationFrame for ghost movement
============================================================ */
let drag=null;
let lastTouchEnd=0;
let ghostRAF=null;
let pendingX=0, pendingY=0;

function buildGhost(ci,idx){
  const {CW,CH,OV,RK,SS,CC}=SZ;
  const cards=G.cols[ci].slice(idx);
  const g=$('ghost');
  g.innerHTML='';
  g.style.cssText=[
    'display:block',
    `width:${CW}px`,
    `height:${CH+(cards.length-1)*OV}px`,
    'position:fixed',
    'z-index:9999',
    'pointer-events:none',
    'will-change:transform',
    'opacity:0.92',
    'filter:drop-shadow(2px 6px 12px rgba(0,0,0,.6))'
  ].join(';');
  cards.forEach((card,i)=>{
    const w=document.createElement('div');
    w.style.cssText=`position:absolute;top:${i*OV}px;width:${CW}px`;
    w.appendChild(mkFace(card,ci,idx+i,'',null,CW,CH,RK,SS,CC));
    g.appendChild(w);
  });
}

// Dim source card elements directly — no DOM rebuild
function dimSourceCards(ci,idx){
  const wrappers=document.querySelectorAll(`#tab .col[data-ci="${ci}"] .coli > div`);
  wrappers.forEach((w,i)=>{
    if(i>=idx){
      const card=w.querySelector('.cf,.cb');
      if(card) card.style.opacity='0.25';
    }
  });
}
function undimAll(){
  document.querySelectorAll('#tab .cf,.cb').forEach(c=>c.style.opacity='');
}

function placeGhost(x,y){
  if(!drag)return;
  const g=$('ghost');
  // Use transform for smooth 60fps on iOS
  g.style.left='0px';
  g.style.top='0px';
  g.style.transform=`translate(${x-drag.ox}px,${y-drag.oy}px)`;
}

function scheduleGhostMove(x,y){
  pendingX=x; pendingY=y;
  if(ghostRAF)return;
  ghostRAF=requestAnimationFrame(()=>{
    ghostRAF=null;
    placeGhost(pendingX,pendingY);
  });
}

function startDrag(ci,idx,x,y,touchId){
  if(!canLift(ci,idx))return false;
  resumeAC();
  G.sel=null;
  const {CW,CH}=SZ;
  buildGhost(ci,idx);
  drag={ci,idx,ox:CW/2,oy:Math.min(32,CH*.28),id:touchId};
  G.drag={ci,idx};
  placeGhost(x,y);
  // DO NOT call render() here — it destroys DOM and breaks iOS touch
  // Instead, dim source cards directly
  dimSourceCards(ci,idx);
  return true;
}

function stopDrag(x,y){
  if(ghostRAF){ cancelAnimationFrame(ghostRAF); ghostRAF=null; }
  const g=$('ghost');
  g.style.display='none';
  undimAll();
  if(!drag)return;
  const{ci:fc,idx:fi}=drag;
  drag=null; G.drag=null;
  // Find column under finger
  const el=document.elementFromPoint(x,y);
  const co=el && el.closest('.col');
  const tc=(co && co.dataset.ci!=null) ? +co.dataset.ci : NaN;
  if(!isNaN(tc) && canPlace(fc,fi,tc)){ doMove(fc,fi,tc); afterMove(); }
  else render();
}

// Block Safari long-press context menu
document.addEventListener('contextmenu', e=>e.preventDefault());

// ---- Mouse ----
$('tab').addEventListener('mousedown',e=>{
  if(e.button!==0)return;
  const ce=e.target.closest('.cf'); if(!ce)return;
  e.preventDefault();
  startDrag(+ce.dataset.ci,+ce.dataset.idx,e.clientX,e.clientY,-1);
},{passive:false});
document.addEventListener('mousemove',e=>{
  if(drag&&drag.id===-1) scheduleGhostMove(e.clientX,e.clientY);
});
document.addEventListener('mouseup',e=>{
  if(drag&&drag.id===-1) stopDrag(e.clientX,e.clientY);
});

// ---- Touch (iOS Safari safe) ----
$('tab').addEventListener('touchstart',e=>{
  e.preventDefault();   // MUST be first — prevents long-press menu + scroll
  if(drag)return;
  const t=e.changedTouches[0];
  // Walk up from target to find the face-up card
  const ce=t.target.closest('.cf');
  if(!ce)return;
  startDrag(+ce.dataset.ci,+ce.dataset.idx,t.clientX,t.clientY,t.identifier);
},{passive:false});

// touchmove on document — must be passive:false to call preventDefault
document.addEventListener('touchmove',e=>{
  if(!drag||drag.id===-1)return;
  // Use e.touches to find our finger (more reliable on iOS than changedTouches)
  let found=null;
  for(let i=0;i<e.touches.length;i++){
    if(e.touches[i].identifier===drag.id){ found=e.touches[i]; break; }
  }
  if(!found)return;
  e.preventDefault();
  scheduleGhostMove(found.clientX,found.clientY);
},{passive:false});

document.addEventListener('touchend',e=>{
  if(!drag||drag.id===-1)return;
  for(let i=0;i<e.changedTouches.length;i++){
    const t=e.changedTouches[i];
    if(t.identifier===drag.id){
      lastTouchEnd=Date.now();
      stopDrag(t.clientX,t.clientY);
      return;
    }
  }
},{passive:true});

document.addEventListener('touchcancel',e=>{
  if(!drag||drag.id===-1)return;
  if(ghostRAF){ cancelAnimationFrame(ghostRAF); ghostRAF=null; }
  $('ghost').style.display='none';
  undimAll();
  drag=null; G.drag=null;
  render();
},{passive:true});

