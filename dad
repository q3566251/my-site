let fwRAF=null,fwP=[];
const fwC=$('fw-canvas'),fwX=fwC.getContext('2d');
function startFW(){
  fwC.style.display='block';fwC.width=window.innerWidth;fwC.height=window.innerHeight;fwP=[];
  let n=0;
  function launch(){fwP.push({type:'r',x:Math.random()*fwC.width,y:fwC.height,tx:Math.random()*fwC.width,ty:fwC.height*(0.08+Math.random()*.45),col:`hsl(${0|Math.random()*360},100%,62%)`,sp:14+Math.random()*5});if(++n<22)setTimeout(launch,200+Math.random()*500);}
  launch();fwRAF=requestAnimationFrame(fwLoop);
}
function fwLoop(){
  fwX.fillStyle='rgba(0,0,0,.17)';fwX.fillRect(0,0,fwC.width,fwC.height);
  const alive=[];
  for(const p of fwP){
    if(p.type==='r'){
      const dx=p.tx-p.x,dy=p.ty-p.y,d=Math.sqrt(dx*dx+dy*dy);
      if(d<p.sp+2){for(let i=0;i<90;i++){const a=Math.random()*Math.PI*2,s=2+Math.random()*6;alive.push({type:'s',x:p.x,y:p.y,vx:Math.cos(a)*s,vy:Math.sin(a)*s,col:p.col,life:1,dec:.013+Math.random()*.018,sz:1.5+Math.random()*2});}}
      else{p.x+=dx/d*p.sp;p.y+=dy/d*p.sp;fwX.beginPath();fwX.arc(p.x,p.y,2.5,0,Math.PI*2);fwX.fillStyle=p.col;fwX.fill();alive.push(p);}
    }else{
      p.x+=p.vx;p.y+=p.vy;p.vy+=.09;p.vx*=.98;p.life-=p.dec;
      if(p.life>0){fwX.beginPath();fwX.arc(p.x,p.y,p.sz*p.life,0,Math.PI*2);fwX.fillStyle=p.col;fwX.globalAlpha=p.life;fwX.fill();fwX.globalAlpha=1;alive.push(p);}
    }
  }
  fwP=alive;
  if(fwP.length)fwRAF=requestAnimationFrame(fwLoop);else stopFW();
}
function stopFW(){if(fwRAF){cancelAnimationFrame(fwRAF);fwRAF=null;}fwC.style.display='none';fwX.clearRect(0,0,fwC.width,fwC.height);fwP=[];}
