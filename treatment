      <tr style="border-bottom:1px solid var(--border-light);">
        <td style="padding:11px 14px;font-weight:500;color:var(--text);">ADHD</td>
        <td style="padding:11px 14px;color:var(--text-muted);"><span class="tag" style="background:rgba(0,113,227,0.08);color:#0071e3;">CBT</span>（成人）行为管理（儿童）</td>
        <td style="padding:11px 14px;color:var(--text-muted);">正念（MBCT）、结构化行为训练</td>
        <td style="padding:11px 14px;color:var(--accent3);font-size:12px;">单纯谈话无行为结构效果有限</td>
      </tr>
      <!-- SOMATIC -->
      <tr style="background:rgba(255,107,107,0.04);"><td colspan="4" style="padding:8px 14px;font-size:11px;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;color:var(--accent3);">躯体/其他 Somatic &amp; Other</td></tr>
      <tr style="border-bottom:1px solid var(--border-light);">
        <td style="padding:11px 14px;font-weight:500;color:var(--text);">Somatic Symptom Disorder</td>
        <td style="padding:11px 14px;color:var(--text-muted);"><span class="tag" style="background:rgba(0,113,227,0.08);color:#0071e3;">CBT</span> + 正念身体扫描</td>
        <td style="padding:11px 14px;color:var(--text-muted);">ACT、Psychodynamic（躯体化防御）</td>
        <td style="padding:11px 14px;color:var(--accent3);font-size:12px;">否认症状的真实性会破坏治疗联盟</td>
      </tr>
      <tr style="border-bottom:1px solid var(--border-light);">
        <td style="padding:11px 14px;font-weight:500;color:var(--text);">Grief / Bereavement</td>
        <td style="padding:11px 14px;color:var(--text-muted);"><span class="tag" style="background:rgba(52,170,220,0.12);color:#0077b5;">Person-Centered</span> + 哀伤处理</td>
        <td style="padding:11px 14px;color:var(--text-muted);">Narrative（重写关系故事）、支持团体</td>
        <td style="padding:11px 14px;color:var(--accent3);font-size:12px;">过快推进"接受"会强化来访者压抑悲伤</td>
      </tr>
      <tr>
        <td style="padding:11px 14px;font-weight:500;color:var(--text);">Insomnia 失眠</td>
        <td style="padding:11px 14px;color:var(--text-muted);"><span class="tag" style="background:rgba(0,113,227,0.08);color:#0071e3;">CBT-I</span> 失眠认知行为疗法（睡眠限制、刺激控制）</td>
        <td style="padding:11px 14px;color:var(--text-muted);">正念、放松训练</td>
        <td style="padding:11px 14px;color:var(--accent3);font-size:12px;">安眠药长期使用不是首选</td>
      </tr>
    </tbody>
  </table>
  </div>

  <div class="highlight">
    <div class="highlight-title">快速记忆口诀</div>
    <p>
      <b>焦虑</b> → CBT + 暴露 &nbsp;|&nbsp;
      <b>抑郁</b> → CBT + 行为激活 &nbsp;|&nbsp;
      <b>双相</b> → IPSRT + 药 &nbsp;|&nbsp;
      <b>PTSD</b> → EMDR / TF-CBT &nbsp;|&nbsp;
      <b>BPD</b> → DBT 首选 &nbsp;|&nbsp;
      <b>OCD</b> → ERP（不是普通CBT）&nbsp;|&nbsp;
      <b>ASD</b> → ABA &nbsp;|&nbsp;
      <b>物质</b> → MI + CBT &nbsp;|&nbsp;
      <b>厌食青少年</b> → FBT Maudsley &nbsp;|&nbsp;
      <b>人格障碍</b> → Schema / Psychodynamic / DBT（视类型）
    </p>
  </div>
</div>

</main>

<script>
function show(id, el) {
  document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  el.classList.add('active');
  window.scrollTo({ top: 0, behavior: 'smooth' });
}
</script>
</body>
