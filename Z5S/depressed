    +'</div></div>'

    // Overview
    +'<div class="rcard"><div class="card-label">失调分布总览（过载 vs 停摆，各满分 5）</div>'+overviewHtml+'</div>'

    // Per system
    +'<div class="rcard"><div class="card-label" style="margin-bottom:1rem">五个系统的低落状态解读</div>'+detailHtml+'</div>'

    +'<div style="text-align:center;margin-top:1.5rem;padding-bottom:2.5rem">'
    +'<button onclick="resetAll()" style="background:#fff;color:#666;border:1px solid #ddd;border-radius:10px;padding:.85rem 2.5rem;font-size:14px;cursor:pointer;font-family:inherit">重新测评</button>'
    +'</div>';

  goTo(3);
  requestAnimationFrame(function(){requestAnimationFrame(function(){
    document.querySelectorAll('[data-w]').forEach(function(el){el.style.width=el.getAttribute('data-w')+'%';});
  });});
}

function resetAll(){
  ans={};
  buildQuestions();
  document.getElementById('qcount').textContent='0 / 10';
  document.getElementById('qbar').style.width='0%';
  var btn=document.getElementById('qnext');
  btn.disabled=true;btn.textContent='还有 10 题未选';
  goTo(0);
}

buildSliders();
buildQuestions();
</script>
</body>
</html>
