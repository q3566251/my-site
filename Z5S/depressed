var z5sScores={A:5,B:5,C:5,D:5,E:5};
var ans={};

function buildSliders(){
  var c=document.getElementById('sliders');c.innerHTML='';
  ['A','B','C','D','E'].forEach(function(k){
    var s=SYS[k];
    c.innerHTML+='<div class="zscore-row">'
      +'<div class="zscore-icon">'+s.icon+'</div>'
      +'<div class="zscore-name" style="color:'+s.tc+'">'+s.zh+'</div>'
      +'<input type="range" class="zscore-slider" min="0" max="10" step="1" value="5" id="sl-'+k+'" style="accent-color:'+s.color+'" '
      +'oninput="z5sScores[\''+k+'\']=+this.value;document.getElementById(\'sv-'+k+'\').textContent=this.value">'
      +'<div class="zscore-num" id="sv-'+k+'" style="color:'+s.color+'">5</div>'
      +'</div>';
  });
}

function buildQuestions(){
  var c=document.getElementById('questions');c.innerHTML='';
  QS.forEach(function(q,i){
    var s=SYS[q.sys];
    var btns=SCALE.map(function(sc){
      return '<button class="sbt" id="b_'+i+'_'+sc.v+'" onclick="setAns('+i+','+sc.v+',\''+q.sys+'\')">'
        +sc.v+'<span class="sl">'+sc.l.replace('\n','<br>')+'</span></button>';
    }).join('');
    c.innerHTML+='<div class="qcard">'
      +'<div class="qcard-top"><div class="qnum">'+(i+1)+'</div>'
      +'<div class="qtext">'+q.text+'</div></div>'
      +'<div class="scale-row">'+btns+'</div>'
      +'<div class="scale-ends"><span>完全不像我</span><span>非常像我</span></div>'
      +'</div>';
  });
}

function setAns(qi,val,sys){
  ans[qi]=val;
  var colors=SYS_COLORS[sys];
  SCALE.forEach(function(sc){
    var el=document.getElementById('b_'+qi+'_'+sc.v);
    if(sc.v===val){el.className='sbt sel';el.style.background=colors[sc.v-1];el.style.borderColor=colors[sc.v-1];}
    else{el.className='sbt dim';el.style.background='';el.style.borderColor='';}
  });
  var done=Object.keys(ans).length;
  document.getElementById('qcount').textContent=done+' / 10';
  document.getElementById('qbar').style.width=(done/10*100)+'%';
  var btn=document.getElementById('qnext');
  btn.disabled=done<10;
  btn.textContent=done<10?'还有 '+(10-done)+' 题未选':'查看结果 →';
}

function goTo(n){
  document.querySelectorAll('.page').forEach(function(p){p.classList.remove('active');});
  document.getElementById('p'+n).classList.add('active');
  window.scrollTo(0,0);
}

function getBaselineLevel(score){
  if(score>=6) return 'high';
  if(score>=3) return 'mid';
  return 'low';
}

function getPattern(amp,col){
  var highAmp=amp>=4, highCol=col>=4;
  if(highAmp&&highCol) return 'mixed';
  if(highAmp) return 'amp';
  if(highCol) return 'col';
  return 'stable';
}

