<!DOCTYPE html>
<html lang="zh">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Z5S Measure</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:-apple-system,BlinkMacSystemFont,"PingFang SC","Hiragino Sans GB",sans-serif;background:#f5f4f0;min-height:100vh;color:#1a1a1a}
.page{display:none}.page.active{display:block}
.wrap{max-width:660px;margin:0 auto;padding:2rem 1.25rem}

/* intro */
.hero{background:linear-gradient(135deg,#EEEDFE,#E6F1FB);border-radius:16px;padding:2.25rem 2rem;text-align:center;margin-bottom:2rem}
.hero h1{font-size:28px;font-weight:700;color:#2a2060;margin-bottom:.4rem;letter-spacing:-.3px}
.hero .sub{font-size:13px;color:#7F77DD;font-weight:500;letter-spacing:.06em;text-transform:uppercase;margin-bottom:.75rem}
.hero p{font-size:15px;color:#534AB7;line-height:1.6}
.info-card{background:#fff;border:1px solid #e8e6e0;border-radius:12px;padding:1.25rem 1.5rem;margin-bottom:1.5rem;box-shadow:0 1px 3px rgba(0,0,0,.04)}
.info-row{display:flex;align-items:center;gap:10px;font-size:13.5px;color:#555;margin-bottom:.6rem;line-height:1.5}
.info-row:last-child{margin-bottom:0}
.info-dot{width:6px;height:6px;border-radius:50%;background:#7F77DD;flex-shrink:0}

/* progress */
.prog-wrap{margin-bottom:1.75rem}
.prog-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:.5rem}
.prog-label{font-size:13px;font-weight:600;color:#555}
.prog-count{font-size:13px;font-weight:700;color:#7F77DD}
.prog-bar{height:5px;background:#e8e6e0;border-radius:3px}
.prog-fill{height:100%;background:#7F77DD;border-radius:3px;transition:width .35s ease}
.prog-hint{font-size:12px;color:#aaa;margin-top:.6rem}

/* question card */
.qcard{background:#fff;border:1px solid #e8e6e0;border-radius:12px;padding:1.25rem 1.5rem;margin-bottom:.85rem;box-shadow:0 1px 3px rgba(0,0,0,.04);position:relative}
.qcard-top{display:flex;align-items:flex-start;gap:10px;margin-bottom:1rem}
.qnum{font-size:11px;font-weight:700;color:#bbb;min-width:22px;padding-top:3px;flex-shrink:0}
.qtext{font-size:15px;line-height:1.7;color:#1a1a1a;flex:1}

/* tooltip trigger - top right of card */
.tip-trigger{position:absolute;top:14px;right:14px;width:22px;height:22px;border-radius:50%;border:1.5px solid #d0cee8;background:#fff;cursor:pointer;font-size:11px;font-weight:700;color:#9990e0;display:flex;align-items:center;justify-content:center;transition:all .15s;flex-shrink:0;z-index:3;line-height:1}
.tip-trigger:hover{border-color:#7F77DD;color:#534AB7;background:#EEEDFE}
.tip-trigger.active{border-color:#7F77DD;background:#EEEDFE;color:#534AB7}

/* tooltip box - absolute to card */
.tipbox{display:none;position:absolute;top:44px;right:14px;width:250px;background:#fff;border:1px solid #ddd;border-radius:10px;padding:.9rem 1rem;font-size:13px;line-height:1.65;color:#444;box-shadow:0 6px 20px rgba(0,0,0,.12);z-index:100}
.tipbox.show{display:block}
.tipbox-title{font-size:11px;font-weight:700;color:#9990e0;letter-spacing:.05em;text-transform:uppercase;margin-bottom:.4rem}
@media(max-width:520px){.tipbox{right:0;left:0;width:auto}}

/* likert */
.likert{display:flex;align-items:center;gap:8px;justify-content:space-between}
.llabel{font-size:11px;color:#aaa;white-space:nowrap;line-height:1.3}
.lbtns{display:flex;gap:7px}
.lbtn{width:38px;height:38px;border-radius:50%;border:1.5px solid #ddd;background:#fff;cursor:pointer;font-size:13.5px;font-weight:600;color:#999;transition:all .15s;display:flex;align-items:center;justify-content:center}
.lbtn:hover{border-color:#7F77DD;color:#7F77DD;background:#EEEDFE}
.lbtn.sel{background:#7F77DD;border-color:#7F77DD;color:#fff}

/* nav buttons */
.btn-row{display:flex;gap:12px;margin-top:1.75rem;padding-bottom:2.5rem}
.btnP{background:#534AB7;color:#fff;border:none;border-radius:10px;padding:.85rem 2rem;font-size:15px;font-weight:500;cursor:pointer;flex:1;transition:background .15s}
.btnP:hover{background:#3C3489}
.btnP:disabled{opacity:.35;cursor:not-allowed}
.btnS{background:#fff;color:#666;border:1px solid #ddd;border-radius:10px;padding:.8rem 1.5rem;font-size:14px;cursor:pointer}
.btnS:hover{background:#f5f4f0}
.btnFull{width:100%;font-size:16px;padding:1rem}

/* results */
.r-header{border-bottom:1px solid #f0eeea;padding-bottom:1.5rem;margin-bottom:1.5rem}
.eyebrow{font-size:11px;color:#aaa;letter-spacing:.07em;text-transform:uppercase;font-weight:600;margin-bottom:.35rem}
.card-label{font-size:11px;color:#aaa;letter-spacing:.06em;text-transform:uppercase;font-weight:600;margin-bottom:1rem}
.rcard{background:#fff;border:1px solid #e8e6e0;border-radius:12px;padding:1.4rem 1.5rem;margin-bottom:1rem;box-shadow:0 1px 3px rgba(0,0,0,.04)}
.primary-row{display:flex;align-items:center;gap:14px}
.p-icon{width:56px;height:56px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:26px;flex-shrink:0}
.p-name{font-size:21px;font-weight:700}
.p-desc{font-size:12.5px;color:#999;margin-top:3px;line-height:1.4}
.p-score{font-size:32px;font-weight:700;margin-left:auto;flex-shrink:0}
.dom-badge{display:inline-block;padding:5px 16px;border-radius:20px;font-size:13px;font-weight:700;margin-bottom:1rem}
.bar-row{margin-bottom:.9rem}
.bar-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:.35rem}
.bar-name{font-size:13px;font-weight:600}
.bar-score{font-size:13px;color:#888;font-weight:500}
.bar-track{height:8px;background:#f0eeea;border-radius:4px;overflow:hidden}
.bar-fill{height:100%;border-radius:4px;transition:width 1s ease}
.chip{display:inline-block;padding:4px 13px;border-radius:20px;font-size:12px;font-weight:600;margin-right:5px;margin-bottom:5px}
.interpret-box{background:#fafaf8;border:1px solid #eeebe5;border-radius:10px;padding:1.25rem;font-size:14.5px;line-height:1.85;color:#2a2a2a}
.sys-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:1rem}
.sys-item{border-radius:10px;padding:.9rem 1rem}
.sys-item .sn{font-size:13px;font-weight:700;margin-bottom:3px}
.sys-item .sd{font-size:11px;opacity:.8;line-height:1.4}
@media(max-width:480px){
  .lbtns{gap:5px}.lbtn{width:34px;height:34px;font-size:12px}
  .wrap{padding:1rem .85rem}.p-score{font-size:26px}
  .sys-grid{grid-template-columns:1fr}
}
</style>
</head>
<body>

<!-- INTRO -->
<div id="p0" class="page active">
<div class="wrap">
  <div class="hero">
    <div class="sub">Z5S Measure · Version 1</div>
    <h1>人格系统测评</h1>
    <p>了解你的主导人格系统是什么——<br>你用哪种方式认识世界、做决定、与人连接</p>
  </div>
  <div class="info-card">
    <div class="info-row"><div class="info-dot"></div>共 <strong>30 道题</strong>，每题 1–5 分，约需 5 分钟</div>
    <div class="info-row"><div class="info-dot"></div>没有好坏对错，选最符合你真实状态的</div>
    <div class="info-row"><div class="info-dot"></div>题目旁的 <strong style="color:#7F77DD">?</strong> 可以看题目解释</div>
    <div class="info-row"><div class="info-dot"></div>完成后揭晓你的主导系统与详细解读</div>
  </div>
  <button class="btnP btnFull" onclick="goTo(1)">开始测评</button>
</div>
</div>

<!-- QUESTIONS -->
<div id="p1" class="page">
<div class="wrap">
  <div class="prog-wrap">
    <div class="prog-top">
      <span class="prog-label">Z5S Measure V1</span>
      <span class="prog-count" id="qcount">0 / 30</span>
    </div>
    <div class="prog-bar"><div class="prog-fill" id="qbar" style="width:0%"></div></div>
    <div class="prog-hint">1 = 完全不符合 &nbsp;·&nbsp; 5 = 非常符合</div>
  </div>
  <div id="questions"></div>
  <div class="btn-row">
    <button class="btnS" onclick="goTo(0)">← 返回</button>
    <button class="btnP" id="qnext" disabled onclick="showResults()">查看结果 →</button>
  </div>
</div>
</div>

<!-- RESULTS -->
<div id="p2" class="page">
<div class="wrap" id="results"></div>
</div>

<script>
