    strong:'你的主导系统是游戏系统，且倾向非常明显。你对世界的默认操作是"探索和体验"——好奇心、乐趣感和创造力是你的驱动力，你在新奇事物里感到最有活力，也最擅长在僵局中找到新的玩法。',
    moderate:'你的主导系统是游戏系统。你天然地被新鲜、有趣的事物吸引，会通过创造和探索来恢复能量，也能在压力里找到轻松的缝隙——这是一种宝贵的弹性。',
    mild:'你的主导系统倾向游戏系统，但不是特别突出。你有好奇心和创造力，但也会认真对待严肃的事，不是纯粹的"什么都好玩"型。',
  },
};

const SECONDARY_NOTE={
  A:'副系统是解释系统，说明你在决策和应对时也会调用分析和理解的能力——行动和感受背后，常有一套逻辑在支撑。',
  B:'副系统是执行系统，说明你在主系统之外也有很强的行动驱动力——需要时能快速切换到推进模式。',
  C:'副系统是情感系统，说明情绪感知和共情是你重要的辅助工具——理性或行动背后，情感信号一直在被处理。',
  D:'副系统是认同系统，说明价值观和自我认同在你的决策中扮演重要角色——做选择时"这是不是我"是一个真实的考量。',
  E:'副系统是游戏系统，说明你有弹性和创造力作为辅助——在主系统遇到瓶颈时，探索和好奇心会帮你找到新出路。',
};

// ── 状态 ─────────────────────────────────────────────────
const ans={};
let activeTooltipId=null;

function closeTip(){
  if(activeTooltipId){
    const el=document.getElementById(activeTooltipId);
    if(el){el.classList.remove('show');}
    const btn=document.getElementById('btn_'+activeTooltipId);
    if(btn){btn.classList.remove('active');}
    activeTooltipId=null;
  }
}

function toggleTip(id,e){
  e.stopPropagation();
  if(activeTooltipId===id){closeTip();return;}
  closeTip();
  const el=document.getElementById(id);
  const btn=document.getElementById('btn_'+id);
  if(!el||!btn)return;
  el.classList.add('show');
  btn.classList.add('active');
  activeTooltipId=id;
}

document.addEventListener('click',closeTip);

// ── 构建题目 ─────────────────────────────────────────────
function buildQuestions(){
  const c=document.getElementById('questions');
  QS.forEach((q,i)=>{
    const tid='tip_'+i;
    c.innerHTML+=`
    <div class="qcard">
      <button class="tip-trigger" id="btn_${tid}" onclick="toggleTip('${tid}',event)" title="看题目解释">?</button>
      <div class="tipbox" id="${tid}" onclick="event.stopPropagation()">
        <div class="tipbox-title">题目说明</div>
        ${q.tip}
      </div>
      <div class="qcard-top">
        <div class="qnum">${i+1}</div>
        <div class="qtext">${q.t}</div>
      </div>
      <div class="likert">
        <div class="llabel">完全<br>不符合</div>
        <div class="lbtns">
          ${[1,2,3,4,5].map(v=>`<button class="lbtn" id="q${i}_${v}" onclick="setAns(${i},${v})">${v}</button>`).join('')}
        </div>
        <div class="llabel">非常<br>符合</div>
      </div>
    </div>`;
  });
}

function setAns(qi,val){
  for(let v=1;v<=5;v++){
    const b=document.getElementById(`q${qi}_${v}`);
    if(b)b.classList.toggle('sel',v===val);
  }
  ans[qi]=val;
  const done=Object.keys(ans).length;
  document.getElementById('qcount').textContent=`${done} / 30`;
  document.getElementById('qbar').style.width=`${done/30*100}%`;
  const btn=document.getElementById('qnext');
  btn.disabled=done<30;
  btn.textContent=done<30?`还有 ${30-done} 题未填`:'查看结果 →';
}

// ── 页面导航 ─────────────────────────────────────────────
function goTo(n){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.getElementById('p'+n).classList.add('active');
  window.scrollTo(0,0);
  closeTip();
}

// ── 计算结果 ─────────────────────────────────────────────
function showResults(){
  // 计分
  const scores={A:0,B:0,C:0,D:0,E:0};
  QS.forEach((q,i)=>{if(ans[i])scores[q.s]+=ans[i];});

  const sorted=Object.entries(scores).sort((a,b)=>b[1]-a[1]);
  const [pk,pv]=sorted[0];
  const [sk,sv]=sorted[1];

  // Dominance level
  let domLevel,domLabel,domColor,domBg;
  if(pv>=26){domLevel='strong';domLabel='Strong Dominant';domColor='#3B6D11';domBg='#EAF3DE';}
  else if(pv>=21){domLevel='moderate';domLabel='Moderate Dominant';domColor='#185FA5';domBg='#E6F1FB';}
  else if(pv>=16){domLevel='mild';domLabel='Mild Dominant';domColor='#854F0B';domBg='#FAEEDA';}
  else{domLevel='mild';domLabel='No Clear Dominant';domColor='#666';domBg='#f0eeea';}

  const interpret=DESCRIBE[pk][domLevel]+'\n\n'+SECONDARY_NOTE[sk];

  document.getElementById('results').innerHTML=`
    <div class="r-header">
      <div class="eyebrow">Z5S Measure · V1 结果</div>
      <h2 style="font-size:24px;font-weight:700;margin-bottom:.4rem">你的人格系统图谱</h2>
      <p style="font-size:13px;color:#888">基于 30 道题的作答分析</p>
    </div>

    <div class="rcard" style="border-left:4px solid ${SYS[pk].color}">
      <div class="card-label">Primary System · 主导系统</div>
      <div class="primary-row">
        <div class="p-icon" style="background:${SYS[pk].bg}">${SYS[pk].icon}</div>
        <div style="flex:1">
          <div class="p-name" style="color:${SYS[pk].tc}">${SYS[pk].zh}</div>
          <div class="p-desc">${SYS[pk].name} · ${SYS[pk].desc}</div>
        </div>
        <div class="p-score" style="color:${SYS[pk].color}">${pv}<span style="font-size:14px;font-weight:400;color:#aaa">/30</span></div>
      </div>
      <div style="margin-top:1rem">
        <span class="dom-badge" style="background:${domBg};color:${domColor}">${domLabel}</span>
        <div style="font-size:13px;color:#888;line-height:1.5">
          Secondary: <strong style="color:${SYS[sk].tc}">${SYS[sk].zh}</strong> (${SYS[sk].name}) &nbsp;·&nbsp; ${sv}/30
        </div>
      </div>
    </div>

    <div class="rcard">
      <div class="card-label">五系统得分分布</div>
      ${sorted.map(([k,v],i)=>`
        <div class="bar-row">
          <div class="bar-head">
            <span class="bar-name" style="color:${SYS[k].color}">
              ${SYS[k].icon} ${SYS[k].zh}
              ${i===0?`<span style="font-size:11px;color:#bbb;font-weight:400;margin-left:6px">Primary</span>`:''}
              ${i===1?`<span style="font-size:11px;color:#bbb;font-weight:400;margin-left:6px">Secondary</span>`:''}
            </span>
            <span class="bar-score">${v} / 30</span>
          </div>
          <div class="bar-track">
            <div class="bar-fill" style="width:${Math.round(v/30*100)}%;background:${SYS[k].color}"></div>
          </div>
        </div>`).join('')}
    </div>

    <div class="rcard">
      <div class="card-label">Dominance Level · 主导强度</div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:.75rem">
        ${[['26–30','Strong Dominant','#3B6D11','#EAF3DE'],['21–25','Moderate Dominant','#185FA5','#E6F1FB'],['16–20','Mild Dominant','#854F0B','#FAEEDA'],['< 16','No Clear Dominant','#777','#f0eeea']].map(([range,label,tc,bg])=>`
          <div style="background:${bg};border-radius:8px;padding:.65rem .85rem;${label===domLabel?'outline:2px solid '+tc:''}">
            <div style="font-size:11px;font-weight:700;color:${tc}">${range}</div>
            <div style="font-size:12px;color:${tc};opacity:.85;margin-top:1px">${label}</div>
          </div>`).join('')}
      </div>
      <div style="font-size:13px;color:#888;line-height:1.6">
        你的主导系统得分 <strong style="color:${SYS[pk].color}">${pv}</strong>，属于 <strong style="color:${domColor}">${domLabel}</strong>。
      </div>
    </div>

    <div class="rcard">
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:1rem">
        <div style="width:24px;height:24px;border-radius:6px;background:#EEEDFE;display:flex;align-items:center;justify-content:center;font-size:12px;flex-shrink:0">✦</div>
        <div class="card-label" style="margin-bottom:0">系统解读</div>
      </div>
      <div class="interpret-box">${interpret}</div>
    </div>

    <div class="rcard">
      <div class="card-label">五个系统是什么？</div>
      <p style="font-size:13px;color:#888;margin-bottom:1rem;line-height:1.6">每个人都同时拥有这五种系统，只是主导的优先级不同。</p>
      <div class="sys-grid">
        ${Object.entries(SYS).map(([k,s])=>`
          <div class="sys-item" style="background:${s.bg}${k===pk?';outline:2px solid '+s.color:''}">
            <div class="sn" style="color:${s.tc}">${s.icon} ${s.zh} ${k===pk?'★':''}</div>
            <div class="sd" style="color:${s.tc}">${s.desc}</div>
          </div>`).join('')}
      </div>
    </div>

    <div style="text-align:center;margin-top:2rem;padding-bottom:2.5rem">
      <button style="background:#fff;color:#666;border:1px solid #ddd;border-radius:10px;padding:.85rem 2.5rem;font-size:14px;cursor:pointer" onclick="resetAll()">重新测评</button>
    </div>`;

  goTo(2);
}

// ── 重置 ─────────────────────────────────────────────────
function resetAll(){
  Object.keys(ans).forEach(k=>delete ans[k]);
  QS.forEach((_,i)=>{for(let v=1;v<=5;v++){const b=document.getElementById(`q${i}_${v}`);if(b)b.classList.remove('sel');}});
  document.getElementById('qcount').textContent='0 / 30';
  document.getElementById('qbar').style.width='0%';
  document.getElementById('qnext').disabled=true;
  document.getElementById('qnext').textContent='还有 30 题未填';
  goTo(0);
}

buildQuestions();
</script>
</body>
</html>
