<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>为什么我会被吓到 — 了解ADHD的感官世界</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;600;700;900&family=Noto+Sans+SC:wght@300;400;500;700&display=swap" rel="stylesheet">
<style>
  :root {
    --ink: #1a1a2e;
    --paper: #faf8f5;
    --warm: #e8ddd3;
    --accent: #c45d3e;
    --accent-soft: #e8a690;
    --accent-glow: rgba(196, 93, 62, 0.08);
    --sage: #5a7a6a;
    --sage-soft: #dce8e0;
    --storm: #4a5568;
    --mist: #f0ece6;
    --gold: #b8860b;
    --gold-soft: rgba(184,134,11,0.1);
  }

  * { margin:0; padding:0; box-sizing:border-box; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Noto Sans SC', sans-serif;
    background: var(--paper);
    color: var(--ink);
    line-height: 1.85;
    font-size: 17px;
    overflow-x: hidden;
  }

  /* ============ HERO ============ */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 4rem 2rem;
    position: relative;
    background: linear-gradient(170deg, var(--paper) 0%, var(--warm) 50%, var(--mist) 100%);
  }

  .hero::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: 
      radial-gradient(ellipse 600px 400px at 20% 30%, rgba(196,93,62,0.06), transparent),
      radial-gradient(ellipse 500px 500px at 80% 70%, rgba(90,122,106,0.06), transparent);
    pointer-events: none;
  }

  .hero-badge {
    display: inline-block;
    font-family: 'Noto Sans SC', sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--sage);
    background: var(--sage-soft);
    padding: 0.4rem 1.2rem;
    border-radius: 100px;
    margin-bottom: 2rem;
    font-weight: 500;
    animation: fadeDown 1s ease-out;
  }

  .hero h1 {
    font-family: 'Noto Serif SC', serif;
    font-size: clamp(2.2rem, 6vw, 4.2rem);
    font-weight: 900;
    line-height: 1.25;
    color: var(--ink);
    margin-bottom: 1.5rem;
    animation: fadeDown 1s ease-out 0.15s both;
  }

  .hero h1 em {
    font-style: normal;
    color: var(--accent);
    position: relative;
  }

  .hero h1 em::after {
    content: '';
    position: absolute;
    bottom: 2px;
    left: 0; right: 0;
    height: 3px;
    background: var(--accent-soft);
    border-radius: 2px;
  }

  .hero-sub {
    font-size: 1.15rem;
    color: var(--storm);
    max-width: 540px;
    line-height: 1.9;
    animation: fadeDown 1s ease-out 0.3s both;
    font-weight: 300;
  }

  .hero-cta {
    margin-top: 2.5rem;
    animation: fadeDown 1s ease-out 0.45s both;
  }

  .hero-cta a {
    display: inline-block;
    background: var(--ink);
    color: var(--paper);
    text-decoration: none;
    padding: 0.9rem 2.4rem;
    border-radius: 100px;
    font-size: 0.95rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    transition: all 0.3s ease;
  }

  .hero-cta a:hover {
    background: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(196,93,62,0.2);
  }

  /* ============ SCROLL INDICATOR ============ */
  .scroll-hint {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    animation: bounce 2s infinite, fadeDown 1s ease-out 0.6s both;
  }

  .scroll-hint svg {
    width: 24px;
    height: 24px;
    stroke: var(--storm);
    opacity: 0.4;
  }

  /* ============ NAV ============ */
  .sticky-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(250,248,245,0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(0,0,0,0.06);
    padding: 0.8rem 2rem;
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .sticky-nav a {
    text-decoration: none;
    color: var(--storm);
    font-size: 0.82rem;
    padding: 0.4rem 1rem;
    border-radius: 100px;
    transition: all 0.25s;
    font-weight: 400;
  }

  .sticky-nav a:hover {
    background: var(--accent-glow);
    color: var(--accent);
  }

  /* ============ SECTIONS ============ */
  .content-wrap {
    max-width: 740px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  section {
    padding: 5rem 0;
  }

  section + section {
    border-top: 1px solid rgba(0,0,0,0.04);
  }

  .section-num {
    font-family: 'Noto Serif SC', serif;
    font-size: 0.8rem;
    color: var(--accent);
    letter-spacing: 0.1em;
    font-weight: 600;
    margin-bottom: 0.8rem;
    display: block;
  }

  h2 {
    font-family: 'Noto Serif SC', serif;
    font-size: clamp(1.6rem, 3.5vw, 2.2rem);
    font-weight: 700;
    line-height: 1.35;
    margin-bottom: 1.5rem;
    color: var(--ink);
  }

  h3 {
    font-family: 'Noto Serif SC', serif;
    font-size: 1.2rem;
    font-weight: 600;
    margin: 2.5rem 0 1rem;
    color: var(--ink);
  }

  p {
    margin-bottom: 1.3rem;
    color: var(--storm);
  }

  p strong {
    color: var(--ink);
    font-weight: 600;
  }

  /* ============ EVIDENCE CARDS ============ */
  .evidence-card {
    background: white;
    border-radius: 16px;
    padding: 2rem 2.2rem;
    margin: 2rem 0;
    box-shadow: 0 2px 20px rgba(0,0,0,0.04);
    border-left: 4px solid var(--accent);
    position: relative;
    overflow: hidden;
  }

  .evidence-card::before {
    content: '';
    position: absolute;
    top: 0; right: 0;
    width: 120px; height: 120px;
    background: radial-gradient(circle, var(--accent-glow), transparent);
    border-radius: 50%;
    transform: translate(30%, -30%);
  }

  .evidence-card .tag {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.25rem 0.8rem;
    border-radius: 100px;
    margin-bottom: 1rem;
  }

  .tag-research {
    background: var(--gold-soft);
    color: var(--gold);
  }

  .tag-neuro {
    background: rgba(90,122,106,0.1);
    color: var(--sage);
  }

  .tag-clinical {
    background: rgba(196,93,62,0.08);
    color: var(--accent);
  }

  .evidence-card h4 {
    font-family: 'Noto Serif SC', serif;
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 0.8rem;
    color: var(--ink);
  }

  .evidence-card p {
    font-size: 0.95rem;
    line-height: 1.8;
  }

  .source {
    font-size: 0.78rem;
    color: var(--sage);
    margin-top: 0.8rem;
    font-style: italic;
    border-top: 1px solid rgba(0,0,0,0.05);
    padding-top: 0.8rem;
  }

  .source a {
    color: var(--sage);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* ============ ANALOGY BOX ============ */
  .analogy {
    background: linear-gradient(135deg, var(--sage-soft), #e8ede9);
    border-radius: 16px;
    padding: 2.2rem 2.5rem;
    margin: 2.5rem 0;
    position: relative;
  }

  .analogy::before {
    content: '💡';
    font-size: 1.5rem;
    position: absolute;
    top: -12px;
    left: 24px;
  }

  .analogy h4 {
    font-family: 'Noto Serif SC', serif;
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--sage);
    margin-bottom: 0.6rem;
  }

  .analogy p {
    color: #3d5a4a;
    font-size: 0.95rem;
  }

  /* ============ PARTNER TIPS ============ */
  .tips-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.2rem;
    margin: 2rem 0;
  }

  .tip-item {
    background: white;
    border-radius: 14px;
    padding: 1.8rem 2rem;
    display: flex;
    gap: 1.2rem;
    align-items: flex-start;
    box-shadow: 0 2px 16px rgba(0,0,0,0.03);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .tip-item:hover {
    transform: translateY(-3px);
    box-shadow: 0 6px 24px rgba(0,0,0,0.06);
  }

  .tip-icon {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.3rem;
    background: var(--mist);
  }

  .tip-content h4 {
    font-family: 'Noto Serif SC', serif;
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.4rem;
    color: var(--ink);
  }

  .tip-content p {
    font-size: 0.9rem;
    margin: 0;
  }

  /* ============ QUOTE STRIP ============ */
  .quote-strip {
    text-align: center;
    padding: 4rem 2rem;
    background: var(--ink);
    color: var(--paper);
  }

  .quote-strip blockquote {
    font-family: 'Noto Serif SC', serif;
    font-size: clamp(1.2rem, 3vw, 1.7rem);
    font-weight: 400;
    line-height: 1.7;
    max-width: 600px;
    margin: 0 auto;
    opacity: 0.9;
  }

  .quote-strip cite {
    display: block;
    margin-top: 1.2rem;
    font-size: 0.85rem;
    font-style: normal;
    opacity: 0.5;
    font-family: 'Noto Sans SC', sans-serif;
  }

  /* ============ VISUAL DIAGRAM ============ */
  .brain-compare {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin: 2.5rem 0;
  }

  .brain-box {
    background: white;
    border-radius: 16px;
    padding: 2rem;
    text-align: center;
    box-shadow: 0 2px 16px rgba(0,0,0,0.03);
  }

  .brain-box.nt { border-top: 4px solid var(--sage); }
  .brain-box.adhd { border-top: 4px solid var(--accent); }

  .brain-box .emoji {
    font-size: 2.5rem;
    margin-bottom: 0.8rem;
  }

  .brain-box h4 {
    font-family: 'Noto Serif SC', serif;
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.6rem;
  }

  .brain-box p {
    font-size: 0.85rem;
    line-height: 1.7;
  }

  .signal-bar {
    height: 8px;
    border-radius: 100px;
    margin: 1rem auto 0.4rem;
    max-width: 180px;
  }

  .signal-bar.low {
    background: linear-gradient(90deg, var(--sage), var(--sage-soft));
  }

  .signal-bar.high {
    background: linear-gradient(90deg, var(--accent), var(--accent-soft));
    animation: pulse-bar 2s ease-in-out infinite;
  }

  .signal-label {
    font-size: 0.72rem;
    color: var(--storm);
    opacity: 0.7;
  }

  /* ============ INTERACTIVE SIMULATION ============ */
  .sim-container {
    background: white;
    border-radius: 20px;
    padding: 2.5rem;
    margin: 2.5rem 0;
    text-align: center;
    box-shadow: 0 4px 30px rgba(0,0,0,0.05);
    border: 1px solid rgba(0,0,0,0.04);
  }

  .sim-container h4 {
    font-family: 'Noto Serif SC', serif;
    font-size: 1.15rem;
    margin-bottom: 0.6rem;
  }

  .sim-container p.sim-desc {
    font-size: 0.88rem;
    color: var(--storm);
    margin-bottom: 1.5rem;
  }

  .sim-visual {
    width: 160px;
    height: 160px;
    border-radius: 50%;
    margin: 0 auto 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
    background: var(--mist);
    transition: all 0.15s ease;
    cursor: default;
    position: relative;
    user-select: none;
  }

  .sim-visual.startled {
    background: rgba(196,93,62,0.15);
    transform: scale(1.15);
    box-shadow: 0 0 0 20px rgba(196,93,62,0.06), 0 0 0 40px rgba(196,93,62,0.03);
  }

  .sim-btn {
    display: inline-block;
    background: var(--accent);
    color: white;
    border: none;
    padding: 0.8rem 2rem;
    border-radius: 100px;
    font-size: 0.9rem;
    font-family: 'Noto Sans SC', sans-serif;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.25s;
  }

  .sim-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(196,93,62,0.25);
  }

  .sim-result {
    margin-top: 1.2rem;
    font-size: 0.88rem;
    color: var(--storm);
    min-height: 1.5rem;
  }

  /* ============ CLOSING ============ */
  .closing {
    text-align: center;
    padding: 5rem 2rem;
    background: linear-gradient(180deg, var(--paper), var(--warm));
  }

  .closing h2 {
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    margin-bottom: 1rem;
  }

  .closing p {
    max-width: 520px;
    margin: 0 auto 1rem;
    font-size: 1rem;
  }

  .heart {
    font-size: 2rem;
    margin-top: 1.5rem;
    display: inline-block;
    animation: heartbeat 1.5s ease-in-out infinite;
  }

  /* ============ FOOTER ============ */
  footer {
    text-align: center;
    padding: 2rem;
    font-size: 0.75rem;
    color: var(--storm);
    opacity: 0.5;
  }

  footer a {
    color: var(--storm);
  }

  /* ============ ANIMATIONS ============ */
  @keyframes fadeDown {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(8px); }
  }

  @keyframes pulse-bar {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.6; }
  }

  @keyframes heartbeat {
    0%, 100% { transform: scale(1); }
    15% { transform: scale(1.15); }
    30% { transform: scale(1); }
    45% { transform: scale(1.1); }
  }

  /* ============ SCROLL REVEAL ============ */
  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }

  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ============ RESPONSIVE ============ */
  @media (max-width: 640px) {
    .brain-compare {
      grid-template-columns: 1fr;
    }

    .evidence-card {
      padding: 1.5rem 1.6rem;
    }

    .content-wrap {
      padding: 0 1.2rem;
    }

    section {
      padding: 3.5rem 0;
    }

    .sticky-nav {
      padding: 0.6rem 1rem;
      gap: 0.3rem;
    }

    .sticky-nav a {
      font-size: 0.75rem;
      padding: 0.35rem 0.7rem;
    }
  }
</style>
