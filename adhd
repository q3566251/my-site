<script>
// ========= Scroll Reveal =========
const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      entry.target.classList.add('visible');
    }
  });
}, { threshold: 0.12 });

document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

// ========= Startle Simulation =========
let simTimeout = null;

function startSim() {
  const face = document.getElementById('simFace');
  const btn = document.getElementById('simBtn');
  const result = document.getElementById('simResult');

  // Reset
  face.textContent = '😌';
  face.classList.remove('startled');
  result.textContent = '等待中……不要离开这个区域';
  btn.disabled = true;
  btn.style.opacity = '0.5';

  const delay = 2000 + Math.random() * 4000;

  simTimeout = setTimeout(() => {
    // STARTLE
    face.textContent = '😱';
    face.classList.add('startled');

    // Sound effect via Web Audio
    try {
      const ctx = new (window.AudioContext || window.webkitAudioContext)();
      const osc = ctx.createOscillator();
      const gain = ctx.createGain();
      osc.connect(gain);
      gain.connect(ctx.destination);
      osc.frequency.value = 800;
      gain.gain.value = 0.3;
      osc.start();
      osc.stop(ctx.currentTime + 0.15);
    } catch(e) {}

    result.innerHTML = '<strong>就是这种感觉。</strong><br>ADHD 大脑在每次被突然叫到时，<br>都经历类似强度的惊吓反射。';

    setTimeout(() => {
      face.textContent = '😮‍💨';
      face.classList.remove('startled');
      btn.disabled = false;
      btn.style.opacity = '1';
    }, 2000);
  }, delay);
}
</script>
