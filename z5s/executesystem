<!doctype html>
<html lang="zh">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>执行系统 | Z5S 系统故事</title>
  <meta name="description" content="执行系统——人格里的行动层、启动层、完成力。" />
  <meta name="theme-color" content="#ffffff" />
  <style>
    :root{
      --bg:#ffffff; --text:#0b0c0f; --muted:#5b5f6a; --line:#e9eaee; --card:#f6f7f9;
      --shadow:0 10px 30px rgba(0,0,0,.06); --radius:18px; --radius2:14px; --max:1080px;
      --accent:#0a6640; --accent2:#158a56;
      --page-bg:#ffffff; --section-bg:#ffffff; --soft-bg:#f6f7f9;
    }
    *{box-sizing:border-box}
    html{zoom:0.9}
    html,body{height:100%}
    body{
      margin:0;
      font-family:ui-sans-serif,system-ui,-apple-system,"PingFang SC","Hiragino Sans GB",Segoe UI,Roboto,Helvetica,Arial;
      color:var(--text); background:var(--page-bg); line-height:1.55;
      -webkit-font-smoothing:antialiased;
      transition:background-color .28s ease;
    }
    a{color:inherit;text-decoration:none}
    .wrap{max-width:var(--max);margin:0 auto;padding:0 20px}

    /* NAV */
    .nav{position:sticky;top:0;z-index:100;background:rgba(255,255,255,.82);backdrop-filter:saturate(180%) blur(18px);border-bottom:1px solid var(--line);}
    .navin{display:flex;align-items:center;justify-content:space-between;padding:12px 0;gap:18px;}
    .brand{display:flex;align-items:center;gap:10px;font-weight:650;letter-spacing:-.2px;white-space:nowrap;}
    .dot{width:10px;height:10px;border-radius:999px;background:linear-gradient(135deg,var(--accent),#34c759);box-shadow:0 0 0 4px rgba(10,102,64,.10);}
    .navlinks{display:flex;gap:22px;align-items:center;flex:1 1 auto;justify-content:flex-end;}
    .navlinks > a{color:var(--muted);font-size:14px;transition:color .16s;}
    .navlinks > a:hover{color:var(--text);}
    .btn{display:inline-flex;align-items:center;justify-content:center;padding:10px 18px;border-radius:999px;border:1px solid var(--line);background:#fff;color:var(--text);font-size:14px;font-weight:600;transition:transform .08s ease,box-shadow .2s ease,border-color .2s ease;}
    .btn:hover{transform:translateY(-1px);box-shadow:0 10px 18px rgba(0,0,0,.06);}
    .btn.primary{background:linear-gradient(180deg,var(--accent2),var(--accent));color:#fff;border-color:transparent;box-shadow:0 12px 24px rgba(10,102,64,.22);}
    .btn.primary:hover{box-shadow:0 16px 30px rgba(10,102,64,.30);}

    /* HERO */
    .hero{padding:64px 0 44px;background:var(--section-bg);}
    .heroGrid{display:grid;gap:22px;grid-template-columns:1.25fr .75fr;align-items:stretch;}
    .hLabel{font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--accent);margin-bottom:14px;display:flex;align-items:center;gap:8px;}
    .hLabel::before{content:'';display:inline-block;width:20px;height:2px;background:var(--accent);border-radius:2px;}
    .hTitle{font-size:46px;line-height:1.06;letter-spacing:-1.2px;margin:0 0 16px;}
    .hSub{margin:0 0 22px;color:var(--muted);font-size:18px;max-width:60ch;line-height:1.65;}
    .chips{display:flex;flex-wrap:wrap;gap:10px;margin:0}
    .chip{padding:8px 14px;border-radius:999px;background:var(--card);border:1px solid var(--line);color:#2b2f38;font-size:13px;}
    .chip.accent{background:rgba(10,102,64,.08);border-color:rgba(10,102,64,.20);color:var(--accent);}

    /* HERO CARD */
    .heroCard{border:1px solid var(--line);background:linear-gradient(160deg,#f4fff8,#e8f9ef);border-radius:var(--radius);box-shadow:var(--shadow);padding:22px;display:flex;flex-direction:column;justify-content:space-between;min-height:260px;}
    .heroCard .eyebrow{font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--accent);margin-bottom:10px;}
    .heroCard h3{margin:0 0 10px;letter-spacing:-.35px;font-size:18px;}
    .heroCard p{margin:0;color:var(--muted);font-size:14px;line-height:1.65;}
    .quote{font-size:15px;font-style:italic;line-height:1.7;color:#0d3d26;border-left:3px solid var(--accent);padding-left:14px;margin:16px 0 0;}

    /* SECTIONS */
    section{padding:52px 0;border-top:1px solid var(--line);background:var(--section-bg);transition:background-color .28s ease;}
    h2{margin:0 0 10px;font-size:30px;letter-spacing:-.7px;}
    .lead{margin:0 0 24px;color:var(--muted);max-width:74ch;font-size:16px;line-height:1.7;}
    .grid3{display:grid;gap:14px;grid-template-columns:repeat(3,minmax(0,1fr));}
    .grid2{display:grid;gap:14px;grid-template-columns:repeat(2,minmax(0,1fr));}
    .card{border:1px solid var(--line);background:#fff;border-radius:var(--radius);padding:20px;box-shadow:0 8px 20px rgba(0,0,0,.04);}
    .card.soft{background:var(--soft-bg);}
    .card.green{background:linear-gradient(135deg,rgba(10,102,64,.07),rgba(52,199,89,.05));border-color:rgba(10,102,64,.15);}
    .card h3{margin:0 0 8px;letter-spacing:-.35px;font-size:16px;}
    .card p{margin:0;color:var(--muted);font-size:14px;line-height:1.65;}
    .card ul{margin:10px 0 0;padding:0 0 0 18px;color:var(--muted);font-size:14px;}
    .card li{margin:6px 0;}
    .card .num{font-size:26px;font-weight:800;color:var(--accent);opacity:.25;margin-bottom:6px;line-height:1;}

    /* STORY BLOCK */
    .storyBlock{display:grid;gap:22px;grid-template-columns:1fr 1fr;align-items:start;}
    .storyText{font-size:15px;color:var(--muted);line-height:1.8;}
    .storyText p{margin:0 0 14px;}
    .storyText p:last-child{margin:0;}
    .storyText b{color:var(--text);}
    .storyCard{border:1px solid rgba(10,102,64,.18);background:rgba(10,102,64,.04);border-radius:var(--radius);padding:20px;}
    .storyCard h4{margin:0 0 12px;letter-spacing:-.3px;color:var(--accent);}
    .storyCard ul{margin:0;padding:0 0 0 16px;color:#0d3d26;font-size:14px;line-height:1.7;}
    .storyCard li{margin:5px 0;}

    /* BADGE ROW */
    .badgeRow{display:flex;gap:10px;flex-wrap:wrap;margin-top:16px;}
    .badge{display:inline-flex;gap:8px;align-items:center;padding:8px 12px;border-radius:999px;background:#fff;border:1px solid var(--line);font-size:13px;color:#2b2f38;}
    .dot2{width:8px;height:8px;border-radius:999px;background:#0a6640;}
    .dot3{width:8px;height:8px;border-radius:999px;background:#34c759;}
    .dot4{width:8px;height:8px;border-radius:999px;background:#007aff;}
    .dot5{width:8px;height:8px;border-radius:999px;background:#ff9f0a;}

    /* COMPARISON TABLE */
    .compareGrid{display:grid;gap:14px;grid-template-columns:1fr 1fr 1fr;}
    .compareCard{border:1px solid var(--line);background:#fff;border-radius:var(--radius2);padding:16px;}
    .compareCard .tag{font-size:11px;font-weight:700;letter-spacing:.09em;text-transform:uppercase;margin-bottom:8px;}
    .compareCard h4{margin:0 0 6px;font-size:15px;letter-spacing:-.3px;}
    .compareCard p{margin:0;color:var(--muted);font-size:13px;line-height:1.6;}

    /* QUOTE PULL */
    .pullQuote{border:1px solid rgba(10,102,64,.20);background:linear-gradient(135deg,rgba(10,102,64,.06),rgba(52,199,89,.04));border-radius:var(--radius);padding:28px 32px;text-align:center;}
    .pullQuote p{margin:0;font-size:20px;line-height:1.6;letter-spacing:-.3px;color:#0d3d26;font-style:italic;}
    .pullQuote small{display:block;margin-top:12px;font-size:13px;color:var(--muted);font-style:normal;}

    /* GROWTH STEPS */
    .stepList{display:grid;gap:10px;}
    .step{display:flex;gap:14px;align-items:flex-start;padding:16px;border-radius:var(--radius2);border:1px solid var(--line);background:#fff;}
    .stepNum{width:32px;height:32px;border-radius:999px;background:var(--accent);color:#fff;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:800;flex:0 0 auto;}
    .stepText b{display:block;margin-bottom:4px;font-size:15px;letter-spacing:-.2px;}
    .stepText span{color:var(--muted);font-size:14px;}

    /* SUBHEAD inside accordion */
    .acc-subhead{font-size:11px;font-weight:700;letter-spacing:.10em;text-transform:uppercase;color:var(--accent);margin:0 0 12px;padding-bottom:8px;border-bottom:1px solid var(--line);}
    .triggerGrid{display:grid;gap:10px;grid-template-columns:repeat(2,1fr);}
    .triggerCard{border:1px solid var(--line);background:#fff;border-radius:var(--radius2);padding:14px;}
    .triggerCard .tNum{font-size:11px;font-weight:800;color:var(--accent);letter-spacing:.06em;margin-bottom:5px;}
    .triggerCard h4{margin:0 0 5px;font-size:14px;letter-spacing:-.2px;}
    .triggerCard p{margin:0;color:var(--muted);font-size:13px;line-height:1.6;}
    .levelGrid{display:grid;gap:14px;grid-template-columns:repeat(3,1fr);}
    .levelCard{border-radius:var(--radius);padding:20px;border:1px solid var(--line);}
    .levelCard .lTag{font-size:11px;font-weight:800;letter-spacing:.09em;text-transform:uppercase;margin-bottom:8px;}
    .levelCard h3{margin:0 0 8px;font-size:16px;letter-spacing:-.3px;}
    .levelCard p{margin:0 0 10px;font-size:14px;line-height:1.65;}
    .levelCard ul{margin:0;padding:0 0 0 16px;font-size:13px;line-height:1.7;}
    @media(max-width:780px){.triggerGrid{grid-template-columns:1fr}.levelGrid{grid-template-columns:1fr}}

    /* THEME SWATCH */
    .themePanel{margin-top:0;border:1px solid var(--line);background:rgba(255,255,255,.72);border-radius:16px;padding:14px;backdrop-filter:blur(12px);}
    .themePanel h4{margin:0 0 6px;font-size:14px;}
    .themePanel p{margin:0 0 10px;color:var(--muted);font-size:13px;}
    .swatchRow{display:flex;gap:10px;}
    .swatch{width:30px;height:30px;border-radius:999px;border:1px solid rgba(0,0,0,.08);cursor:pointer;transition:transform .08s,box-shadow .18s;}
    .swatch:hover{transform:translateY(-1px);box-shadow:0 8px 18px rgba(0,0,0,.10);}
    .swatch.active{box-shadow:0 0 0 3px rgba(10,102,64,.25);border-color:rgba(10,102,64,.5);}

    /* FOOTER */
    footer{padding:28px 0;border-top:1px solid var(--line);color:var(--muted);font-size:13px;background:var(--section-bg);}
    .footGrid{display:flex;justify-content:space-between;gap:12px;flex-wrap:wrap;}
    .fine{font-size:12px;color:#7b808c;margin-top:8px;}

    /* ACCORDION */
    .accordion{border-top:1px solid var(--line);background:var(--section-bg);transition:background-color .28s ease;}
    .accordionHeader{cursor:pointer;padding:32px 0;display:flex;align-items:center;justify-content:space-between;gap:16px;user-select:none;list-style:none;}
    .accordionHeader::-webkit-details-marker{display:none;}
    .accordionTitle{font-size:24px;font-weight:700;letter-spacing:-.6px;margin:0;}
    .accordionMeta{display:flex;align-items:center;gap:12px;}
    .accordionLead{font-size:14px;color:var(--muted);}
    .accordionCaret{width:32px;height:32px;border-radius:999px;background:var(--card);border:1px solid var(--line);display:flex;align-items:center;justify-content:center;font-size:14px;flex:0 0 auto;transition:transform .28s ease,background .2s ease;}
    details[open] .accordionCaret{transform:rotate(180deg);background:rgba(10,102,64,.10);border-color:rgba(10,102,64,.25);}
    .accordionBody{padding-bottom:44px;}
    .accordionBody .lead{margin-top:0;}

    @keyframes rainbow{to{background-position:300% center}}
    @media(max-width:920px){.heroGrid{grid-template-columns:1fr}.hTitle{font-size:38px}.storyBlock{grid-template-columns:1fr}}
    @media(max-width:780px){.grid3{grid-template-columns:1fr}.grid2{grid-template-columns:1fr}.compareGrid{grid-template-columns:1fr}.hTitle{font-size:32px}}
  </style>
</head>
<body>

<header class="nav" role="banner">
  <div class="wrap">
    <div class="navin">
      <a class="brand" href="https://bestwellnesstherapy.com">
        <span class="dot" aria-hidden="true"></span>
        <span>Z5S 系统故事</span>
      </a>
      <nav class="navlinks" aria-label="Primary">
        <a href="#definition">定义</a>
        <a href="#tasks">核心任务</a>
        <a href="#language">典型语言</a>
        <a href="#misread">常见误解</a>
        <a href="#growth">成长方向</a>
      </nav>
      <a class="btn primary" href="https://bestwellnesstherapy.com">← 返回首页</a>
    </div>
  </div>
</header>

<main role="main">

  <!-- HERO -->
  <section class="hero" aria-label="执行系统介绍">
    <div class="wrap">
      <div class="heroGrid">
        <div>
          <div class="hLabel">Z5S · 五个系统之一</div>
          <h1 class="hTitle">⚙️ 执行系统</h1>
          <p class="hSub">
            它不回答「我想要什么」，而是回答<b>「我能不能真的动起来」</b>。
          </p>
          <div class="chips">
            <span class="chip accent">启动力</span>
            <span class="chip">持续性</span>
            <span class="chip">完成力</span>
            <span class="chip">自我调节</span>
            <span class="chip">抗拖延</span>
          </div>
        </div>
        <aside class="heroCard" aria-label="核心摘要">
          <div>
            <div class="eyebrow">一句话定位</div>
            <h3>执行系统，是一个人把意图转化为行动的系统。</h3>
            <p>它高的人：启动快，完成率高，能持续推进——但也更容易因过度自我驱动而耗尽，或因完美主义而卡死。</p>
            <p class="quote">真正成熟的执行系统，不是一直在跑，而是：能动起来，也能停下来，还知道为什么而跑。</p>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- 定义 -->
  <section id="definition" aria-label="定义">
    <div class="wrap">
      <h2>什么是执行系统？</h2>
      <p class="lead">它不是「努力不努力」，也不是「懒不懒」。它负责回答四个更根本的问题。</p>
      <div class="grid2" style="margin-bottom:22px;">
        <div class="card green">
          <div class="num">01</div>
          <h3>我能不能启动</h3>
          <p>面对一件事，能不能在合适的时间真的开始。很多人知道要做，但一直"等一个合适的时机"。</p>
        </div>
        <div class="card green">
          <div class="num">02</div>
          <h3>我能不能坚持</h3>
          <p>启动之后，能不能在没有外部压力的情况下继续推进。持续性是执行系统最核心的能力。</p>
        </div>
        <div class="card green">
          <div class="num">03</div>
          <h3>我能不能完成</h3>
          <p>善始善终的能力。很多人启动力强，但完成率低——这也是执行系统的问题，不是动力问题。</p>
        </div>
        <div class="card green">
          <div class="num">04</div>
          <h3>我能不能调节自己</h3>
          <p>在疲惫、失焦、情绪干扰时，能不能重新调整回轨道，而不是彻底崩掉或消失。</p>
        </div>
      </div>
      <div class="pullQuote">
        <p>执行系统是人格里的<b>行动层</b>。<br/>它不处理方向，也不处理情绪，<br/>它处理的是：「这件事，我能不能真的做到」。</p>
        <small>Z5S 框架</small>
      </div>
    </div>
  </section>

  <!-- 核心任务 -->
  <section id="tasks" aria-label="核心任务">
    <div class="wrap">
      <h2><span style="background:linear-gradient(90deg,#0a6640,#34c759,#007aff,#0a6640);background-size:300% auto;-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;animation:rainbow 3s linear infinite;">五个核心任务</span></h2>
      <p class="lead">执行系统不是单一功能，它同时在做五件非常不同的事。</p>
      <div class="grid3">
        <div class="card">
          <h3>🚀 启动行动</h3>
          <p>把「想做」变成「在做」。启动力是执行系统的第一道关，也是最容易被拖延卡住的地方。</p>
        </div>
        <div class="card">
          <h3>🔄 维持推进</h3>
          <p>在没有外部压力、没有即时反馈时，仍然能保持行动节奏。这是执行系统区别于爆发力的地方。</p>
        </div>
        <div class="card">
          <h3>🏁 达到完成</h3>
          <p>不只是开始，而是真的把事情做完。完成力涉及收尾能力、对「够好」的容忍度，以及放手时机。</p>
        </div>
        <div class="card">
          <h3>🎛️ 自我调节</h3>
          <p>在干扰来临时，能识别偏移、重新聚焦，而不是一旦打断就全面崩溃或永久放弃。</p>
        </div>
        <div class="card">
          <h3>⚡ 管理能量</h3>
          <p>知道什么时候用力，什么时候休息，什么时候慢下来保存资源——而不只是一直硬撑。</p>
        </div>
        <div class="card soft">
          <h3>核心追求</h3>
          <p>执行系统真正追求的，不是速度，也不是努力，而是<b>完成率</b>——意图和结果之间的距离要小。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 高低对比 ACCORDION -->
  <details class="accordion" aria-label="高低执行系统的样子">
    <summary class="accordionHeader">
      <div class="wrap" style="display:flex;align-items:center;justify-content:space-between;width:100%;gap:16px;">
        <div>
          <h2 class="accordionTitle">1. 执行系统高 vs 低，是什么样子</h2>
          <p class="accordionLead" style="margin:4px 0 0;">不是谁好谁坏，是两种不同的人格运作方式。</p>
        </div>
        <span class="accordionCaret">▾</span>
      </div>
    </summary>
    <div class="accordionBody">
      <div class="wrap">
        <div class="acc-subhead">执行系统高的人</div>
        <div class="grid2" style="margin-bottom:22px;">
          <div class="storyCard" style="border-color:rgba(10,102,64,.25);background:rgba(10,102,64,.05);">
            <h4>优势</h4>
            <ul>
              <li>说到做到，承诺兑现率高</li>
              <li>能在低动力状态下仍然推进</li>
              <li>不容易被拖延长期绑住</li>
              <li>有完成感，不容易半途而废</li>
              <li>能在压力下维持输出</li>
            </ul>
          </div>
          <div class="storyCard" style="border-color:rgba(255,59,48,.20);background:rgba(255,59,48,.03);">
            <h4 style="color:#c0392b;">过高时的风险</h4>
            <ul style="color:#7a3030;">
              <li>停不下来——即使身体已经发出信号</li>
              <li>用行动回避感受——做着做着不知道为什么</li>
              <li>完美主义卡死——不够好就不想交出去</li>
              <li>容易过载，然后突然崩掉一段时间</li>
              <li>把「效率」当成自我价值的来源</li>
            </ul>
          </div>
        </div>
        <div class="badgeRow" style="margin-bottom:28px;">
          <span class="badge"><span class="dot2"></span> 完成率高</span>
          <span class="badge"><span class="dot3"></span> 启动快</span>
          <span class="badge"><span class="dot4"></span> 能持续</span>
          <span class="badge"><span class="dot5"></span> 容易耗竭</span>
        </div>

        <div class="acc-subhead">执行系统低的人</div>
        <div class="grid2" style="margin-bottom:22px;">
          <div class="storyCard" style="border-color:rgba(0,0,0,.10);background:#fafafa;">
            <h4 style="color:var(--muted);">挑战</h4>
            <ul style="color:var(--muted);">
              <li><b style="color:var(--text);">启动困难</b> — 明明想做，但就是无法开始，等状态等到最后没时间</li>
              <li><b style="color:var(--text);">推进断续</b> — 很难维持没有即时反馈的行动，容易中断</li>
              <li><b style="color:var(--text);">完成率低</b> — 许多事情开始了但没有结束，积压大量未完成项</li>
              <li><b style="color:var(--text);">自责循环</b> — 因为没做而自责，自责又让启动更难</li>
              <li><b style="color:var(--text);">能量管理混乱</b> — 不清楚自己什么时候能用力，什么时候已经透支</li>
            </ul>
          </div>
          <div class="storyCard" style="border-color:rgba(52,199,89,.20);background:rgba(52,199,89,.03);">
            <h4 style="color:#1a6e32;">可能的优势</h4>
