<script>
  document.getElementById("y").textContent = new Date().getFullYear();
  const themes = {
    default:   { pageBg:"#ffffff", sectionBg:"#ffffff", softBg:"#f6f7f9", cardBg:"#ffffff" },
    warm:      { pageBg:"#f7f1e8", sectionBg:"#fbf7f1", softBg:"#f2e7d9", cardBg:"#fdf9f4" },
    sage:      { pageBg:"#edf4ee", sectionBg:"#f4f8f4", softBg:"#e3eee5", cardBg:"#f4f8f4" },
    mist:      { pageBg:"#eef4f8", sectionBg:"#f6f9fb", softBg:"#e3edf4", cardBg:"#f6f9fb" },
    lavender:  { pageBg:"#f0eeff", sectionBg:"#f6f4ff", softBg:"#e8e4fb", cardBg:"#f8f6ff" }
  };
  const root = document.documentElement;
  const swatches = document.querySelectorAll(".swatch");
  function applyTheme(name) {
    const t = themes[name] || themes.default;
    root.style.setProperty("--page-bg", t.pageBg);
    root.style.setProperty("--section-bg", t.sectionBg);
    root.style.setProperty("--soft-bg", t.softBg);
    document.querySelectorAll(".card:not(.soft),.step,details").forEach(el => {
      el.style.backgroundColor = t.cardBg;
    });
    swatches.forEach(b => b.classList.toggle("active", b.dataset.theme === name));
    try { localStorage.setItem("z5s-theme", name); } catch(e) {}
  }
  swatches.forEach(b => b.addEventListener("click", () => applyTheme(b.dataset.theme)));
  try { applyTheme(localStorage.getItem("z5s-theme") || "default"); } catch(e) { applyTheme("default"); }
</script>
