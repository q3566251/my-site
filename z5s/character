<script>
var sfSys1=null, sfSys2=null;

function getCardSystems(card){
  var chips=card.querySelectorAll('.sys-chip');
  var result=[];
  chips.forEach(function(c){
    var t=c.textContent;
    if(t.includes('解释')) result.push('A');
    else if(t.includes('执行')) result.push('B');
    else if(t.includes('情感')) result.push('C');
    else if(t.includes('认同')) result.push('D');
    else if(t.includes('游戏')) result.push('E');
  });
  return result;
}

function pickSys(slot, sys, btn){
  if(slot===1){
    if(sfSys1===sys){sfSys1=null;btn.classList.remove('active');}
    else{document.querySelectorAll('#chips1 .sf-chip').forEach(function(b){b.classList.remove('active');});sfSys1=sys;btn.classList.add('active');}
    if(sfSys2===sfSys1){sfSys2=null;document.querySelectorAll('#chips2 .sf-chip').forEach(function(b){b.classList.remove('active');});}
  } else {
    if(!sfSys1) return;
    if(sfSys2===sys){sfSys2=null;btn.classList.remove('active');}
    else{document.querySelectorAll('#chips2 .sf-chip').forEach(function(b){b.classList.remove('active');});sfSys2=sys;btn.classList.add('active');}
    if(sfSys2===sfSys1){sfSys2=null;document.querySelectorAll('#chips2 .sf-chip').forEach(function(b){b.classList.remove('active');});}
  }
  applyFilter();
}

function applyFilter(){
  var r=document.getElementById('sfResult');
  var rt=document.getElementById('sfResultText');
  var sysName={A:'解释',B:'执行',C:'情感',D:'认同',E:'游戏'};
  if(!sfSys1){
    r.style.display='none';
    document.querySelectorAll('.struct-card').forEach(function(c){c.classList.remove('sf-hidden');});
    ['cat-single','cat-double','cat-extreme'].forEach(function(cls){document.querySelector('.'+cls).style.display='';});
    return;
  }
  var label=sysName[sfSys1];
  if(sfSys2) label+=' → '+sysName[sfSys2];
  rt.textContent='显示：'+label+' 的结构';
  r.style.display='flex';
  document.querySelectorAll('.struct-card').forEach(function(card){
    var sysList=getCardSystems(card);
    var match=false;
    if(sfSys1&&sfSys2){
      match=sysList.length===2&&sysList[0]===sfSys1&&sysList[1]===sfSys2;
    } else {
      match=sysList.length===1&&sysList[0]===sfSys1;
    }
    card.classList.toggle('sf-hidden',!match);
  });
  ['cat-single','cat-double','cat-extreme'].forEach(function(cls){
    document.querySelector('.'+cls).style.display='';
  });
}

function clearFilter(){
  sfSys1=null;sfSys2=null;
  document.querySelectorAll('.sf-chip').forEach(function(b){b.classList.remove('active');});
  document.getElementById('sfResult').style.display='none';
  document.querySelectorAll('.struct-card').forEach(function(c){c.classList.remove('sf-hidden');});
}

function toggleCard(btn){
  var card=btn.closest('.struct-card');
  card.classList.toggle('open');
  var span=btn.querySelector('span:first-child');
  span.textContent=card.classList.contains('open')?'收起':'临床现象与参照 · 结构深析';
}

function filterCat(cat,el){
  clearFilter();
  document.querySelectorAll('.tab').forEach(function(t){t.classList.remove('active');});
  el.classList.add('active');
  var s=document.querySelector('.cat-single');
  var d=document.querySelector('.cat-double');
  var e=document.querySelector('.cat-extreme');
  s.style.display=cat==='double'||cat==='extreme'?'none':'';
  d.style.display=cat==='single'||cat==='extreme'?'none':'';
  e.style.display=cat==='single'||cat==='double'?'none':'';
  window.scrollTo({top:0,behavior:'smooth'});
}

function goTest(){
  window.open('z5s-level-measure.html','_self');
}

document.querySelectorAll('.card-why-label').forEach(function(el){
  el.textContent='临床现象与参照';
});
document.querySelectorAll('.card-dark-label').forEach(function(el){
  el.textContent='这个结构会在哪里卡住';
});
document.querySelectorAll('.card-note-label').forEach(function(el){
  var t=el.textContent;
  if(t==='结构特点'||t==='结构特别之处'||t==='极端特征'||t==='结构特点') el.textContent='在关系里的失灵方式';
});
document.querySelectorAll('.expand-btn span:first-child').forEach(function(el){
  el.textContent='临床现象与参照 · 结构深析';
});
</script>
