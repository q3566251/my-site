  },
  C:{
    reactive:{body:'你的情感系统目前在反应层级运行。情绪会自动响应环境和他人——你通常在意识到之前就已经被带动了。这让你有很高的情感感知力，但也意味着情绪有时候会在你还没准备好的情况下驱动你的反应。',note:'下一步：开始注意"我什么时候已经被带进情绪了"。不需要阻止，只需要能看见它。'},
    integrative:{body:'你的情感系统处于整合层级。你能感受到情绪，也能在大多数情况下不让它直接控制你的行为——你和情绪之间有了空间，虽然有时候它还是会溢出来。',note:'下一步：练习把情绪当成信息来读："这个感受在告诉我什么？"让情绪成为你的资源，不只是需要管理的东西。'},
    transformational:{body:'你的情感系统处于转化层级。你能深度感受情绪，同时保持对它的觉察和选择——情绪是你理解世界的重要工具，但不会自动控制你的行为。你可以选择在什么情境下让情绪引导你。',note:'值得注意的是：在需要快速决策的高压场景中，有意识地区分"情绪信号"和"情绪干扰"，是让情感系统保持锋利的关键。'}
  },
  D:{
    reactive:{body:'你的认同系统目前在反应层级运行。当价值观或自我认知受到挑战时，防御或收缩会自动触发——外部的否定容易直接等于"我这个人有问题"，这个连接在你能评估之前就发生了。',note:'下一步：开始注意"这件事被否定"和"我这个人被否定"这两种感受有什么不同。'},
    integrative:{body:'你的认同系统处于整合层级。你能区分事件评价和自我价值，也能在被触碰的时候给自己一点缓冲——虽然冲击还是会有，但你开始能在情绪里站稳了。',note:'下一步：练习在被否定时多问自己一步："他在否定的是什么？这件事和我是谁有关吗？"'},
    transformational:{body:'你的认同系统处于转化层级。你有稳定的内在参照，不容易被外部评价带偏——你知道原则是什么，也知道偏好和原则的区别。外部的变化不会动摇你知道自己是谁这件事。',note:'值得注意的是：内在稳定不等于封闭——保持"我是谁可以更新"的弹性，是让认同系统真正有力量的关键。'}
  },
  E:{
    reactive:{body:'你的游戏系统目前在反应层级运行。新鲜感和探索欲会自动触发——无聊或压力来了，切换状态或寻找刺激几乎是自动发生的，有时候是在帮你，有时候只是在逃跑，很难区分。',note:'下一步：下次想切换状态的时候，先停一秒，问自己：我是真的需要切换，还是不想待在这里？'},
    integrative:{body:'你的游戏系统处于整合层级。你能察觉到自己的探索冲动，也开始能区分"健康的切换"和"逃避"——虽然这个区分有时候还是会消耗你，但你已经在做了。',note:'下一步：找一件值得深耕的事，在它变得无聊之后再留一会儿——深度也是一种探索。'},
    transformational:{body:'你的游戏系统处于转化层级。你能主动调用和关闭探索模式，也不需要靠新鲜感维持动力——你可以在稳定中找到深度的乐趣，也可以在卡住的时候有意识地切换视角。',note:'值得注意的是：转化层级的游戏系统最强大的地方是"能在任何情境里找到可玩的东西"——包括在沉重的、重复的、无聊的情境里。'}
  }
};

var ans={};

(function(){
  var groups={A:[],B:[],C:[],D:[],E:[]};
  QS.forEach(function(q){groups[q.sys].push(q);});
  Object.keys(groups).forEach(function(k){
    var g=groups[k];
    for(var i=g.length-1;i>0;i--){var j=Math.floor(Math.random()*(i+1));var t=g[i];g[i]=g[j];g[j]=t;}
  });
  var keys=Object.keys(groups);
  for(var i=keys.length-1;i>0;i--){var j=Math.floor(Math.random()*(i+1));var t=keys[i];keys[i]=keys[j];keys[j]=t;}
  var newQS=[];
  keys.forEach(function(k){groups[k].forEach(function(q){newQS.push(q);});});
  QS.length=0;
  newQS.forEach(function(q){QS.push(q);});
})();

function buildQuestions(){
  var c=document.getElementById('questions');
  c.innerHTML='';
  QS.forEach(function(q,i){
    var s=SYS[q.sys];
    var opts=[
      {level:'reactive',text:q.r},
      {level:'integrative',text:q.i},
      {level:'transformational',text:q.t}
    ];
    for(var x=opts.length-1;x>0;x--){var y=Math.floor(Math.random()*(x+1));var tmp=opts[x];opts[x]=opts[y];opts[y]=tmp;}
    var optsHtml=opts.map(function(o,j){
      return '<button class="opt-btn" id="q'+i+'_'+j+'" onclick="setAns('+i+','+j+',\''+o.level+'\')">'
        +'<span class="opt-dot" style="background:#ddd;margin-top:7px"></span>'
        +'<span>'+o.text+'</span>'
        +'</button>';
    }).join('');
    c.innerHTML+='<div class="qcard" data-qi="'+i+'">'
      +'<div class="qscenario">问题 '+(i+1)+' / 20</div>'
      +'<div class="qtext">'+q.q+'</div>'
      +'<div class="opts-list">'+optsHtml+'</div>'
      +'</div>';
  });
}

function setAns(qi,optIdx,level){
  for(var j=0;j<3;j++){
    var b=document.getElementById('q'+qi+'_'+j);
    if(b){b.className='opt-btn';b.querySelector('.opt-dot').style.background='#ddd';}
  }
  var sel=document.getElementById('q'+qi+'_'+optIdx);
  if(sel){sel.className='opt-btn sel';sel.querySelector('.opt-dot').style.background='rgba(255,255,255,.5)';}
  ans[qi]=level;
  var done=Object.keys(ans).length;
  document.getElementById('qcount').textContent=done+' / 20';
  document.getElementById('qbar').style.width=(done/20*100)+'%';
  var curSys=QS[qi]?SYS[QS[qi].sys]:null;
  if(curSys) document.getElementById('cur-sys').textContent=curSys.icon+' '+curSys.zh;
  var btn=document.getElementById('qnext');
  btn.disabled=done<20;
  btn.textContent=done<20?'还有 '+(20-done)+' 题未选':'查看结果 →';
}

function goTo(n){
  document.querySelectorAll('.page').forEach(function(p){p.classList.remove('active');});
  document.getElementById('p'+n).classList.add('active');
  window.scrollTo(0,0);
}

function showResults(){
  var tally={};
  ['A','B','C','D','E'].forEach(function(k){tally[k]={reactive:0,integrative:0,transformational:0};});
  QS.forEach(function(q,i){if(ans[i]) tally[q.sys][ans[i]]++;});

  function getLevel(k){
    var t=tally[k];
    if(t.transformational>t.integrative&&t.transformational>t.reactive) return 'transformational';
    if(t.integrative>t.reactive) return 'integrative';
    if(t.reactive>=t.integrative&&t.reactive>=t.transformational) return 'reactive';
    return 'integrative';
  }

  var levels={};
  ['A','B','C','D','E'].forEach(function(k){levels[k]=getLevel(k);});

  var ovHtml=['A','B','C','D','E'].map(function(k){
    var s=SYS[k];var lv=LV[levels[k]];var t=tally[k];
    var bw={reactive:33,integrative:66,transformational:100}[levels[k]];
    return '<div class="ov-row" style="background:'+s.bg+'">'
      +'<div class="ov-icon">'+s.icon+'</div>'
      +'<div class="ov-sys" style="color:'+s.tc+'">'+s.zh+'</div>'
      +'<div class="ov-bar-wrap">'
      +'<div class="ov-bar-track"><div class="ov-bar-fill" data-w="'+bw+'" style="background:'+lv.color+'"></div></div>'
      +'<div class="ov-level-label" style="color:'+lv.color+'">'+lv.label+'</div>'
      +'</div>'
      +'<div class="ov-score" style="color:'+s.tc+'">'+t[levels[k]]+'/4</div>'
      +'</div>';
  }).join('');

  var detHtml=['A','B','C','D','E'].map(function(k){
    var s=SYS[k];var lv=levels[k];var lvDef=LV[lv];var d=DETAIL[k][lv];var t=tally[k];
    return '<div class="detail-block" style="background:'+s.bg+';border-color:'+s.color+'44">'
      +'<div class="det-head">'
      +'<span style="font-size:18px">'+s.icon+'</span>'
      +'<span style="font-size:14px;font-weight:700;color:'+s.tc+'">'+s.zh+'</span>'
      +'<span class="det-level-badge" style="background:'+lvDef.color+';color:#fff">'+lvDef.label+'</span>'
      +'<span style="font-size:11px;color:'+s.tc+';opacity:.6;margin-left:auto">'+t[lv]+'/4 题</span>'
      +'</div>'
      +'<div class="det-body" style="color:'+s.tc+'"><p>'+d.body+'</p></div>'
      +'<div class="det-note"><div class="det-note-label" style="color:'+s.tc+'">下一步</div>'+d.note+'</div>'
      +'</div>';
  }).join('');

  document.getElementById('results').innerHTML=
    '<div style="border-bottom:1px solid #f0eeea;padding-bottom:1.5rem;margin-bottom:1.5rem">'
    +'<div style="font-size:11px;color:#aaa;letter-spacing:.07em;text-transform:uppercase;font-weight:600;margin-bottom:.35rem">Z5S Level Measure · V1 结果</div>'
    +'<h2 style="font-size:24px;font-weight:700;margin-bottom:.4rem">你的系统层级图谱</h2>'
    +'<p style="font-size:13px;color:#888">五个系统各自的运行层级</p>'
    +'</div>'
    +'<div class="rcard"><div class="card-label">层级总览</div><div class="overview-grid">'+ovHtml+'</div></div>'
    +'<div class="rcard"><div class="card-label">详细解读</div>'+detHtml+'</div>'
    +'<div style="text-align:center;margin-top:1.5rem;padding-bottom:2.5rem">'
    +'<button onclick="resetAll()" style="background:#fff;color:#666;border:1px solid #ddd;border-radius:10px;padding:.85rem 2.5rem;font-size:14px;cursor:pointer;font-family:-apple-system,BlinkMacSystemFont,\'PingFang SC\',\'Hiragino Sans GB\',sans-serif">重新测评</button>'
    +'</div>';

  goTo(2);
  requestAnimationFrame(function(){requestAnimationFrame(function(){
    document.querySelectorAll('.ov-bar-fill[data-w]').forEach(function(b){b.style.width=b.dataset.w+'%';});
  });});
}

function resetAll(){
  Object.keys(ans).forEach(function(k){delete ans[k];});
  buildQuestions();
  document.getElementById('qcount').textContent='0 / 20';
  document.getElementById('qbar').style.width='0%';
  document.getElementById('qnext').disabled=true;
  document.getElementById('qnext').textContent='还有 20 题未选';
  document.getElementById('cur-sys').textContent='· · ·';
  goTo(0);
}

buildQuestions();
</script>
</body>
</html>
