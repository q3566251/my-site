<!DOCTYPE html>
<html lang="zh">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Z5S 层级测评</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:-apple-system,BlinkMacSystemFont,"PingFang SC","Hiragino Sans GB",sans-serif;background:#f5f4f0;min-height:100vh;color:#1a1a1a}
.page{display:none}.page.active{display:block}
.wrap{max-width:660px;margin:0 auto;padding:2rem 1.25rem}

/* INTRO */
.hero{background:linear-gradient(135deg,#faf7f2,#f0e9dc);border:1px solid #e8e0d4;border-radius:16px;padding:2.5rem 2rem;text-align:center;margin-bottom:2rem;position:relative;overflow:hidden}
.hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 70% 20%,rgba(127,119,221,.1),transparent 60%)}
.hero-inner{position:relative;z-index:1}
.hero .sub{font-size:12px;color:rgba(0,0,0,.35);font-weight:600;letter-spacing:.1em;text-transform:uppercase;margin-bottom:.75rem}
.hero h1{font-size:27px;font-weight:700;color:#1a1a1a;margin-bottom:.6rem;letter-spacing:-.3px;line-height:1.2}
.hero p{font-size:14px;color:rgba(0,0,0,.45);line-height:1.65}

.info-card{background:#fff;border:1px solid #e8e6e0;border-radius:12px;padding:1.25rem 1.5rem;margin-bottom:1.5rem;box-shadow:0 1px 3px rgba(0,0,0,.04)}
.info-row{display:flex;align-items:flex-start;gap:10px;font-size:13.5px;color:#555;margin-bottom:.65rem;line-height:1.55}
.info-row:last-child{margin-bottom:0}
.info-dot{width:6px;height:6px;border-radius:50%;background:#7F77DD;flex-shrink:0;margin-top:6px}

/* levels legend */
.levels-row{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-bottom:1.5rem}
.level-pill{border-radius:10px;padding:.75rem 1rem;text-align:center}
.level-pill .lv-icon{font-size:16px;margin-bottom:.3rem}
.level-pill .lv-name{font-size:12px;font-weight:700;line-height:1.3}
.level-pill .lv-desc{font-size:10.5px;opacity:.75;line-height:1.4;margin-top:2px}

/* QUESTION PAGE */
.prog-hero{background:linear-gradient(135deg,#faf7f2,#f0e9dc);border:1px solid #e8e0d4;border-radius:14px;padding:1.5rem 1.75rem;margin-bottom:1.75rem;position:relative;overflow:hidden}
.prog-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 80% 30%,rgba(127,119,221,.08),transparent 55%)}
.prog-inner{position:relative;z-index:1}
.prog-badge{display:inline-flex;align-items:center;background:rgba(83,74,183,.08);border:1px solid rgba(83,74,183,.18);border-radius:20px;padding:3px 12px;font-size:11px;font-weight:600;color:#534AB7;letter-spacing:.07em;text-transform:uppercase;margin-bottom:1rem}
.prog-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:.5rem}
.prog-label{font-size:13px;font-weight:600;color:rgba(0,0,0,.4)}
.prog-count{font-size:13px;font-weight:700;color:#1a1a1a}
.prog-bar{height:4px;background:rgba(0,0,0,.1);border-radius:2px}
.prog-fill{height:100%;background:#534AB7;border-radius:2px;transition:width .35s ease}
.sys-badge{display:none}

/* question card */
.qcard{background:#fff;border:1px solid #e8e6e0;border-radius:12px;padding:1.4rem 1.5rem;margin-bottom:.85rem;box-shadow:0 1px 3px rgba(0,0,0,.04)}
.qscenario{font-size:11px;font-weight:700;color:#aaa;letter-spacing:.05em;text-transform:uppercase;margin-bottom:.6rem}
.qtext{font-size:15px;line-height:1.7;color:#1a1a1a;font-weight:500;margin-bottom:1.1rem}
.opts-list{display:flex;flex-direction:column;gap:8px}
.opt-btn{width:100%;text-align:left;background:#f9f8f6;border:1.5px solid #e8e6e0;border-radius:10px;padding:.85rem 1rem;cursor:pointer;font-size:14px;line-height:1.6;color:#444;transition:all .15s;font-family:-apple-system,BlinkMacSystemFont,"PingFang SC","Hiragino Sans GB",sans-serif;display:flex;align-items:flex-start;gap:10px}
.opt-btn:hover{border-color:#7F77DD;background:#EEEDFE;color:#3C3089}
.opt-btn.sel{border-color:#534AB7;background:#534AB7;color:#fff;font-weight:500}
.opt-btn.sel .opt-dot{background:rgba(255,255,255,.5)}
.opt-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;margin-top:6px}

.btn-row{display:flex;gap:12px;margin-top:1.75rem;padding-bottom:2.5rem}
.btnP{background:#534AB7;color:#fff;border:none;border-radius:10px;padding:.85rem 2rem;font-size:15px;font-weight:500;cursor:pointer;flex:1;transition:background .15s;font-family:-apple-system,BlinkMacSystemFont,"PingFang SC","Hiragino Sans GB",sans-serif}
.btnP:hover{background:#3C3489}
.btnP:disabled{opacity:.35;cursor:not-allowed}
.btnS{background:#fff;color:#666;border:1px solid #ddd;border-radius:10px;padding:.8rem 1.5rem;font-size:14px;cursor:pointer;font-family:-apple-system,BlinkMacSystemFont,"PingFang SC","Hiragino Sans GB",sans-serif}
.btnS:hover{background:#f5f4f0}
.btnFull{width:100%;font-size:16px;padding:1rem}

/* RESULTS */
.rcard{background:#fff;border:1px solid #e8e6e0;border-radius:12px;padding:1.4rem 1.5rem;margin-bottom:1rem;box-shadow:0 1px 3px rgba(0,0,0,.04)}
.card-label{font-size:11px;color:#aaa;letter-spacing:.06em;text-transform:uppercase;font-weight:600;margin-bottom:1rem}

/* overview grid */
.overview-grid{display:flex;flex-direction:column;gap:10px}
.ov-row{display:flex;align-items:center;gap:14px;padding:.9rem 1rem;border-radius:10px;border:1px solid #e8e6e0}
.ov-icon{font-size:20px;flex-shrink:0;width:32px;text-align:center}
.ov-sys{font-size:13px;font-weight:700;min-width:60px}
.ov-bar-wrap{flex:1}
.ov-bar-track{height:6px;background:#f0eeea;border-radius:3px;overflow:hidden;margin-bottom:4px}
.ov-bar-fill{height:100%;border-radius:3px;transition:width 1s cubic-bezier(.4,0,.2,1)}
.ov-level-label{font-size:11px;font-weight:700;letter-spacing:.04em}
.ov-score{font-size:12px;color:#bbb;min-width:32px;text-align:right}

/* detail block */
.detail-block{border-radius:10px;padding:1.1rem 1.2rem;margin-bottom:.75rem;border:1.5px solid transparent}
.det-head{display:flex;align-items:center;gap:10px;margin-bottom:.75rem}
.det-level-badge{font-size:10px;font-weight:700;padding:3px 10px;border-radius:5px;letter-spacing:.04em;text-transform:uppercase}
.det-body{font-size:14px;line-height:1.8;color:#333}
.det-body p{margin-bottom:.5rem}
.det-body p:last-child{margin-bottom:0}
.det-note{margin-top:.75rem;padding:.75rem 1rem;border-radius:8px;background:rgba(255,255,255,.55);border:1px solid rgba(0,0,0,.07);font-size:13px;line-height:1.65;color:#555}
.det-note-label{font-size:10px;font-weight:700;letter-spacing:.05em;text-transform:uppercase;margin-bottom:.3rem}

@media(max-width:480px){
  .wrap{padding:1rem .85rem}
  .levels-row{grid-template-columns:1fr}
}
</style>
</head>
<body>

<!-- INTRO -->
<div id="p0" class="page active">
<div class="wrap">
  <div class="hero">
    <div class="hero-inner">
      <div class="sub">Z5S Level Measure · V1</div>
      <h1>系统运行层级测评</h1>
      <p>了解你的五个人格系统<br>各自在哪个运行层级</p>
    </div>
  </div>

  <div class="levels-row">
    <div class="level-pill" style="background:#fce8e4">
      <div class="lv-icon">🔴</div>
      <div class="lv-name" style="color:#902010">反应层级</div>
      <div class="lv-desc" style="color:#902010">系统自动运行<br>你被它带着走</div>
    </div>
    <div class="level-pill" style="background:#fdf0dc">
      <div class="lv-icon">🟡</div>
      <div class="lv-name" style="color:#8a4e08">整合层级</div>
      <div class="lv-desc" style="color:#8a4e08">你察觉到系统<br>开始有选择空间</div>
    </div>
    <div class="level-pill" style="background:#eef6e6">
      <div class="lv-icon">🟢</div>
      <div class="lv-name" style="color:#2a5a14">转化层级</div>
      <div class="lv-desc" style="color:#2a5a14">你主动指挥系统<br>能调用也能放下</div>
    </div>
  </div>

  <div class="info-card">
    <div class="info-row"><div class="info-dot"></div>共 <strong>20 道情境题</strong>，每题三个选项，约需 5 分钟</div>
    <div class="info-row"><div class="info-dot"></div>选最像你真实反应的，不是最理想的</div>
    <div class="info-row"><div class="info-dot"></div>结果显示你五个系统各自所在的层级</div>
  </div>
  <button class="btnP btnFull" onclick="goTo(1)">开始测评</button>
</div>
</div>

<!-- QUESTIONS -->
<div id="p1" class="page">
<div class="wrap">
  <div class="prog-hero">
    <div class="prog-inner">
      <div class="prog-badge">Z5S Level Measure</div>
      <div class="prog-top">
        <span class="prog-label">进度</span>
        <span class="prog-count" id="qcount">0 / 20</span>
      </div>
      <div class="prog-bar"><div class="prog-fill" id="qbar" style="width:0%"></div></div>
      <div class="sys-badge" id="cur-sys">· · ·</div>
    </div>
  </div>
  <div id="questions"></div>
  <div class="btn-row">
    <button class="btnS" onclick="goTo(0)">← 返回</button>
    <button class="btnP" id="qnext" disabled onclick="showResults()">查看结果 →</button>
  </div>
</div>
</div>

<!-- RESULTS -->
<div id="p2" class="page">
<div class="wrap" id="results"></div>
</div>

