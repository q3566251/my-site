<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>五系统触动故事 · 加强版 | Z5S</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;600;700;900&family=Noto+Sans+SC:wght@300;400;500;700&display=swap" rel="stylesheet">
<style>
:root {
  --page-bg: #f7f1e8;
  --soft-bg: #f2e7d9;
  --card-bg: #fdf9f4;
  --text-primary: #2c2418;
  --text-secondary: #6b5d4f;
  --text-muted: #9a8b7a;
  --border: #e5d9c8;
  --border-light: #efe6d8;
  --accent-explain: #4a6fa5;
  --accent-emotion: #c45b5b;
  --accent-execute: #d4922a;
  --accent-identity: #6b7f5e;
  --accent-play: #8e6bbf;
  --explain-bg: #eef3fa;
  --emotion-bg: #faeaea;
  --execute-bg: #faf3e6;
  --identity-bg: #eff4ec;
  --play-bg: #f3eefa;
  --explain-bg-deep: #dce6f2;
  --emotion-bg-deep: #f2d4d4;
  --execute-bg-deep: #f2e4cc;
  --identity-bg-deep: #dfe8da;
  --play-bg-deep: #e6dbf2;
  --shadow-sm: 0 1px 3px rgba(44,36,24,0.04);
  --shadow-md: 0 4px 16px rgba(44,36,24,0.06);
  --shadow-lg: 0 8px 32px rgba(44,36,24,0.08);
}

* { margin: 0; padding: 0; box-sizing: border-box; }

html { scroll-behavior: smooth; }

body {
  background: var(--page-bg);
  color: var(--text-primary);
  font-family: 'Noto Sans SC', sans-serif;
  font-weight: 400;
  line-height: 1.85;
  -webkit-font-smoothing: antialiased;
  overflow-x: hidden;
}

/* ====== HERO ====== */
.hero {
  text-align: center;
  padding: 100px 24px 72px;
  position: relative;
  overflow: hidden;
}

.hero::before {
  content: '';
  position: absolute;
  top: -40%;
  left: 50%;
  transform: translateX(-50%);
  width: 1000px;
  height: 1000px;
  background: radial-gradient(circle, rgba(142,107,191,0.07) 0%, rgba(74,111,165,0.04) 30%, rgba(196,91,91,0.03) 50%, transparent 70%);
  pointer-events: none;
  animation: heroGlow 12s ease-in-out infinite alternate;
}

@keyframes heroGlow {
  0% { transform: translateX(-50%) scale(1); opacity: 0.8; }
  100% { transform: translateX(-50%) scale(1.15); opacity: 1; }
}

.hero::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--border), transparent);
}

.hero-badge {
  display: inline-block;
  padding: 6px 18px;
  border-radius: 20px;
  font-size: 0.78rem;
  font-weight: 500;
  letter-spacing: 0.1em;
  color: var(--text-muted);
  border: 1px solid var(--border);
  margin-bottom: 24px;
  animation: fadeDown 0.8s ease;
}

@keyframes fadeDown {
  from { opacity: 0; transform: translateY(-10px); }
  to { opacity: 1; transform: translateY(0); }
}

.hero h1 {
  font-family: 'Noto Serif SC', serif;
  font-size: clamp(2.2rem, 5.5vw, 3.6rem);
  font-weight: 900;
  letter-spacing: 0.06em;
  margin-bottom: 20px;
  position: relative;
  animation: fadeUp 0.8s ease 0.2s both;
}

.hero .subtitle {
  font-size: 1.08rem;
  color: var(--text-secondary);
  max-width: 620px;
  margin: 0 auto 28px;
  font-weight: 300;
  line-height: 1.9;
  animation: fadeUp 0.8s ease 0.4s both;
}

.hero .reading-info {
  font-size: 0.82rem;
  color: var(--text-muted);
  animation: fadeUp 0.8s ease 0.6s both;
}

.hero .reading-info span {
  display: inline-block;
  margin: 0 8px;
  color: var(--border);
}

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

/* ====== NAV BAR ====== */
.nav-bar {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(247,241,232,0.88);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--border);
  padding: 0 24px;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  transition: box-shadow 0.3s;
}

.nav-bar.scrolled { box-shadow: var(--shadow-md); }
.nav-bar::-webkit-scrollbar { display: none; }

.nav-inner {
  display: flex;
  justify-content: center;
  gap: 2px;
  max-width: 900px;
  margin: 0 auto;
  min-width: max-content;
}

.nav-tab {
  padding: 15px 20px;
  font-size: 0.88rem;
  font-weight: 500;
  color: var(--text-muted);
  cursor: pointer;
  border: none;
  background: none;
  border-bottom: 3px solid transparent;
  transition: all 0.3s;
  white-space: nowrap;
  font-family: 'Noto Sans SC', sans-serif;
  position: relative;
}

.nav-tab:hover { color: var(--text-primary); }

.nav-tab.active {
  font-weight: 700;
}

.nav-tab[data-system="explain"].active { border-bottom-color: var(--accent-explain); color: var(--accent-explain); }
.nav-tab[data-system="emotion"].active { border-bottom-color: var(--accent-emotion); color: var(--accent-emotion); }
.nav-tab[data-system="execute"].active { border-bottom-color: var(--accent-execute); color: var(--accent-execute); }
.nav-tab[data-system="identity"].active { border-bottom-color: var(--accent-identity); color: var(--accent-identity); }
.nav-tab[data-system="play"].active { border-bottom-color: var(--accent-play); color: var(--accent-play); }
.nav-tab[data-system="overview"].active { border-bottom-color: var(--text-primary); color: var(--text-primary); }

/* ====== PROGRESS BAR ====== */
.progress-bar {
  position: fixed;
  top: 0;
  left: 0;
  height: 3px;
  background: var(--accent-explain);
  z-index: 200;
  transition: width 0.15s linear, background 0.5s;
  border-radius: 0 2px 2px 0;
}

/* ====== CONTENT ====== */
.content {
  max-width: 860px;
  margin: 0 auto;
  padding: 52px 24px 140px;
}

.system-section {
  display: none;
}

.system-section.visible {
  display: block;
  animation: sectionIn 0.6s cubic-bezier(0.22, 1, 0.36, 1);
}

@keyframes sectionIn {
  from { opacity: 0; transform: translateY(28px); }
  to { opacity: 1; transform: translateY(0); }
}

/* ====== SYSTEM HEADER ====== */
.sys-header {
  display: flex;
  align-items: center;
  gap: 20px;
  margin-bottom: 20px;
  padding-bottom: 24px;
  border-bottom: 1px solid var(--border);
}

.sys-icon {
  width: 72px;
  height: 72px;
  border-radius: 18px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 2rem;
  flex-shrink: 0;
  box-shadow: var(--shadow-sm);
}

.sys-header h2 {
  font-family: 'Noto Serif SC', serif;
  font-size: 1.7rem;
  font-weight: 700;
}

.sys-header .sys-motto {
  font-family: 'Noto Serif SC', serif;
  font-size: 0.92rem;
  color: var(--text-secondary);
  margin-top: 4px;
  font-style: italic;
}

.sys-header .sys-reading {
  font-size: 0.78rem;
  color: var(--text-muted);
  margin-top: 4px;
}

/* ====== SECTION ANCHORS (TOC) ====== */
.section-toc {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 40px;
}

.toc-chip {
  padding: 6px 14px;
  border-radius: 20px;
  font-size: 0.78rem;
  color: var(--text-muted);
  border: 1px solid var(--border);
  background: var(--card-bg);
  cursor: pointer;
  transition: all 0.2s;
  text-decoration: none;
}

.toc-chip:hover {
  background: var(--soft-bg);
  color: var(--text-primary);
}

/* ====== CARDS ====== */
.card {
  background: var(--card-bg);
  border-radius: 16px;
  padding: 36px;
  margin-bottom: 32px;
  border: 1px solid var(--border);
  position: relative;
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  transition: box-shadow 0.3s;
}

.card:hover { box-shadow: var(--shadow-md); }

.card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 4px;
  height: 100%;
}

.card-label {
  display: inline-block;
  padding: 3px 10px;
  border-radius: 6px;
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  margin-bottom: 14px;
}

.card h3 {
  font-family: 'Noto Serif SC', serif;
  font-size: 1.2rem;
  font-weight: 700;
  margin-bottom: 18px;
  display: flex;
  align-items: center;
  gap: 10px;
}

.card h3 .label-icon { font-size: 1.15rem; }

.card h4 {
  font-family: 'Noto Serif SC', serif;
  font-size: 1rem;
  font-weight: 600;
  margin: 24px 0 12px;
  color: var(--text-primary);
}

.card p, .card li {
  font-size: 0.95rem;
  line-height: 1.95;
  color: var(--text-secondary);
}

.card ul { list-style: none; padding: 0; }
.card li {
  padding: 8px 0;
  padding-left: 22px;
  position: relative;
}

.card li::before {
  content: '';
  position: absolute;
  left: 6px;
  top: 17px;
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: var(--text-muted);
}

/* Story cards */
.story-card p {
  font-family: 'Noto Serif SC', serif;
  color: var(--text-primary);
  font-size: 1rem;
  line-height: 2.1;
  text-indent: 2em;
}

.story-card p:first-of-type,
.story-card h3 + p,
.story-card h4 + p { text-indent: 0; }

.story-card .scene-break {
  text-align: center;
  padding: 16px 0;
  color: var(--text-muted);
  font-size: 1.2rem;
  letter-spacing: 1em;
}

/* Dialogue cards */
.dialogue-block {
  margin: 16px 0;
  padding: 20px 24px;
  border-radius: 12px;
  border-left: 3px solid var(--border);
}

.dialogue-line {
  margin: 10px 0;
  font-size: 0.93rem;
  line-height: 1.85;
}

.dialogue-line .speaker {
  font-weight: 700;
  font-size: 0.82rem;
  display: block;
  margin-bottom: 2px;
}

.dialogue-line .speaker.therapist { color: var(--text-muted); }

.dialogue-note {
  font-size: 0.82rem;
  color: var(--text-muted);
  font-style: italic;
  margin: 8px 0;
  padding-left: 12px;
  border-left: 2px solid var(--border-light);
}

/* Inner voice */
.inner-voice {
  position: relative;
  padding: 24px 28px;
  margin: 16px 0;
  border-radius: 12px;
  font-family: 'Noto Serif SC', serif;
  font-style: italic;
  line-height: 2;
  font-size: 0.95rem;
}

.inner-voice::before {
  content: '"';
  position: absolute;
  top: -8px;
  left: 12px;
  font-size: 3rem;
  opacity: 0.15;
  font-family: Georgia, serif;
}

/* Technique detail */
.tech-grid { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 14px; }

.tech-tag {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 8px 16px;
  border-radius: 24px;
  font-size: 0.85rem;
  font-weight: 500;
  border: 1px solid var(--border);
  background: var(--soft-bg);
}

.tech-detail {
  margin-top: 20px;
}

.tech-item {
  padding: 20px 0;
  border-bottom: 1px solid var(--border-light);
}

.tech-item:last-child { border-bottom: none; }

.tech-item-name {
  font-family: 'Noto Serif SC', serif;
  font-weight: 700;
  font-size: 1rem;
  margin-bottom: 4px;
}

.tech-item-en {
  font-size: 0.78rem;
  color: var(--text-muted);
  margin-bottom: 8px;
}

.tech-item p {
  font-size: 0.9rem;
  line-height: 1.85;
}

/* Compare grids */
.compare-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
  gap: 12px;
  margin-top: 14px;
}

.compare-item {
  padding: 18px;
  border-radius: 12px;
  text-align: center;
}

.compare-item .dim-label {
  font-size: 0.75rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: 8px;
  color: var(--text-muted);
}

.compare-item .dim-value {
  font-family: 'Noto Serif SC', serif;
  font-size: 0.92rem;
  font-weight: 600;
  line-height: 1.6;
}

/* Relationship map */
.rel-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14px;
  margin-top: 14px;
}

.rel-item {
  padding: 18px;
  border-radius: 12px;
  border: 1px solid var(--border);
  background: var(--card-bg);
}

.rel-item .rel-pair {
  font-size: 0.82rem;
  font-weight: 700;
  margin-bottom: 6px;
  display: flex;
  align-items: center;
  gap: 6px;
}

.rel-item .rel-type {
  display: inline-block;
  padding: 2px 8px;
  border-radius: 8px;
  font-size: 0.7rem;
  font-weight: 600;
}

.rel-type.friction { background: #fde8e8; color: #b44; }
.rel-type.resonance { background: #e8f5e8; color: #5a5; }
.rel-type.complement { background: #e8eef5; color: #55a; }

.rel-item p {
  font-size: 0.85rem;
  line-height: 1.7;
}

/* Warning / tip boxes */
.warning-box {
  padding: 20px 24px;
  border-radius: 12px;
  margin: 16px 0;
  border-left: 4px solid #c45b5b;
  background: rgba(196,91,91,0.06);
}

.warning-box .box-title {
  font-weight: 700;
  font-size: 0.88rem;
  margin-bottom: 8px;
  color: #c45b5b;
}

.tip-box {
  padding: 20px 24px;
  border-radius: 12px;
  margin: 16px 0;
  border-left: 4px solid var(--accent-identity);
  background: rgba(107,127,94,0.06);
}

.tip-box .box-title {
  font-weight: 700;
  font-size: 0.88rem;
  margin-bottom: 8px;
  color: var(--accent-identity);
}

/* Reference list */
.ref-list {
  margin-top: 14px;
}

.ref-item {
  display: flex;
  gap: 14px;
  padding: 14px 0;
  border-bottom: 1px solid var(--border-light);
  align-items: flex-start;
}

.ref-item:last-child { border-bottom: none; }

.ref-emoji {
  font-size: 1.4rem;
  flex-shrink: 0;
  width: 36px;
  text-align: center;
}

.ref-info .ref-title {
  font-weight: 600;
  font-size: 0.92rem;
}

.ref-info .ref-author {
  font-size: 0.82rem;
  color: var(--text-muted);
}

.ref-info .ref-why {
  font-size: 0.85rem;
  color: var(--text-secondary);
  margin-top: 4px;
}

/* System-specific accent colors on cards */
[data-sys="explain"] .card::before { background: var(--accent-explain); }
[data-sys="explain"] .sys-icon { background: var(--explain-bg); color: var(--accent-explain); }
[data-sys="explain"] .compare-item { background: var(--explain-bg); }
[data-sys="explain"] .tech-tag { background: var(--explain-bg); border-color: rgba(74,111,165,0.2); color: var(--accent-explain); }
[data-sys="explain"] .inner-voice { background: var(--explain-bg); color: var(--accent-explain); }
[data-sys="explain"] .dialogue-block { background: rgba(74,111,165,0.04); border-left-color: var(--accent-explain); }
[data-sys="explain"] .card-label { background: var(--explain-bg); color: var(--accent-explain); }
[data-sys="explain"] .toc-chip:hover { border-color: var(--accent-explain); color: var(--accent-explain); }

[data-sys="emotion"] .card::before { background: var(--accent-emotion); }
[data-sys="emotion"] .sys-icon { background: var(--emotion-bg); color: var(--accent-emotion); }
[data-sys="emotion"] .compare-item { background: var(--emotion-bg); }
[data-sys="emotion"] .tech-tag { background: var(--emotion-bg); border-color: rgba(196,91,91,0.2); color: var(--accent-emotion); }
[data-sys="emotion"] .inner-voice { background: var(--emotion-bg); color: var(--accent-emotion); }
[data-sys="emotion"] .dialogue-block { background: rgba(196,91,91,0.04); border-left-color: var(--accent-emotion); }
[data-sys="emotion"] .card-label { background: var(--emotion-bg); color: var(--accent-emotion); }
[data-sys="emotion"] .toc-chip:hover { border-color: var(--accent-emotion); color: var(--accent-emotion); }

[data-sys="execute"] .card::before { background: var(--accent-execute); }
[data-sys="execute"] .sys-icon { background: var(--execute-bg); color: var(--accent-execute); }
[data-sys="execute"] .compare-item { background: var(--execute-bg); }
[data-sys="execute"] .tech-tag { background: var(--execute-bg); border-color: rgba(212,146,42,0.2); color: var(--accent-execute); }
[data-sys="execute"] .inner-voice { background: var(--execute-bg); color: var(--accent-execute); }
[data-sys="execute"] .dialogue-block { background: rgba(212,146,42,0.04); border-left-color: var(--accent-execute); }
[data-sys="execute"] .card-label { background: var(--execute-bg); color: var(--accent-execute); }
[data-sys="execute"] .toc-chip:hover { border-color: var(--accent-execute); color: var(--accent-execute); }

[data-sys="identity"] .card::before { background: var(--accent-identity); }
[data-sys="identity"] .sys-icon { background: var(--identity-bg); color: var(--accent-identity); }
[data-sys="identity"] .compare-item { background: var(--identity-bg); }
[data-sys="identity"] .tech-tag { background: var(--identity-bg); border-color: rgba(107,127,94,0.2); color: var(--accent-identity); }
[data-sys="identity"] .inner-voice { background: var(--identity-bg); color: var(--accent-identity); }
[data-sys="identity"] .dialogue-block { background: rgba(107,127,94,0.04); border-left-color: var(--accent-identity); }
[data-sys="identity"] .card-label { background: var(--identity-bg); color: var(--accent-identity); }
[data-sys="identity"] .toc-chip:hover { border-color: var(--accent-identity); color: var(--accent-identity); }

[data-sys="play"] .card::before { background: var(--accent-play); }
[data-sys="play"] .sys-icon { background: var(--play-bg); color: var(--accent-play); }
[data-sys="play"] .compare-item { background: var(--play-bg); }
[data-sys="play"] .tech-tag { background: var(--play-bg); border-color: rgba(142,107,191,0.2); color: var(--accent-play); }
[data-sys="play"] .inner-voice { background: var(--play-bg); color: var(--accent-play); }
[data-sys="play"] .dialogue-block { background: rgba(142,107,191,0.04); border-left-color: var(--accent-play); }
[data-sys="play"] .card-label { background: var(--play-bg); color: var(--accent-play); }
[data-sys="play"] .toc-chip:hover { border-color: var(--accent-play); color: var(--accent-play); }

/* Overview table */
.overview-table-wrap { overflow-x: auto; margin-top: 16px; }

.overview-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.86rem;
  min-width: 700px;
}

.overview-table th {
  padding: 14px 12px;
  text-align: center;
  font-family: 'Noto Serif SC', serif;
  font-size: 0.84rem;
  border-bottom: 2px solid var(--border);
  background: var(--soft-bg);
}

.overview-table th:first-child { text-align: left; width: 110px; }

.overview-table td {
  padding: 11px 12px;
  text-align: center;
  border-bottom: 1px solid var(--border-light);
  vertical-align: top;
}

.overview-table td:first-child {
  text-align: left;
  font-weight: 600;
  color: var(--text-muted);
  font-size: 0.82rem;
}

.overview-table tbody tr:hover {
  background: rgba(242,231,217,0.4);
}

/* Footer */
.page-footer {
  text-align: center;
  padding: 48px 24px;
  color: var(--text-muted);
  font-size: 0.8rem;
  border-top: 1px solid var(--border);
}

/* Back to top */
.back-top {
  position: fixed;
  bottom: 24px;
  right: 24px;
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: var(--card-bg);
  border: 1px solid var(--border);
  box-shadow: var(--shadow-md);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  opacity: 0;
  transform: translateY(10px);
  transition: all 0.3s;
  z-index: 90;
  font-size: 1.1rem;
}

.back-top.visible { opacity: 1; transform: translateY(0); }
.back-top:hover { box-shadow: var(--shadow-lg); }

/* Responsive */
@media (max-width: 700px) {
  .hero { padding: 64px 20px 48px; }
  .card { padding: 26px 22px; }
  .sys-icon { width: 56px; height: 56px; font-size: 1.5rem; border-radius: 14px; }
  .compare-grid { grid-template-columns: repeat(2, 1fr); }
  .rel-grid { grid-template-columns: 1fr; }
  .dialogue-block { padding: 16px 18px; }
  .inner-voice { padding: 18px 20px; }
}

@media (max-width: 480px) {
  .nav-tab { padding: 13px 13px; font-size: 0.82rem; }
  .card { padding: 22px 18px; }
  .hero h1 { font-size: 1.8rem; }
}
</style>
</head>
