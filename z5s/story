<script>
// Tab switching
function showSystem(name) {
  document.querySelectorAll('.system-section').forEach(s => s.classList.remove('visible'));
  document.querySelectorAll('.nav-tab').forEach(t => t.classList.remove('active'));
  
  const section = document.getElementById('sec-' + name);
  const tab = document.querySelector('.nav-tab[data-system="' + name + '"]');
  
  if (section) section.classList.add('visible');
  if (tab) tab.classList.add('active');
  
  // Update progress bar color
  const colors = {
    explain: 'var(--accent-explain)',
    emotion: 'var(--accent-emotion)',
    execute: 'var(--accent-execute)',
    identity: 'var(--accent-identity)',
    play: 'var(--accent-play)',
    overview: 'var(--text-primary)'
  };
  document.getElementById('progressBar').style.background = colors[name] || 'var(--text-primary)';
  
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

// Scroll to card within section
function scrollToCard(id) {
  const el = document.getElementById(id);
  if (el) {
    const navH = document.getElementById('navBar').offsetHeight;
    const y = el.getBoundingClientRect().top + window.pageYOffset - navH - 16;
    window.scrollTo({ top: y, behavior: 'smooth' });
  }
}

// Scroll progress bar
window.addEventListener('scroll', () => {
  const winH = document.documentElement.scrollHeight - window.innerHeight;
  const scrolled = window.pageYOffset;
  const pct = Math.min(scrolled / winH * 100, 100);
  document.getElementById('progressBar').style.width = pct + '%';
  
  // Nav shadow
  document.getElementById('navBar').classList.toggle('scrolled', scrolled > 50);
  
  // Back to top
  document.getElementById('backTop').classList.toggle('visible', scrolled > 600);
});
</script>

