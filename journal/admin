<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Private Access | Best Wellness Therapy</title>
  <style>
    :root{
      --text:#0b0c0f; --muted:#5b5f6a; --line:#e9eaee;
      --max:1080px; --accent:#007aff; --accent2:#0a84ff;
      --page-bg:#ffffff; --soft-bg:#f6f7f9;
    }
    *{box-sizing:border-box}
    html{zoom:0.9}
    html,body{height:100%}
    body{margin:0;font-family:ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial;color:var(--text);background:var(--page-bg);line-height:1.45;-webkit-font-smoothing:antialiased;}
    a{color:inherit;text-decoration:none}
    .wrap{max-width:var(--max);margin:0 auto;padding:0 20px}

    /* NAV */
    .nav{position:sticky;top:0;z-index:100;background:rgba(255,255,255,.82);backdrop-filter:saturate(180%) blur(18px);border-bottom:1px solid var(--line);}
    .navin{display:flex;align-items:center;justify-content:space-between;padding:12px 0;gap:18px;}
    .brand{display:flex;align-items:center;gap:10px;font-weight:650;letter-spacing:-.2px;white-space:nowrap;}
    .dot{width:10px;height:10px;border-radius:999px;background:linear-gradient(135deg,var(--accent),#34c759);box-shadow:0 0 0 4px rgba(0,122,255,.10);}
    .navlinks{display:flex;gap:18px;align-items:center;}
    .navlinks a{color:var(--muted);font-size:14px;}
    .navlinks a:hover{color:var(--text);}

    /* LOGIN LAYOUT */
    .loginWrap{
      min-height: calc(100vh - 56px);
      display:flex;
      align-items:center;
      justify-content:center;
      padding:40px 20px;
    }
    .loginBox{
      width:100%;
      max-width:400px;
    }
    .loginBox h1{
      font-size:24px;
      letter-spacing:-.5px;
      margin:0 0 6px;
    }
    .loginBox p{
      margin:0 0 28px;
      color:var(--muted);
      font-size:14px;
    }

    /* FORM */
    .field{margin-bottom:14px;}
    .field label{
      display:block;
      font-size:13px;
      font-weight:600;
      color:var(--muted);
      margin-bottom:6px;
      text-transform:uppercase;
      letter-spacing:.06em;
    }
    .field input{
      width:100%;
      border:1px solid var(--line);
      border-radius:12px;
      padding:12px 14px;
      font-size:15px;
      font-family:inherit;
      outline:none;
      background:#fff;
      color:var(--text);
      transition:border-color .15s ease, box-shadow .15s ease;
    }
    .field input:focus{
      border-color:rgba(0,122,255,.4);
      box-shadow:0 0 0 3px rgba(0,122,255,.08);
    }

    .submitBtn{
      width:100%;
      padding:13px;
      border-radius:999px;
      border:none;
      background:linear-gradient(180deg,var(--accent2),var(--accent));
      color:#fff;
      font-size:15px;
      font-weight:600;
      font-family:inherit;
      cursor:pointer;
      box-shadow:0 12px 24px rgba(10,132,255,.22);
      transition:box-shadow .2s ease, transform .08s ease;
      margin-top:6px;
    }
    .submitBtn:hover{box-shadow:0 16px 30px rgba(10,132,255,.28);transform:translateY(-1px);}
    .submitBtn:active{transform:translateY(0);}

    .msg{
      margin-top:14px;
      font-size:13px;
      color:var(--muted);
      min-height:18px;
      text-align:center;
    }
    .msg.error{color:#c0002a;}
    .msg.success{color:#1a8f3a;}

    .backLink{
      display:block;
      text-align:center;
      margin-top:24px;
      font-size:13px;
      color:var(--muted);
    }
    .backLink:hover{color:var(--text);}
  </style>
</head>
<body>

  <header class="nav">
    <div class="wrap">
      <div class="navin">
        <a class="brand" href="index.html">
          <span class="dot"></span>
          <span>Best Wellness Therapy</span>
        </a>
        <nav class="navlinks">
          <a href="journal.html">← Journal</a>
        </nav>
      </div>
    </div>
  </header>

  <div class="loginWrap">
    <div class="loginBox">
      <h1>Private access</h1>
      <p>Enter your token to access the journal editor.</p>

      <div class="field">
        <label for="secretToken">Token</label>
        <input id="secretToken" type="password" placeholder="••••••••••••" autocomplete="current-password" />
      </div>

      <button class="submitBtn" id="loginBtn">Continue</button>
      <div class="msg" id="msg"></div>

      <a class="backLink" href="journal.html">Back to journal</a>
    </div>
  </div>

  <script>
    const tokenInput = document.getElementById("secretToken");
    const loginBtn = document.getElementById("loginBtn");
    const msg = document.getElementById("msg");

    async function doLogin() {
      const token = tokenInput.value.trim();
      if (!token) {
        msg.className = "msg error";
        msg.textContent = "Please enter your token.";
        return;
      }

      msg.className = "msg";
      msg.textContent = "Checking...";
      loginBtn.disabled = true;

      try {
        const res = await fetch("/api/journal?admin=1", {
          headers: { "X-Journal-Token": token }
        });

        if (res.ok) {
          sessionStorage.setItem("journal_token", token);
          msg.className = "msg success";
          msg.textContent = "Access granted. Redirecting...";
          setTimeout(() => window.location.href = "/journal-editor.html", 800);
        } else {
          msg.className = "msg error";
          msg.textContent = "Invalid token. Please try again.";
          loginBtn.disabled = false;
        }
      } catch {
        msg.className = "msg error";
        msg.textContent = "Connection error. Please try again.";
        loginBtn.disabled = false;
      }
    }

    loginBtn.addEventListener("click", doLogin);
    tokenInput.addEventListener("keydown", e => { if (e.key === "Enter") doLogin(); });
  </script>

</body>
</html>
