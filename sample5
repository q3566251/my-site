<!DOCTYPE html>
<html lang="zh">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Z5S Stress · 压力启动倾向量表 V1</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:wght@300;400;500;600;700&display=swap');

*{box-sizing:border-box;margin:0;padding:0}
:root{
  --ink:#1a1814;
  --ink2:#5a554e;
  --ink3:#9a9590;
  --bg:#f6f4ef;
  --card:#ffffff;
  --border:#e8e4dc;
  --A-c:#3e7c22;--A-bg:#eef6e6;--A-tc:#2a5a14;
  --B-c:#2060b0;--B-bg:#e4eef8;--B-tc:#144080;
  --C-c:#c07010;--C-bg:#fdf0dc;--C-tc:#8a4e08;
  --D-c:#7050c8;--D-bg:#eeebfc;--D-tc:#4a34a0;
  --E-c:#c03820;--E-bg:#fce8e4;--E-tc:#902010;
  --accent:#5a4fcc;
}

body{font-family:'DM Sans',sans-serif;background:var(--bg);min-height:100vh;color:var(--ink)}
h1,h2,.serif{font-family:'DM Serif Display',serif}

.page{display:none}.page.active{display:block}
.wrap{max-width:680px;margin:0 auto;padding:2.5rem 1.5rem}

/* ── HERO ── */
.hero{
  background:linear-gradient(150deg,#1a1530 0%,#2d2660 60%,#1e3060 100%);
  border-radius:20px;padding:2.75rem 2.5rem;margin-bottom:2rem;
  position:relative;overflow:hidden;
}
.hero::before{
  content:'';position:absolute;inset:0;
  background:radial-gradient(ellipse at 80% 20%,rgba(120,100,255,.25) 0%,transparent 60%),
             radial-gradient(ellipse at 20% 80%,rgba(60,120,255,.15) 0%,transparent 50%);
}
.hero-inner{position:relative;z-index:1}
.hero-badge{display:inline-flex;align-items:center;gap:6px;
  background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.15);
  border-radius:20px;padding:5px 14px;font-size:11px;font-weight:600;
  color:rgba(255,255,255,.7);letter-spacing:.1em;text-transform:uppercase;margin-bottom:1.25rem}
.hero h1{font-size:30px;color:#fff;margin-bottom:.6rem;line-height:1.25}
.hero .sub{font-size:15px;color:rgba(255,255,255,.65);line-height:1.65;max-width:460px}
.stress-dots{display:flex;gap:6px;margin-top:1.5rem}
.stress-dot{width:8px;height:8px;border-radius:50%;opacity:.6}

/* ── INFO CARD ── */
.info-card{background:var(--card);border:1px solid var(--border);border-radius:14px;
  padding:1.35rem 1.6rem;margin-bottom:1.75rem;box-shadow:0 1px 4px rgba(0,0,0,.04)}
.info-row{display:flex;align-items:flex-start;gap:10px;font-size:14px;
  color:var(--ink2);margin-bottom:.75rem;line-height:1.6}
.info-row:last-child{margin-bottom:0}
.info-dot{width:5px;height:5px;border-radius:50%;background:var(--accent);flex-shrink:0;margin-top:7px}

/* ── PROGRESS ── */
.prog-wrap{margin-bottom:2rem}
.prog-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:.5rem}
.prog-label{font-size:12px;font-weight:700;color:var(--ink3);letter-spacing:.08em;text-transform:uppercase}
.prog-count{font-size:13px;font-weight:700;color:var(--accent)}
.prog-bar{height:4px;background:var(--border);border-radius:2px}
.prog-fill{height:100%;background:var(--accent);border-radius:2px;transition:width .4s ease}

/* ── QUESTION CARD ── */
.section-label{font-size:11px;font-weight:700;color:var(--ink3);letter-spacing:.1em;
  text-transform:uppercase;padding:.5rem 0 .75rem;border-top:1px solid var(--border);
  margin-top:1.5rem;margin-bottom:.5rem}
.section-label:first-child{border-top:none;margin-top:0}

.qcard{background:var(--card);border:1px solid var(--border);border-radius:14px;
  padding:1.5rem 1.6rem;margin-bottom:.85rem;box-shadow:0 1px 4px rgba(0,0,0,.04);
  transition:border-color .2s}
.qcard.answered{border-color:#c8c4f0}
.qcard-top{display:flex;align-items:flex-start;gap:10px;margin-bottom:1.25rem}
.qnum{font-size:11px;font-weight:700;color:var(--ink3);min-width:24px;padding-top:3px;flex-shrink:0}
.qtext{font-size:15px;line-height:1.7;color:var(--ink);font-weight:500}
.reverse-tag{display:inline-block;font-size:10px;font-weight:700;color:#c07010;
  background:#fdf0dc;border-radius:4px;padding:1px 6px;margin-left:6px;vertical-align:middle}

/* ── LIKERT SCALE ── */
.likert{display:flex;flex-direction:column;gap:0}
.likert-labels{display:flex;justify-content:space-between;font-size:10.5px;
  color:var(--ink3);margin-bottom:.6rem;padding:0 2px}
.likert-row{display:flex;gap:6px}
.lopt{flex:1;background:var(--bg);border:1.5px solid var(--border);border-radius:10px;
  padding:.65rem .3rem;cursor:pointer;font-size:14px;font-weight:600;color:var(--ink2);
  text-align:center;transition:all .15s;line-height:1}
.lopt:hover{border-color:var(--accent);background:#eeedfc;color:var(--accent)}
.lopt.sel{border-color:var(--accent);background:var(--accent);color:#fff;
  box-shadow:0 2px 8px rgba(90,79,204,.3)}

/* ── BUTTONS ── */
.btn-row{display:flex;gap:12px;margin-top:2rem;padding-bottom:3rem}
.btnP{background:var(--accent);color:#fff;border:none;border-radius:11px;
  padding:.9rem 2rem;font-size:15px;font-weight:600;cursor:pointer;flex:1;
  transition:all .15s;font-family:inherit}
.btnP:hover{background:#4a3fb0;transform:translateY(-1px);box-shadow:0 4px 16px rgba(90,79,204,.35)}
.btnP:disabled{opacity:.35;cursor:not-allowed;transform:none;box-shadow:none}
.btnS{background:var(--card);color:var(--ink2);border:1px solid var(--border);
  border-radius:11px;padding:.85rem 1.5rem;font-size:14px;cursor:pointer;font-family:inherit;
  transition:all .15s}
.btnS:hover{background:var(--bg)}
.btnFull{width:100%;font-size:16px;padding:1.1rem;margin-top:.25rem}

/* ── RESULTS ── */
.r-header{margin-bottom:2rem}
.r-header .eyebrow{font-size:11px;color:var(--ink3);letter-spacing:.1em;
  text-transform:uppercase;font-weight:700;margin-bottom:.4rem}
.r-header h2{font-size:26px;color:var(--ink);margin-bottom:.35rem}
.r-header p{font-size:13px;color:var(--ink3)}

.rcard{background:var(--card);border:1px solid var(--border);border-radius:14px;
  padding:1.5rem 1.6rem;margin-bottom:1.1rem;box-shadow:0 1px 4px rgba(0,0,0,.04)}
.card-label{font-size:11px;color:var(--ink3);letter-spacing:.08em;text-transform:uppercase;
  font-weight:700;margin-bottom:1rem}

.primary-row{display:flex;align-items:center;gap:14px}
.p-icon{width:58px;height:58px;border-radius:15px;display:flex;align-items:center;
  justify-content:center;font-size:27px;flex-shrink:0}
.p-name{font-size:22px;font-weight:700}
.p-desc{font-size:12.5px;color:var(--ink3);margin-top:3px;line-height:1.45}
.p-score{font-size:34px;font-weight:700;margin-left:auto;flex-shrink:0;font-family:'DM Serif Display',serif}

.level-badge{display:inline-block;padding:5px 16px;border-radius:20px;
  font-size:12px;font-weight:700;margin:1rem 0 .5rem}

.bar-row{margin-bottom:1.1rem}
.bar-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:.4rem}
.bar-track{height:9px;background:#f0ede8;border-radius:5px;overflow:hidden}
.bar-fill{height:100%;border-radius:5px;transition:width 1.1s cubic-bezier(.4,0,.2,1)}

.interpret-box{background:#fafaf7;border:1px solid #edeae4;border-radius:11px;
  padding:1.35rem;font-size:14.5px;line-height:1.9;color:#2a2a2a;white-space:pre-wrap}

.sys-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:1rem}
.sys-item{border-radius:11px;padding:1rem 1.1rem}
.sys-item .sys-name{font-size:13px;font-weight:700;margin-bottom:3px}
.sys-item .sys-desc{font-size:11px;opacity:.8;line-height:1.45}

.score-chip{display:inline-flex;align-items:center;gap:5px;font-size:12px;
  font-weight:600;padding:3px 10px;border-radius:12px}

@media(max-width:480px){
  .wrap{padding:1.25rem 1rem}
  .hero{padding:2rem 1.5rem}
  .hero h1{font-size:25px}
  .likert-labels{font-size:9.5px}
  .p-score{font-size:28px}
  .sys-grid{grid-template-columns:1fr}
}
</style>
</head>
<body>

<!-- PAGE 0: INTRO -->
<div id="p0" class="page active">
<div class="wrap">
  <div class="hero">
    <div class="hero-inner">
      <div class="hero-badge">Z5S Stress · Version 1</div>
      <h1>压力启动<br>倾向量表</h1>
      <p class="sub">在困难或高压情境下，你的心理系统会如何自动启动？<br>这不是性格测试，而是压力下的反应模式扫描。</p>
      <div class="stress-dots">
        <div class="stress-dot" style="background:#3e7c22"></div>
        <div class="stress-dot" style="background:#2060b0"></div>
        <div class="stress-dot" style="background:#c07010"></div>
        <div class="stress-dot" style="background:#7050c8"></div>
        <div class="stress-dot" style="background:#c03820"></div>
      </div>
    </div>
  </div>
  <div class="info-card">
    <div class="info-row"><div class="info-dot"></div>共 <strong>25 道题</strong>，每题按符合程度评 1–5 分，约需 4–6 分钟</div>
    <div class="info-row"><div class="info-dot"></div>请根据你在<strong>压力或困难情境下的真实反应</strong>作答，不是日常状态</div>
    <div class="info-row"><div class="info-dot"></div>1 = 非常不同意 &nbsp;→&nbsp; 5 = 非常同意</div>
    <div class="info-row"><div class="info-dot"></div>完成后揭晓你在压力下最容易启动的心理系统</div>
  </div>
  <button class="btnP btnFull" onclick="goTo(1)">开始测评</button>
</div>
</div>

<!-- PAGE 1: QUESTIONS -->
<div id="p1" class="page">
<div class="wrap">
  <div class="prog-wrap">
    <div class="prog-top">
      <span class="prog-label">Z5S Stress V1</span>
      <span class="prog-count" id="qcount">0 / 25</span>
    </div>
    <div class="prog-bar"><div class="prog-fill" id="qbar" style="width:0%"></div></div>
  </div>
  <div id="questions"></div>
  <div class="btn-row">
    <button class="btnS" onclick="goTo(0)">← 返回</button>
    <button class="btnP" id="qnext" disabled onclick="showResults()">查看结果 →</button>
  </div>
</div>
</div>

<!-- PAGE 2: RESULTS -->
<div id="p2" class="page">
<div class="wrap" id="results"></div>
</div>

<script>
const SYS={
  A:{name:'Interpretation',zh:'解释系统',color:'#3e7c22',bg:'#eef6e6',tc:'#2a5a14',icon:'🔍',
     desc:'通过分析和理解来应对压力，本能追问"为什么"'},
  B:{name:'Execution',zh:'执行系统',color:'#2060b0',bg:'#e4eef8',tc:'#144080',icon:'⚡',
