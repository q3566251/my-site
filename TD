// ── FIREWORKS ────────────────────────────────────────────────────
const fw={active:false,shells:[],particles:[],_iv:null};
function startFireworks(){
  fw.active=true;
  for(let i=0;i<8;i++) setTimeout(launchShell,i*180);
  fw._iv=setInterval(()=>{if(fw.active){launchShell();if(Math.random()>.5)launchShell();}},550);
}
function stopFireworks(){fw.active=false;if(fw._iv){clearInterval(fw._iv);fw._iv=null;}}
const FWCOLS=['#ff3b30','#ffd60a','#30d158','#007aff','#bf5af2','#ff9500','#5ac8fa','#ff6ec7','#00ffc0','#ff6030'];
function launchShell(){
  const W=fwcv.width,H=fwcv.height;
  fw.shells.push({x:W*.08+Math.random()*W*.84,y:H,tx:W*.08+Math.random()*W*.84,ty:H*.06+Math.random()*H*.45,col:FWCOLS[Math.floor(Math.random()*FWCOLS.length)]});
}
function explodeShell(s){
  const n=55+Math.floor(Math.random()*50);
  for(let i=0;i<n;i++){
    const a=Math.random()*Math.PI*2,sp=70+Math.random()*240;
    fw.particles.push({x:s.x,y:s.y,vx:Math.cos(a)*sp,vy:Math.sin(a)*sp,col:s.col,li:1,sz:2.2+Math.random()*2.8});
  }
}
function updateFireworks(dt){
  fw.shells=fw.shells.filter(s=>{
    const dx=s.tx-s.x,dy=s.ty-s.y,d=Math.hypot(dx,dy);
    if(d<10){explodeShell(s);return false;}
    const sp=340+d*.9;s.x+=dx/d*sp*dt;s.y+=dy/d*sp*dt;return true;
  });
  fw.particles=fw.particles.filter(p=>{
    p.x+=p.vx*dt;p.y+=p.vy*dt;p.vy+=200*dt;p.vx*=.96;p.vy*=.96;p.li-=dt*.75;return p.li>0;
  });
  fwctx.clearRect(0,0,fwcv.width,fwcv.height);
  for(const s of fw.shells){
    fwctx.save();fwctx.fillStyle=s.col;fwctx.shadowColor=s.col;fwctx.shadowBlur=16;
    fwctx.beginPath();fwctx.arc(s.x,s.y,5,0,Math.PI*2);fwctx.fill();fwctx.restore();
  }
  for(const p of fw.particles){
    fwctx.save();fwctx.globalAlpha=Math.max(0,p.li);
    fwctx.fillStyle=p.col;fwctx.shadowColor=p.col;fwctx.shadowBlur=10;
    fwctx.beginPath();fwctx.arc(p.x,p.y,p.sz*Math.max(.1,p.li),0,Math.PI*2);fwctx.fill();fwctx.restore();
  }
}

// ── RENDER ───────────────────────────────────────────────────────
function render(){
  ctx.fillStyle='#e0e5f0';ctx.fillRect(0,0,CW,CH);
  ctx.save();ctx.strokeStyle='rgba(160,172,200,0.28)';ctx.lineWidth=.5;
  for(let c=0;c<=COLS;c++){ctx.beginPath();ctx.moveTo(c*CELL,0);ctx.lineTo(c*CELL,CH);ctx.stroke();}
  for(let r=0;r<=ROWS;r++){ctx.beginPath();ctx.moveTo(0,r*CELL);ctx.lineTo(CW,r*CELL);ctx.stroke();}
  ctx.restore();
  ctx.save();ctx.lineWidth=CELL-8;ctx.lineCap='round';ctx.lineJoin='round';
  ctx.strokeStyle='#c8d2e4';ctx.beginPath();PATH.forEach((p,i)=>i?ctx.lineTo(p.x,p.y):ctx.moveTo(p.x,p.y));ctx.stroke();
  ctx.lineWidth=CELL-22;ctx.strokeStyle='#d8e0f2';ctx.stroke();ctx.restore();
  if(G.selK){
    const def=TD[G.selK];
    for(let r=0;r<ROWS;r++) for(let c=0;c<COLS;c++){
      if(!PSET.has(`${c},${r}`)&&!G.towers.find(t=>t.c===c&&t.r===r)){
        ctx.fillStyle=G.gold>=def.cost?'rgba(0,122,255,.13)':'rgba(255,59,48,.09)';
        rFill(c*CELL+3,r*CELL+3,CELL-6,CELL-6,6);
      }
    }
  }
  ctx.save();ctx.font='bold 9px -apple-system';ctx.textAlign='center';
  ctx.fillStyle='#30d158';ctx.fillText('START',PATH[0].x,PATH[0].y+4);
  ctx.fillStyle='#ff3b30';ctx.fillText('END',PATH[PATH.length-1].x,PATH[PATH.length-1].y+4);
  ctx.restore();
  G.efx.forEach(drawEfx);G.towers.forEach(drawTower);G.mechs.forEach(drawMechUnit);
  G.enemies.forEach(drawEnemy);G.projs.forEach(drawProj);
  for(const p of G.parts){
    ctx.save();ctx.globalAlpha=Math.max(0,p.li/p.ml);ctx.fillStyle=p.col;ctx.shadowColor=p.col;ctx.shadowBlur=5;
    ctx.beginPath();ctx.arc(p.x,p.y,Math.max(.5,p.sz*(p.li/p.ml)),0,Math.PI*2);ctx.fill();ctx.restore();
  }
  for(const f of G.floats){
    ctx.save();ctx.globalAlpha=Math.max(0,f.li/f.ml);
    ctx.font=`bold ${f.sz}px -apple-system,Arial`;ctx.textAlign='center';
    ctx.strokeStyle='rgba(0,0,0,.6)';ctx.lineWidth=3.5;ctx.lineJoin='round';ctx.strokeText(f.txt,f.x,f.y);
    ctx.fillStyle=f.col;ctx.shadowColor=f.col;ctx.shadowBlur=10;ctx.fillText(f.txt,f.x,f.y);
    ctx.restore();
  }
}
function rFill(x,y,w,h,r){
  ctx.beginPath();ctx.moveTo(x+r,y);ctx.lineTo(x+w-r,y);ctx.quadraticCurveTo(x+w,y,x+w,y+r);
  ctx.lineTo(x+w,y+h-r);ctx.quadraticCurveTo(x+w,y+h,x+w-r,y+h);ctx.lineTo(x+r,y+h);
  ctx.quadraticCurveTo(x,y+h,x,y+h-r);ctx.lineTo(x,y+r);ctx.quadraticCurveTo(x,y,x+r,y);ctx.closePath();ctx.fill();
}
function drawEfx(e){
  if(e.type==='beam'){
    const a=e.li/e.ml;
    ctx.save();ctx.globalAlpha=a*.9;ctx.strokeStyle=e.col;ctx.lineWidth=2+e.st;ctx.shadowColor=e.col;ctx.shadowBlur=16;
    ctx.beginPath();ctx.moveTo(e.x1,e.y1);ctx.lineTo(e.x2,e.y2);ctx.stroke();
    ctx.lineWidth=(2+e.st)*3;ctx.globalAlpha=a*.14;ctx.stroke();ctx.restore();
  } else if(e.type==='explosion'){
    const a=e.li/e.ml,r=e.rad*(1.2-a*.3);
    ctx.save();ctx.globalAlpha=a*.65;ctx.fillStyle=e.col;ctx.shadowColor=e.col;ctx.shadowBlur=18;
    ctx.beginPath();ctx.arc(e.x,e.y,r,0,Math.PI*2);ctx.fill();
    ctx.globalAlpha=a*.28;ctx.fillStyle='#fff';ctx.beginPath();ctx.arc(e.x,e.y,r*.38,0,Math.PI*2);ctx.fill();ctx.restore();
  } else if(e.type==='chain'){
    const a=e.li/e.ml;
    ctx.save();ctx.globalAlpha=a;ctx.strokeStyle='#ffd700';ctx.lineWidth=2;ctx.shadowColor='#ffd700';ctx.shadowBlur=12;
    ctx.setLineDash([6,3]);ctx.beginPath();ctx.moveTo(e.x1,e.y1);ctx.lineTo(e.x2,e.y2);ctx.stroke();ctx.restore();
  }
}
function drawTower(t){
  const def=TD[t.k],x=t.c*CELL+CELL/2,y=t.r*CELL+CELL/2,col=def.col;
  if(G.selT===t||G.mergeA===t){
    ctx.save();ctx.strokeStyle=G.mergeA===t&&G.selT!==t?'#ffd60a':'#007aff';
    ctx.lineWidth=2.5;ctx.shadowColor=ctx.strokeStyle;ctx.shadowBlur=14;
    ctx.strokeRect(t.c*CELL+2,t.r*CELL+2,CELL-4,CELL-4);ctx.restore();
  }
  if(G.selT===t){
    const rng=tRng(t)*CELL*G.m.rx;
    ctx.save();ctx.globalAlpha=.1;ctx.fillStyle=col;ctx.beginPath();ctx.arc(x,y,rng,0,Math.PI*2);ctx.fill();
    ctx.globalAlpha=.22;ctx.strokeStyle=col;ctx.lineWidth=1.5;ctx.beginPath();ctx.arc(x,y,rng,0,Math.PI*2);ctx.stroke();ctx.restore();
  }
  ctx.save();ctx.fillStyle='rgba(255,255,255,.88)';ctx.shadowColor='rgba(0,0,0,.13)';ctx.shadowBlur=10;
  rFill(t.c*CELL+6,t.r*CELL+6,CELL-12,CELL-12,9);ctx.restore();
  ctx.save();ctx.translate(x,y);ctx.rotate(t.ang);
  const sz=9+t.st*3.8,cat=def.cat;
  ctx.fillStyle=col+'28';ctx.strokeStyle=col;ctx.lineWidth=2;
  if(cat==='G'){
    ctx.beginPath();ctx.moveTo(0,-sz);ctx.lineTo(sz*.65,0);ctx.lineTo(0,sz);ctx.lineTo(-sz*.65,0);ctx.closePath();ctx.fill();ctx.stroke();
    ctx.fillStyle=col;ctx.fillRect(-sz*.13,-sz,sz*.26,sz*.58);
  } else if(cat==='L'){
    ctx.beginPath();for(let i=0;i<6;i++){const a=i*Math.PI/3-Math.PI/6;i?ctx.lineTo(Math.cos(a)*sz,Math.sin(a)*sz):ctx.moveTo(Math.cos(a)*sz,Math.sin(a)*sz);}
    ctx.closePath();ctx.fill();ctx.stroke();
    ctx.fillStyle=col;ctx.beginPath();ctx.arc(0,0,sz*.28,0,Math.PI*2);ctx.fill();ctx.fillRect(-2,-sz,4,sz*.6);
  } else if(cat==='E'){
    ctx.beginPath();ctx.moveTo(sz*.28,-sz);ctx.lineTo(-sz*.15,-sz*.08);ctx.lineTo(sz*.18,-sz*.05);
    ctx.lineTo(-sz*.28,sz);ctx.lineTo(sz*.1,sz*.06);ctx.lineTo(-sz*.18,0);ctx.closePath();ctx.fill();ctx.stroke();
  } else if(cat==='I'){
    // 雪花形状
    ctx.lineWidth=2.5;
    for(let i=0;i<6;i++){const a=i*Math.PI/3;ctx.beginPath();ctx.moveTo(0,0);ctx.lineTo(Math.cos(a)*sz,Math.sin(a)*sz);ctx.stroke();}
    for(let i=0;i<6;i++){const a=i*Math.PI/3,mx=Math.cos(a)*sz*.6,my=Math.sin(a)*sz*.6,pa=a+Math.PI/2;ctx.beginPath();ctx.moveTo(mx+Math.cos(pa)*sz*.28,my+Math.sin(pa)*sz*.28);ctx.lineTo(mx-Math.cos(pa)*sz*.28,my-Math.sin(pa)*sz*.28);ctx.stroke();}
    ctx.fillStyle=col;ctx.beginPath();ctx.arc(0,0,sz*.22,0,Math.PI*2);ctx.fill();
  } else if(cat==='N'){
    ctx.beginPath();ctx.arc(0,0,sz,0,Math.PI*2);ctx.fill();ctx.stroke();
    ctx.strokeStyle=col+'70';ctx.lineWidth=1.5;
    ctx.beginPath();ctx.moveTo(-sz,0);ctx.lineTo(sz,0);ctx.stroke();
    ctx.beginPath();ctx.moveTo(0,-sz);ctx.lineTo(0,sz);ctx.stroke();
  } else if(cat==='M'){
    ctx.fillRect(-sz*.48,-sz,sz*.96,sz*1.8);ctx.stroke();
    ctx.fillStyle=col;ctx.fillRect(-sz*.72,-sz*.4,sz*.28,sz*.6);ctx.fillRect(sz*.44,-sz*.4,sz*.28,sz*.6);
  } else {
    ctx.beginPath();for(let i=0;i<10;i++){const a=i*Math.PI/5-Math.PI/2,r=i%2===0?sz:sz*.4;i?ctx.lineTo(Math.cos(a)*r,Math.sin(a)*r):ctx.moveTo(Math.cos(a)*r,Math.sin(a)*r);}
    ctx.closePath();ctx.fill();ctx.stroke();
  }
  ctx.restore();
  // Upgrade dots
