<!DOCTYPE html>
<html lang="zh">
<head>
<meta charset="UTF-8">
<title>末日防线 · Doomsday Defense</title>
<style>
*{margin:0;padding:0;box-sizing:border-box;-webkit-font-smoothing:antialiased;}
:root{
  --bg:#f2f2f7;--surface:#fff;--surface2:#f5f5f7;
  --border:rgba(0,0,0,0.09);--text:#1c1c1e;--text2:#6c6c70;--text3:#aeaeb2;
  --blue:#007aff;--green:#30d158;--red:#ff3b30;--orange:#ff9500;
  --yellow:#ffd60a;--purple:#bf5af2;--teal:#5ac8fa;
  --shadow:0 2px 14px rgba(0,0,0,0.07);--shadow-md:0 6px 28px rgba(0,0,0,0.13);
  --r:12px;--rs:8px;
}
body{background:var(--bg);color:var(--text);font-family:-apple-system,BlinkMacSystemFont,'SF Pro Display','Helvetica Neue',sans-serif;overflow:hidden;height:100vh;display:flex;flex-direction:column;}
#diff-screen{position:fixed;inset:0;background:var(--bg);display:flex;align-items:center;justify-content:center;flex-direction:column;gap:36px;z-index:1000;}
.game-logo h1{font-size:46px;font-weight:800;letter-spacing:-2px;text-align:center;}
.game-logo p{font-size:13px;color:var(--text3);letter-spacing:3px;text-transform:uppercase;margin-top:4px;text-align:center;}
.diff-cards{display:flex;gap:16px;}
.diff-card{width:190px;background:var(--surface);border-radius:var(--r);padding:26px 20px;cursor:pointer;border:2px solid transparent;box-shadow:var(--shadow);transition:all .2s;text-align:center;}
.diff-card:hover{transform:translateY(-5px);box-shadow:var(--shadow-md);}
.dc-easy:hover{border-color:var(--green)}.dc-normal:hover{border-color:var(--blue)}.dc-hard:hover{border-color:var(--red)}.dc-nightmare:hover{border-color:#9000ff}
.dc-icon{font-size:38px;margin-bottom:12px}.dc-name{font-size:18px;font-weight:700;margin-bottom:8px}.dc-info{font-size:11px;color:var(--text2);line-height:1.7}
.b-nightmare{background:rgba(144,0,255,.15);color:#9000ff}
#infinite-choice{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);background:rgba(10,0,20,.92);backdrop-filter:blur(18px);border-radius:18px;padding:28px 32px;display:none;flex-direction:column;align-items:center;gap:14px;z-index:150;border:1.5px solid rgba(255,100,255,.3);}
#infinite-choice.on{display:flex}
.ic-title{color:#fff;font-size:18px;font-weight:800;letter-spacing:-.3px}
.ic-sub{color:rgba(255,255,255,.5);font-size:11px;margin-top:-8px}
.ic-btns{display:flex;gap:10px;}
.ic-btn{padding:10px 18px;border-radius:12px;border:none;font-family:inherit;font-size:13px;font-weight:700;cursor:pointer;transition:.15s;}
.ic-btn:hover{transform:scale(1.06)}
.ic-3{background:#ff9500;color:#fff}.ic-5{background:#ff3b30;color:#fff}.ic-10{background:#9000ff;color:#fff}.ic-15{background:#000;color:#ff00ff;border:2px solid #ff00ff}
#hud{display:none;align-items:center;padding:0 16px;height:50px;background:rgba(255,255,255,.88);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);flex-shrink:0;z-index:20;}
.hstat{display:flex;align-items:center;gap:7px;padding:0 14px;border-right:1px solid var(--border);}
.hstat:first-child{padding-left:0}
.hstat-icon{font-size:15px}.hstat-v{font-size:16px;font-weight:700}.hstat-l{font-size:9px;color:var(--text3);text-transform:uppercase;letter-spacing:.6px}
.v-hp{color:var(--red)}.v-gold{color:var(--orange)}.v-wave{color:var(--blue)}.v-kill{color:var(--purple)}
#hud-r{margin-left:auto;display:flex;gap:8px;align-items:center;}
.hbtn{padding:7px 16px;border-radius:20px;border:none;font-family:inherit;font-size:13px;font-weight:600;cursor:pointer;transition:all .15s;}
.hbtn-p{background:var(--blue);color:#fff}.hbtn-p:hover{background:#0066dc}
.hbtn-s{background:rgba(0,0,0,.07);color:var(--text)}.hbtn-s:hover{background:rgba(0,0,0,.11)}
.diff-badge{font-size:11px;padding:3px 10px;border-radius:10px;font-weight:600;}
.b-easy{background:rgba(48,209,88,.15);color:#1a8c35}.b-normal{background:rgba(0,122,255,.12);color:var(--blue)}.b-hard{background:rgba(255,59,48,.12);color:var(--red)}
#main{display:none;flex:1;overflow:hidden;display:flex;}
#canvas-wrap{position:relative;flex:1;display:flex;align-items:center;justify-content:center;background:#dde2ee;overflow:hidden;}
canvas{display:block;}
#fw-canvas{position:absolute;inset:0;pointer-events:none;z-index:199;width:100%;height:100%;}
#panel{width:218px;background:var(--surface);border-left:1px solid var(--border);display:flex;flex-direction:column;overflow-y:auto;flex-shrink:0;}
.psec{padding:11px;border-bottom:1px solid var(--border);}
.ptitle{font-size:10px;font-weight:700;color:var(--text3);letter-spacing:.8px;text-transform:uppercase;margin-bottom:8px;}
.tcard{display:flex;align-items:center;gap:9px;padding:7px 9px;border-radius:var(--rs);cursor:pointer;border:1.5px solid transparent;transition:all .15s;margin-bottom:3px;background:var(--surface2);}
.tcard:hover{background:rgba(0,122,255,.07);border-color:rgba(0,122,255,.2)}.tcard.sel{background:rgba(0,122,255,.11);border-color:var(--blue)}.tcard.no{opacity:.4;cursor:not-allowed}
.tc-ic{font-size:18px;width:26px;text-align:center}.tc-nm{font-size:12px;font-weight:700}.tc-co{font-size:11px;color:var(--orange);font-weight:600}.tc-ds{font-size:9px;color:var(--text3);margin-top:1px}
#sel-info{display:none;}
.sel-nm{font-size:13px;font-weight:700;margin-bottom:6px}
.sel-row{display:flex;justify-content:space-between;font-size:11px;padding:3px 0;border-bottom:1px solid var(--border);}
.sel-lbl{color:var(--text2)}.sel-val{font-weight:700}
#upg-tower-btn{width:100%;margin-top:8px;padding:8px;border-radius:var(--rs);border:none;background:rgba(0,122,255,.1);color:var(--blue);font-family:inherit;font-size:12px;font-weight:700;cursor:pointer;transition:.15s;}
#upg-tower-btn:hover{background:rgba(0,122,255,.2)}
#upg-tower-btn:disabled{opacity:.35;cursor:not-allowed}
.sell-btn{width:100%;margin-top:6px;padding:7px;border-radius:var(--rs);border:none;background:rgba(255,59,48,.1);color:var(--red);font-family:inherit;font-size:12px;font-weight:700;cursor:pointer;transition:.15s;}
.sell-btn:hover{background:rgba(255,59,48,.18)}
#merge-hint{display:none;margin-top:6px;padding:6px 8px;background:rgba(255,214,10,.13);border-radius:var(--rs);font-size:10px;color:#a07800;}
.upill{display:inline-flex;align-items:center;gap:3px;font-size:10px;padding:2px 7px;border-radius:10px;background:rgba(0,0,0,.06);color:var(--text2);margin:2px;}
#upg-ov{position:absolute;inset:0;background:rgba(242,242,247,.96);backdrop-filter:blur(24px);display:none;flex-direction:column;align-items:center;justify-content:center;gap:22px;z-index:100;}
#upg-ov.on{display:flex}
.upg-title{font-size:28px;font-weight:800;letter-spacing:-.5px}.upg-sub{font-size:13px;color:var(--text2);margin-top:-14px}
.upg-cards{display:flex;gap:13px;}
.upg-card{width:175px;background:var(--surface);border-radius:var(--r);padding:20px 15px;text-align:center;cursor:pointer;border:2px solid var(--border);box-shadow:var(--shadow);transition:all .2s;}
.upg-card:hover{transform:translateY(-6px);box-shadow:var(--shadow-md);border-color:var(--blue)}
.ui-ic{font-size:30px;margin-bottom:9px}.ui-nm{font-size:13px;font-weight:700;margin-bottom:4px}.ui-ds{font-size:10px;color:var(--text2);line-height:1.55}.ui-ef{font-size:12px;font-weight:800;color:var(--blue);margin-top:9px}.ui-auto{font-size:10px;color:var(--text3);margin-top:4px;height:14px;}
#trial-bar{position:absolute;top:12px;left:50%;transform:translateX(-50%);display:none;align-items:center;gap:14px;background:rgba(255,50,100,.92);color:#fff;padding:9px 22px;border-radius:24px;font-size:13px;font-weight:700;backdrop-filter:blur(12px);z-index:80;}
#trial-bar.on{display:flex}
#trial-dmg-val{font-size:18px;font-weight:800}
#trial-time{padding:3px 10px;background:rgba(255,255,255,.2);border-radius:10px;font-size:13px}
#boss-alert{position:absolute;top:12px;left:50%;transform:translateX(-50%);display:none;background:rgba(255,59,48,.92);color:#fff;padding:10px 24px;border-radius:24px;font-size:13px;font-weight:700;backdrop-filter:blur(12px);z-index:80;}
#result{position:absolute;inset:0;display:none;align-items:center;justify-content:center;flex-direction:column;z-index:200;}
#result.on{display:flex}
#result-panel{background:rgba(255,255,255,.92);backdrop-filter:blur(28px);border-radius:24px;padding:38px 52px;text-align:center;box-shadow:var(--shadow-md);position:relative;z-index:201;}
.rt{font-size:52px;font-weight:900;letter-spacing:-2.5px}
.rt-win{color:var(--green)}.rt-lose{color:var(--red)}
.rs{font-size:14px;color:var(--text2);margin-top:8px}
.rbtn{margin-top:14px;padding:13px 34px;border-radius:24px;border:none;font-family:inherit;font-size:15px;font-weight:700;cursor:pointer;transition:.15s;display:block;width:100%;}
.rbtn-main{background:var(--blue);color:#fff;margin-bottom:8px}.rbtn-main:hover{background:#0066dc}
.rbtn-sub{background:rgba(0,0,0,.07);color:var(--text)}.rbtn-sub:hover{background:rgba(0,0,0,.12)}
#wbar{position:absolute;bottom:0;left:0;right:0;height:3px;background:rgba(0,0,0,.06);}
#wbar-f{height:100%;background:var(--blue);width:0%;transition:width .8s;border-radius:2px}
.guide-txt{font-size:10px;color:var(--text3);line-height:2.1}
</style>
</head>
<body>

<div id="diff-screen">
  <div class="game-logo"><h1>末日防线</h1><p>Doomsday Defense</p></div>
  <div class="diff-cards">
    <div class="diff-card dc-easy" onclick="chooseDiff('easy')">
      <div class="dc-icon">🌿</div><div class="dc-name" style="color:var(--green)">简单</div>
      <div class="dc-info">HP 30 · 金币 200<br>敌人血量 ×1.55<br>有点挑战</div>
    </div>
    <div class="diff-card dc-normal" onclick="chooseDiff('normal')">
      <div class="dc-icon">⚔️</div><div class="dc-name" style="color:var(--blue)">普通</div>
      <div class="dc-info">HP 20 · 金币 200<br>敌人血量 ×3.0<br>标准挑战</div>
    </div>
    <div class="diff-card dc-hard" onclick="chooseDiff('hard')">
      <div class="dc-icon">💀</div><div class="dc-name" style="color:var(--red)">困难</div>
      <div class="dc-info">HP 12 · 金币 200<br>敌人血量 ×9.0<br>真实末日</div>
    </div>
    <div class="diff-card dc-nightmare" onclick="chooseDiff('nightmare')">
      <div class="dc-icon">☠️</div><div class="dc-name" style="color:#9000ff">终极噩梦</div>
      <div class="dc-info">HP 8 · 金币 200<br>敌人血量 ×15<br>作者都无法胜利</div>
    </div>
  </div>
</div>

<div id="hud">
  <div class="hstat"><span class="hstat-icon">❤️</span><div><div class="hstat-v v-hp" id="h-hp">20</div><div class="hstat-l">HP</div></div></div>
  <div class="hstat"><span class="hstat-icon">🪙</span><div><div class="hstat-v v-gold" id="h-gold">150</div><div class="hstat-l">Gold</div></div></div>
  <div class="hstat"><span class="hstat-icon">🌊</span><div><div class="hstat-v v-wave" id="h-wave">0/20</div><div class="hstat-l">Wave</div></div></div>
  <div class="hstat"><span class="hstat-icon">💀</span><div><div class="hstat-v v-kill" id="h-kills">0</div><div class="hstat-l">Kills</div></div></div>
  <div id="hud-r">
    <span class="diff-badge" id="dbadge"></span>
    <button class="hbtn hbtn-s" onclick="toggleSpd()" id="spd-btn">1× Speed</button>
    <button class="hbtn hbtn-s" onclick="togglePause()" id="pause-btn">⏸ 暂停</button>
    <select id="music-sel" onchange="setMusic(this.value)" style="padding:6px 10px;border-radius:20px;border:1px solid var(--border);font-family:inherit;font-size:12px;font-weight:600;background:rgba(0,0,0,.06);color:var(--text);cursor:pointer;">
      <option value="off">🔇 无音乐</option>
      <option value="happy">🎵 欢快</option>
      <option value="sad">😢 忧伤</option>
      <option value="epic">⚔️ 史诗</option>
      <option value="chill">🌊 轻松</option>
      <option value="intense">🔥 紧张</option>
      <option value="mystery">🌙 神秘</option>
    </select>
    <button class="hbtn hbtn-s" onclick="if(confirm('重新开始？'))location.reload()">↺ 重来</button>
    <button class="hbtn hbtn-p" onclick="startWave()" id="start-btn" style="display:none">Start Wave 1</button>
  </div>
</div>

<div id="main">
  <div id="canvas-wrap">
    <canvas id="gc"></canvas>
    <canvas id="fw-canvas"></canvas>
    <div id="boss-alert">⚠️ BOSS INCOMING</div>
    <div id="trial-bar">
      <span>⚡ TRIAL BOSS · INVINCIBLE</span>
      <span>DMG <span id="trial-dmg-val">0</span></span>
      <span id="trial-time">30s</span>
    </div>
    <div id="upg-ov">
      <div class="upg-title">Wave Clear! 🎉</div>
      <div class="upg-sub">Choose an upgrade</div>
      <div class="upg-cards" id="upg-cards"></div>
    </div>
    <div id="result">
      <div id="result-panel">
        <div class="rt" id="rt">防守成功</div>
        <div class="rs" id="rs"></div>
        <button class="rbtn rbtn-main" onclick="location.reload()">再来一局</button>
        <button class="rbtn rbtn-sub" id="continue-btn" style="display:none" onclick="continueWatch()">继续观看烟花 🎆</button>
      </div>
    </div>
    <div id="wbar"><div id="wbar-f"></div></div>
    <div id="infinite-choice">
      <div class="ic-title">🌊 Wave 20 通关！选择无限模式倍率</div>
      <div class="ic-sub">⚠️ 必须选择，无法取消，已选无法撤回</div>
      <div class="ic-btns">
        <button class="ic-btn ic-3" onclick="chooseInfinite(3)">×3 血量</button>
        <button class="ic-btn ic-5" onclick="chooseInfinite(5)">×5 血量</button>
        <button class="ic-btn ic-10" onclick="chooseInfinite(10)">×10 血量</button>
        <button class="ic-btn ic-15" onclick="chooseInfinite(15)">×15 血量</button>
      </div>
    </div>
  </div>
  <div id="panel">
    <div class="psec" id="sel-info">
      <div class="ptitle">Selected Tower</div>
      <div class="sel-nm" id="sel-nm">—</div>
      <div class="sel-row"><span class="sel-lbl">Damage</span><span class="sel-val" id="sel-dmg">—</span></div>
      <div class="sel-row"><span class="sel-lbl">Rate</span><span class="sel-val" id="sel-rate">—</span></div>
      <div class="sel-row"><span class="sel-lbl">Range</span><span class="sel-val" id="sel-rng">—</span></div>
      <div class="sel-row"><span class="sel-lbl">Kills</span><span class="sel-val" id="sel-kl">—</span></div>
      <div class="sel-row"><span class="sel-lbl">Upgrade</span><span class="sel-val" id="sel-ulv">—</span></div>
      <button id="upg-tower-btn" onclick="upgradeTower()">升级 (50💰) → Lv2</button>
      <div id="merge-hint">⚡ Click another tower to merge</div>
      <button class="sell-btn" onclick="sellSel()">Sell (×0.6)</button>
    </div>
    <div class="psec">
      <div class="ptitle">Deploy Towers</div>
      <div id="tlist"></div>
    </div>
    <div class="psec">
      <div class="ptitle">Wave Upgrades</div>
      <div id="upg-collected"></div>
    </div>
    <div class="psec" style="margin-top:auto;">
      <div class="ptitle">Guide</div>
      <div class="guide-txt">
        Panel → place tower<br>
        Tower → select / upgrade / merge<br>
        Right-click → deselect<br>
        ★+★ same type = Merge<br>
        🔮 Hidden: Laser+Electric<br>
        ⚡❄ Hidden: Ice+Electric
      </div>
    </div>
    <div class="psec" style="background:rgba(255,214,10,.07);">
      <div style="font-size:10px;color:#a07800;line-height:1.8;">⚠️ 注意：两个1★合成2★后攻击力可能反而变低，合成前先对比伤害数值再决定！</div>
    </div>
  </div>
</div>

<script>
'use strict';

// ── BALANCE ─────────────────────────────────────────────────────
const DMGM=0.2;  // all tower dmg ×0.2
const RTEM=3;    // all tower rate ×3

// ── MAP ──────────────────────────────────────────────────────────
const CELL=52,COLS=17,ROWS=10,CW=COLS*CELL,CH=ROWS*CELL;
const RAW=[[0,2],[1,2],[2,2],[3,2],[3,3],[3,4],[3,5],[3,6],[3,7],[4,7],[5,7],[6,7],[7,7],[8,7],[8,6],[8,5],[8,4],[8,3],[8,2],[8,1],[9,1],[10,1],[11,1],[12,1],[13,1],[13,2],[13,3],[13,4],[13,5],[13,6],[13,7],[13,8],[14,8],[15,8],[16,8]];
const PATH=RAW.map(([c,r])=>({c,r,x:c*CELL+CELL/2,y:r*CELL+CELL/2}));
const PSET=new Set(RAW.map(([c,r])=>`${c},${r}`));

// ── TOWER DEFS ───────────────────────────────────────────────────
// 性价比基准：机枪=1.0（54.6 DPS / 60金）
const TD={
  // ── 1★ 基础（可购买，价格从低到高）──
  GUNNER:    {nm:'机枪塔',  ic:'🔫',st:1,cat:'G',at:'projectile',dmg:14,  rate:6.5, rng:3.2,cost:60, col:'#ff6030',ds:'高射速 单体 · 比值1.0',   ef:{}},
  ICE:       {nm:'冰冻塔',  ic:'🧊',st:1,cat:'I',at:'ice',       dmg:22,  rate:2.5, rng:3.8,cost:100,col:'#80d8ff',ds:'减速30% · 位置好比值1.8', ef:{slow:.30,dur:2.5}},
  LASER:     {nm:'激光塔',  ic:'⚡',st:1,cat:'L',at:'laser',     dmg:325, rate:0,   rng:4.5,cost:130,col:'#00aaff',ds:'穿透持续 · 比值1.1',      ef:{pierce:4}},
  ELECTRIC:  {nm:'电磁塔',  ic:'🌩',st:1,cat:'E',at:'chain',     dmg:92,  rate:1.6, rng:3.5,cost:180,col:'#ffd700',ds:'链式3跳 · 比值1.2',       ef:{jumps:2,decay:.72}},
  MECH:      {nm:'机甲塔',  ic:'🤖',st:1,cat:'M',at:'mech',      dmg:420, rate:2,   rng:3.8,cost:200,col:'#7090ff',ds:'召唤机甲 每5秒爆炸 · 比值1.15+',ef:{hp:260,spd:62,exrad:85,exdmg:1800}},
  NUKE:      {nm:'核爆塔',  ic:'☢️',st:1,cat:'N',at:'nuke',      dmg:875, rate:0.1, rng:5.0,cost:320,col:'#ff3030',ds:'AOE爆炸 · 比值1.5',       ef:{cd:4,  rad:108}},
  // ── 2★ 合成 ──
  RAPIDFIRE: {nm:'速射塔',  ic:'🔫',st:2,cat:'G',at:'projectile',dmg:22,  rate:14,  rng:3.8,cost:0,  col:'#ff3800',ds:'超高射速',   ef:{}},
  BLIZZARD:  {nm:'极寒塔',  ic:'❄️',st:2,cat:'I',at:'ice',       dmg:44,  rate:3.5, rng:4.5,cost:0,  col:'#40c8ff',ds:'减速40% 双发',ef:{slow:.40,dur:3}},
  PRISM:     {nm:'棱镜激光',ic:'⚡',st:2,cat:'L',at:'laser',     dmg:650, rate:0,   rng:5.5,cost:0,  col:'#0070ff',ds:'双线穿透',   ef:{pierce:7,dual:true}},
  STORM:     {nm:'雷暴塔',  ic:'🌩',st:2,cat:'E',at:'chain',     dmg:185, rate:2.2, rng:4.2,cost:0,  col:'#ffe040',ds:'5跳链式',    ef:{jumps:4,decay:.74}},
  MEGATON:   {nm:'百万吨塔',ic:'☢️',st:2,cat:'N',at:'nuke',      dmg:1750,rate:0.1, rng:6.0,cost:0,  col:'#ff1010',ds:'超级爆炸',   ef:{cd:3,  rad:145}},
  TITAN:     {nm:'泰坦机甲',ic:'🤖',st:2,cat:'M',at:'mech',      dmg:840, rate:2.5, rng:4.5,cost:0,  col:'#5070ff',ds:'重甲 大爆炸',ef:{hp:480,spd:52,exrad:130,exdmg:4500}},
  // ── 3★ 合成 ──
