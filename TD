  if(trial){gs.push({t:'TRIAL',n:1,iv:0});gs.push({t:'TANK',n:Math.floor(n*.7),iv:.65});}
  else if(boss){gs.push({t:'BOSS',n:1,iv:0});gs.push({t:'TANK',n,iv:.75});}
  else{gs.push({t:'FAST',n:Math.ceil(n*.45),iv:.38});gs.push({t:'TANK',n:Math.floor(n*.55),iv:.82});}
