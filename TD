// ── WAVE GEN ─────────────────────────────────────────────────────
function makeWaves(){
  const W=[];
  for(let w=1;w<=20;w++){
    const trial=w%10===0,boss=w%5===0&&!trial;
    const n=Math.floor(11+w*2.8),gs=[];
    if(trial){gs.push({t:'TRIAL',n:1,iv:0});gs.push({t:w>=15?'TANK':'BASIC',n:Math.floor(n*.7),iv:.72});}
    else if(boss){gs.push({t:'BOSS',n:1,iv:0});gs.push({t:w>=15?'TANK':'BASIC',n,iv:.82});}
    else if(w<=3) gs.push({t:'BASIC',n,iv:.9});
    else if(w<=7){gs.push({t:'BASIC',n:Math.ceil(n*.58),iv:.8});gs.push({t:'FAST',n:Math.floor(n*.42),iv:.52});}
    else if(w<=12){gs.push({t:'FAST',n:Math.ceil(n*.4),iv:.48});gs.push({t:'TANK',n:Math.ceil(n*.32),iv:1.1});gs.push({t:'BASIC',n:Math.floor(n*.28),iv:.72});}
    else{gs.push({t:'FAST',n:Math.ceil(n*.45),iv:.42});gs.push({t:'TANK',n:Math.floor(n*.55),iv:.98});}
    W.push({w,boss,trial,gs});
  }
  return W;
}
