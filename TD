function scheduleBeat(mood,startTime){
  if(_musicMood!==mood) return;
  const c=getACtx(),b=BEATS[mood];
  const step=60/b.bpm/4; // 16th note
  const STEPS=16;
  for(let i=0;i<STEPS;i++){
    const t=startTime+i*step;
    if(b.kick[i])  kick(t,c);
    if(b.snare[i]) snare(t,c);
    if(b.hat[i])   hihat(t,c,b===BEATS.intense?.12:.07);
    if(b.bass[i])  note(midiFreq(b.bass[i]),t,step*1.8,'sine',.09,c);
    if(b.mel[i])   note(midiFreq(b.mel[i]), t,step*.85,'triangle',.055,c);
  }
  // Schedule next bar slightly early to avoid gaps
  const barDur=STEPS*step;
  _musicSched=setTimeout(()=>scheduleBeat(mood,startTime+barDur),barDur*900);
}
function startMusicLoop(mood){
  stopMusic();
  if(mood==='off'||!BEATS[mood]) return;
  _musicMood=mood;_beat=0;
  try{scheduleBeat(mood,getACtx().currentTime+.05);}catch(e){}
}
function stopMusic(){
  if(_musicSched){clearTimeout(_musicSched);_musicSched=null;}
  _musicMood='off';
}
function setMusic(v){startMusicLoop(v);}

// ── PAUSE ────────────────────────────────────────────────────────
let _paused=false;
function togglePause(){
  _paused=!_paused;
  document.getElementById('pause-btn').textContent=_paused?'▶ 继续':'⏸ 暂停';
  const sel=document.getElementById('music-sel');
  if(_paused) stopMusic();
  else if(sel&&sel.value!=='off') startMusicLoop(sel.value);
}

function toggleSpd(){G.spd=G.spd===1?2:G.spd===2?3:1;document.getElementById('spd-btn').textContent=`${G.spd}× Speed`;}
function updateUI(){
  document.getElementById('h-hp').textContent=G.hp;document.getElementById('h-gold').textContent=G.gold;
  const wlbl=G.infinite?`∞${G.wave}`:`${G.wave}/20`;
  document.getElementById('h-wave').textContent=wlbl;document.getElementById('h-kills').textContent=G.kills;
  buildTList();if(G.selT) showTInfo(G.selT);
}

// ── INPUT ────────────────────────────────────────────────────────
cv.addEventListener('click',e=>{
  const rc=cv.getBoundingClientRect(),sx=CW/rc.width,sy=CH/rc.height;
  const x=(e.clientX-rc.left)*sx,y=(e.clientY-rc.top)*sy;
  const c=Math.floor(x/CELL),r=Math.floor(y/CELL);
  if(c<0||c>=COLS||r<0||r>=ROWS) return;
  const tw=G.towers.find(t=>t.c===c&&t.r===r);
  if(G.selK){
    if(!PSET.has(`${c},${r}`)&&!tw){
      const def=TD[G.selK];
      if(G.gold<def.cost){flt(x,y-20,'金币不足!','#ff3b30',14);return;}
      G.gold-=def.cost;placeTower(c,r,G.selK);spawnPart(c*CELL+CELL/2,r*CELL+CELL/2,def.col,10,60);updateUI();
    }
  } else if(tw) selTower(tw);
  else{G.selT=null;G.mergeA=null;document.getElementById('sel-info').style.display='none';document.getElementById('merge-hint').style.display='none';buildTList();}
});
cv.addEventListener('contextmenu',e=>{
  e.preventDefault();G.selK=null;G.selT=null;G.mergeA=null;
  document.getElementById('sel-info').style.display='none';document.getElementById('merge-hint').style.display='none';buildTList();
});

// ── DIFF SELECT ──────────────────────────────────────────────────
function chooseDiff(diff){
  document.getElementById('diff-screen').style.display='none';
  document.getElementById('hud').style.display='flex';document.getElementById('main').style.display='flex';
  const map={easy:['b-easy','🌿 简单'],normal:['b-normal','⚔️ 普通'],hard:['b-hard','💀 困难'],nightmare:['b-nightmare','☠️ 噩梦']};
  const bd=document.getElementById('dbadge');bd.className='diff-badge '+map[diff][0];bd.textContent=map[diff][1];
  sizeCanvas();newGame(diff);updateUI();
  document.getElementById('start-btn').style.display='inline-block';
}
// 全局屏蔽右键菜单，不影响游戏体验
document.addEventListener('contextmenu',e=>e.preventDefault());

// ── MAIN LOOP ────────────────────────────────────────────────────
let lastT=0;
function loop(ts){
  const rawDt=Math.min((ts-lastT)/1000,.05);lastT=ts;
  if(G&&!_paused){
    const dt=rawDt*G.spd;
    const active=G.state==='wave'||G.state==='trial';
    if(active){
      if(G.state==='wave') waveUpdate(dt);else trialUpdate(dt);
      updateTowers(dt);updateProjs(dt);updateMechs(dt);updateEnemies(dt);checkDeaths();
    }
    updateEfx(rawDt);render();
    if(flashT>0){ctx.save();ctx.fillStyle=`rgba(255,255,255,${flashT*2.2})`;ctx.fillRect(0,0,CW,CH);ctx.restore();}
    if(fw.active||fw.particles.length) updateFireworks(rawDt);
  }
  requestAnimationFrame(loop);
}
requestAnimationFrame(ts=>{lastT=ts;requestAnimationFrame(loop);});
window.addEventListener('resize',()=>{if(G) sizeCanvas();});
</script>
