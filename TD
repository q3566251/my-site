let _upgPool=[],_autoIv=null;
function buildUpgradePool(){
  // Update rarity block counter
  const block=Math.floor((G.wave-1)/10);
  if(block!==G.rareBlock){G.rareBlock=block;G.rareCount=0;}
  const commons=UPGRADES.filter(u=>u.r==='common');
  const rares  =UPGRADES.filter(u=>u.r==='rare');
  const epics  =UPGRADES.filter(u=>u.r==='epic');
  // Build weighted pool
  const pool=[];
  // Always add all commons
  commons.forEach(u=>pool.push(u));
  // Add rare if quota not full and 10% roll
  if(G.rareCount<2) rares.forEach(u=>{if(Math.random()<.10) pool.push(u);});
  // Add epic if not used and 15% roll
  if(!G.epicUsed) epics.forEach(u=>{if(Math.random()<.15) pool.push(u);});
  // If pool too small, pad with commons
  while(pool.length<3) pool.push(commons[Math.floor(Math.random()*commons.length)]);
  // Shuffle and pick 3 unique names
  const seen=new Set();
  return pool.sort(()=>Math.random()-.5).filter(u=>{
    if(seen.has(u.nm)) return false;seen.add(u.nm);return true;
  }).slice(0,3);
}
