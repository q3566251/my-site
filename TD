// ── ATTACK SYSTEM ────────────────────────────────────────────────
const dist=(a,b)=>Math.hypot(a.x-b.x,a.y-b.y);
function findTarget(cx,cy,rng){
  let best=null,bpi=-1;
  for(const e of G.enemies) if(e.hp>0&&dist({x:cx,y:cy},e)<=rng&&e.pi>bpi){bpi=e.pi;best=e;}
  return best;
}
function updateTowers(dt){
  for(const t of G.towers){
    const def=TD[t.k];
    if(['mech'].includes(def.at)) continue;
    const tx=t.c*CELL+CELL/2,ty=t.r*CELL+CELL/2;
    const rng=tRng(t)*CELL*G.m.rx,dmg=tDmg(t)*G.m.dx,rate=tRate(t)*G.m.as;

    if(def.at==='laser'||def.at==='plasma'){
      const tgt=findTarget(tx,ty,rng);
      if(tgt){
        t.ang=Math.atan2(tgt.y-ty,tgt.x-tx)+Math.PI/2;
        const dps=dmg*dt;
        if(!t._bt||t._bt<=0){
          G.efx.push({type:'beam',x1:tx,y1:ty,x2:tgt.x,y2:tgt.y,col:def.col,st:def.st,li:.12,ml:.12});
          if(def.ef.dual){const t2=findSecond(tx,ty,tgt,rng);if(t2) G.efx.push({type:'beam',x1:tx,y1:ty,x2:t2.x,y2:t2.y,col:def.col+'80',st:1,li:.1,ml:.1});}
          t._bt=.08;
        } else t._bt-=dt;
        hitE(tgt,dps,false,def.col,t);
        if(def.ef.pierce){let pc=0;for(const e of G.enemies){if(e===tgt||pc>=(def.ef.pierce||0)||e.hp<=0)continue;if(ptDist({x:tx,y:ty},tgt,e)<ED[e.type].sz*1.4&&dist({x:tx,y:ty},e)<=rng){hitE(e,dps*.55,false,def.col,t);pc++;}}}
        if(def.ef.dual){const t2=findSecond(tx,ty,tgt,rng);if(t2) hitE(t2,dps*.48,false,def.col,t);}
        if(def.at==='plasma'){t.cd-=dt;if(t.cd<=0){t.cd=1/(rate||2);doChain(t,tgt,dmg*.35,def.ef.jumps,def.ef.decay,def.col);}}
      }
      continue;
    }
    if(def.at==='chain'){
      t.cd-=dt;if(t.cd>0) continue;
      const tgt=findTarget(tx,ty,rng);if(!tgt) continue;
      t.ang=Math.atan2(tgt.y-ty,tgt.x-tx)+Math.PI/2;t.cd=1/rate;
      doChain(t,tgt,dmg,def.ef.jumps,def.ef.decay,def.col);continue;
    }
    if(def.at==='nuke'){
      t.cd-=dt*G.m.nc;if(t.cd>0) continue;
      const tgt=findTarget(tx,ty,rng*1.4);if(!tgt) continue;
      t.cd=def.ef.cd*(1-t.upgLv*.08);
      const nx=tgt.x,ny=tgt.y,rad=def.ef.rad*(1+t.upgLv*.12),ndmg=dmg,col=def.col;
      setTimeout(()=>{
        if(!G||G.state==='over'||G.state==='win') return;
        G.efx.push({type:'explosion',x:nx,y:ny,rad,col,li:.65,ml:.65});
        shake(12,.3);flashScreen();
        // 性能优化：平方距离，少粒子，低shadowBlur
        const rad2=rad*rad;
        for(const e of G.enemies){
          const dd=(nx-e.x)*(nx-e.x)+(ny-e.y)*(ny-e.y);
          if(dd<=rad2) hitE(e,ndmg*(1-Math.sqrt(dd)/rad*.5),false,col,t);
        }
        spawnPart(nx,ny,col,10,120);flt(nx,ny-65,'💥 NUKE!',col,26);
      },1000);
      spawnPart(tgt.x,tgt.y,'#ff4040',3,22);flt(tgt.x,tgt.y-22,'⚠️',def.col,18);continue;
    }
    // ice projectile
    if(def.at==='ice'||def.at==='thunderblizz'){
      t.cd-=dt;if(t.cd>0) continue;
      const tgt=findTarget(tx,ty,rng);if(!tgt) continue;
      t.ang=Math.atan2(tgt.y-ty,tgt.x-tx)+Math.PI/2;t.cd=1/rate;
      const slow=iceSlowOf(t),dur=def.ef.dur||2.5;
      const spd2=260+def.st*36,dx2=tgt.x-tx,dy2=tgt.y-ty,ml2=Math.hypot(dx2,dy2);
      G.projs.push({id:G.pid++,x:tx,y:ty,vx:dx2/ml2*spd2,vy:dy2/ml2*spd2,pt:'ice',col:def.col,dmg,st:def.st,ch:def.at==='thunderblizz'?(def.ef.jumps||3):G.m.ch,hits:new Set(),tid:t.id,slow,dur,isIce:true,isThunderBlizz:def.at==='thunderblizz',tbJumps:def.ef.jumps||3,tbDecay:def.ef.decay||.75});
      continue;
    }
    // projectile
    t.cd-=dt;if(t.cd>0) continue;
    const tgt=findTarget(tx,ty,rng);if(!tgt) continue;
    t.ang=Math.atan2(tgt.y-ty,tgt.x-tx)+Math.PI/2;t.cd=1/rate;
    const spd=285+def.st*42,dx=tgt.x-tx,dy=tgt.y-ty,ml=Math.hypot(dx,dy);
    G.projs.push({id:G.pid++,x:tx,y:ty,vx:dx/ml*spd,vy:dy/ml*spd,pt:'bullet',col:def.col,dmg,st:def.st,ch:G.m.ch,hits:new Set(),tid:t.id});
  }
}
function findSecond(tx,ty,excl,rng){
  let best=null,bpi=-1;
  for(const e of G.enemies) if(e!==excl&&e.hp>0&&dist({x:tx,y:ty},e)<=rng&&e.pi>bpi){bpi=e.pi;best=e;}
  return best;
}
function ptDist(A,B,P){
  const dx=B.x-A.x,dy=B.y-A.y,l=Math.hypot(dx,dy);
  if(l===0) return dist(A,P);
  const t=Math.max(0,Math.min(1,((P.x-A.x)*dx+(P.y-A.y)*dy)/(l*l)));
  return Math.hypot(P.x-(A.x+t*dx),P.y-(A.y+t*dy));
}
function doChain(tower,first,dmg,jumps,decay,col){
  let cur=first,prevs=new Set([first.id]),d=dmg;
  hitE(cur,d,false,col,tower);
  G.efx.push({type:'chain',x1:tower.c*CELL+CELL/2,y1:tower.r*CELL+CELL/2,x2:cur.x,y2:cur.y,col,li:.26,ml:.26});
  for(let j=0;j<jumps;j++){
    let next=null,nd=9999;
    for(const e of G.enemies) if(!prevs.has(e.id)&&e.hp>0){const dd=dist(cur,e);if(dd<210&&dd<nd){nd=dd;next=e;}}
    if(!next) break;
    d*=decay;hitE(next,d,false,col,tower);
    G.efx.push({type:'chain',x1:cur.x,y1:cur.y,x2:next.x,y2:next.y,col,li:.26,ml:.26});
    prevs.add(next.id);cur=next;
  }
}

// ── ICE / MECH ────────────────────────────────────────────────────
function iceSlowOf(tower){
  const base=TD[tower.k].ef.slow||.30;
  return Math.min(.70,base+(G.m.si||0)+(tower.upgLv*.10));
}
function spawnMech(tower){
  const def=TD[tower.k];
  const maxM=1+Math.floor(tower.upgLv/2);
  if(G.mechs.filter(m=>m.tid===tower.id).length>=maxM) return;
  G.mechs.push({
    id:G.pid++,tid:tower.id,
    x:tower.c*CELL+CELL/2+(Math.random()-.5)*24,
    y:tower.r*CELL+CELL/2+(Math.random()-.5)*24,
    hp:def.ef.hp*(1+tower.upgLv*.25),
    mhp:def.ef.hp*(1+tower.upgLv*.25),
    ang:0,cd:0,st:tower.st,
    exrad:def.ef.exrad||85,
    exdmg:(def.ef.exdmg||1800)*(1+tower.upgLv*.3),
    explodeTimer:5,
  });
}
function triggerMechExplosion(m){
  const tw=G.towers.find(t=>t.id===m.tid);
  if(tw) tw._mechRespawn=5;
  const rad=m.exrad;
  G.efx.push({type:'explosion',x:m.x,y:m.y,rad,col:'#ff8030',li:.7,ml:.7});
  spawnPart(m.x,m.y,'#ff6020',14,110);
  flt(m.x,m.y-44,'💥 BOOM!','#ff8030',20);
  shake(9,.28);flashScreen();
  const rad2=rad*rad;
  for(const e of G.enemies){
    if(e.type==='BOSS'||e.type==='TRIAL') continue;
    const dd=(m.x-e.x)**2+(m.y-e.y)**2;
    if(dd<=rad2) hitE(e,m.exdmg*(1-Math.sqrt(dd)/rad*.4),false,'#ff8030',tw||null);
  }
}
function updateMechs(dt){
  for(const tw of G.towers){
    if(TD[tw.k].at!=='mech') continue;
    tw._mechRespawn=(tw._mechRespawn||0)-dt;
    const maxM=1+Math.floor(tw.upgLv/2);
    if(G.mechs.filter(m=>m.tid===tw.id).length<maxM&&tw._mechRespawn<=0){
      spawnMech(tw);tw._mechRespawn=5;
    }
  }
  const dying=[];
  G.mechs=G.mechs.filter(m=>{
    const tw=G.towers.find(t=>t.id===m.tid);
    if(!tw||m.hp<=0){dying.push(m);return false;}
    m.explodeTimer-=dt;
    if(m.explodeTimer<=0){dying.push(m);return false;}
    return true;
  });
  for(const m of dying) triggerMechExplosion(m);
  for(const m of G.mechs){
    const tw=G.towers.find(t=>t.id===m.tid);if(!tw) continue;
    const def=TD[tw.k],spd=def.ef.spd||62;
    let tgt=null,nd=9999;
    for(const e of G.enemies) if(e.hp>0){const dd=dist(m,e);if(dd<nd){nd=dd;tgt=e;}}
    if(tgt){
      const dx=tgt.x-m.x,dy=tgt.y-m.y,d=Math.hypot(dx,dy);
      if(d>38){m.x+=dx/d*spd*dt;m.y+=dy/d*spd*dt;}
      m.ang=Math.atan2(dy,dx);
    } else {
      const tx=tw.c*CELL+CELL/2,ty=tw.r*CELL+CELL/2,d=dist(m,{x:tx,y:ty});
      if(d>55){m.x+=(tx-m.x)/d*spd*.5*dt;m.y+=(ty-m.y)/d*spd*.5*dt;}
    }
    m.cd-=dt;
    if(m.cd<=0&&tgt&&dist(m,tgt)<52){
      m.cd=1/(tRate(tw)*G.m.as);
      hitE(tgt,tDmg(tw)*G.m.dx,Math.random()<G.m.cr,def.col,tw);
    }
    for(const e of G.enemies) if(dist(m,e)<ED[e.type].sz+14) m.hp-=ED[e.type].spd*.032*dt;
  }
}

// ── DAMAGE + FLOATS ──────────────────────────────────────────────
function hitE(e,dmg,crit,col,tower){
  if(!e||e.hp<=0) return;
  let d=dmg;
  if((e.type==='BOSS'||e.type==='TANK')&&G.m.ap>1) d*=G.m.ap;
  const v=crit?d*G.m.cx:d;
  if(e.type==='TRIAL'){G.trialDmg+=v;G.tdmg+=v;if(tower) tower.dmg+=v;}
  else{e.hp-=v;G.tdmg+=v;if(tower) tower.dmg+=v;}
  const fc=crit?'#ff3b30':col,sz=crit?24:15;
  // SPREAD: random x offset ±55, random y offset so numbers don't stack
  const ox=(Math.random()-.5)*55,oy=-(8+Math.random()*28);
  flt(e.x+ox,e.y+oy,crit?`💥${Math.round(v)}`:`${Math.round(v)}`,fc,sz);
  spawnPart(e.x,e.y,col,2,28);
}
function updateProjs(dt){
  const rem=new Set();
  for(const p of G.projs){
    p.x+=p.vx*dt;p.y+=p.vy*dt;
    if(p.x<-80||p.x>CW+80||p.y<-80||p.y>CH+80){rem.add(p.id);continue;}
    for(const e of G.enemies){
      if(e.hp<=0||p.hits.has(e.id)) continue;
      if(dist(p,e)<ED[e.type].sz+5){
        p.hits.add(e.id);
        const crit=Math.random()<G.m.cr,tw=G.towers.find(t=>t.id===p.tid);
        hitE(e,p.dmg,crit,p.col,tw);
        if(p.isIce){
          // 减速：不叠加，取最大值
          if(!e.frzSlow||p.slow>e.frzSlow){e.frz=p.dur;e.frzSlow=p.slow;}
          else e.frz=Math.max(e.frz,p.dur);
          spawnPart(e.x,e.y,'#80d8ff',4,40);
          if(p.isThunderBlizz) doIceChain(p,e,tw);
        }
        if(p.ch>0&&!p.isIce){chainProj(p,e);rem.add(p.id);break;}
        rem.add(p.id);break;
      }
    }
  }
  G.projs=G.projs.filter(p=>!rem.has(p.id));
}
function doIceChain(src,from,tower){
  let cur=from,prevs=new Set([from.id]),d=src.dmg,jmps=src.tbJumps||3;
  for(let j=0;j<jmps;j++){
    let next=null,nd=9999;
    for(const e of G.enemies) if(!prevs.has(e.id)&&e.hp>0){const dd=dist(cur,e);if(dd<200&&dd<nd){nd=dd;next=e;}}
    if(!next) break;
    d*=(src.tbDecay||.75);
    hitE(next,d,false,src.col,tower);
    if(!next.frzSlow||src.slow>next.frzSlow){next.frz=src.dur;next.frzSlow=src.slow;}
    G.efx.push({type:'chain',x1:cur.x,y1:cur.y,x2:next.x,y2:next.y,col:'#00ffcc',li:.22,ml:.22});
    prevs.add(next.id);cur=next;
  }
}
function chainProj(src,from){
  let near=null,nd=9999;
  for(const e of G.enemies) if(!src.hits.has(e.id)&&e.hp>0){const d=dist(from,e);if(d<220&&d<nd){nd=d;near=e;}}
  if(!near) return;
  const spd=380,dx=near.x-from.x,dy=near.y-from.y,m=Math.hypot(dx,dy);
  G.projs.push({id:G.pid++,x:from.x,y:from.y,vx:dx/m*spd,vy:dy/m*spd,pt:'bullet',col:'#ffff30',dmg:src.dmg*.55,st:src.st,ch:src.ch-1,hits:new Set(src.hits).add(from.id),tid:src.tid});
}
function updateEnemies(dt){
  for(const e of G.enemies){
    if((e.frz||0)>0) e.frz=Math.max(0,e.frz-dt);
    else e.frzSlow=0;
    const def=ED[e.type],d=DIFF[G.diff],slowMult=e.frz>0?(1-(e.frzSlow||.3)):1;
    const spd=def.spd*d.espd*slowMult;
    const nxt=PATH[e.pi+1];
    if(!nxt){
      if(e.type!=='TRIAL'){
        const dmg=e.type==='BOSS'?6:e.type==='TANK'?3:1;
        G.hp=Math.max(0,G.hp-dmg);
        flt(PATH[PATH.length-1].x,PATH[PATH.length-1].y-28,`-${dmg}❤️`,'#ff3b30',20);
        updateUI();
        if(G.hp<=0&&(G.state==='wave'||G.state==='trial')){G.state='over';setTimeout(gameOver,500);}
      }
      G.enemies=G.enemies.filter(x=>x!==e);continue;
    }
    const dx=nxt.x-e.x,dy=nxt.y-e.y,dd=Math.hypot(dx,dy),step=spd*dt;
    if(dd<=step){e.x=nxt.x;e.y=nxt.y;e.pi++;}else{e.x+=dx/dd*step;e.y+=dy/dd*step;}
  }
}
function checkDeaths(){
  const dead=G.enemies.filter(e=>e.hp<=0&&e.type!=='TRIAL');
  for(const e of dead){
    const def=ED[e.type],rwd=Math.round(def.rwd*G.m.gx);
    G.gold+=rwd;G.kills++;G.earn+=rwd;
    flt(e.x+(Math.random()-.5)*30,e.y-20,`+${rwd}💰`,'#ffd60a',14);
    spawnPart(e.x,e.y,def.col,16,90);
    if(e.type==='BOSS'){shake(18,.7);flt(e.x,e.y-65,'💀 BOSS DEFEATED!','#ff3b30',26);}
