<!DOCTYPE html>
<html lang="zh">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Z5S Stress · 压力启动倾向量表 V1</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:wght@300;400;500;600;700&display=swap');

*{box-sizing:border-box;margin:0;padding:0}
:root{
  --ink:#1a1814;
  --ink2:#5a554e;
  --ink3:#9a9590;
  --bg:#f6f4ef;
  --card:#ffffff;
  --border:#e8e4dc;
  --A-c:#3e7c22;--A-bg:#eef6e6;--A-tc:#2a5a14;
  --B-c:#2060b0;--B-bg:#e4eef8;--B-tc:#144080;
  --C-c:#c07010;--C-bg:#fdf0dc;--C-tc:#8a4e08;
  --D-c:#7050c8;--D-bg:#eeebfc;--D-tc:#4a34a0;
  --E-c:#c03820;--E-bg:#fce8e4;--E-tc:#902010;
  --accent:#5a4fcc;
}

body{font-family:'DM Sans',sans-serif;background:var(--bg);min-height:100vh;color:var(--ink)}
h1,h2,.serif{font-family:'DM Serif Display',serif}

.page{display:none}.page.active{display:block}
.wrap{max-width:680px;margin:0 auto;padding:2.5rem 1.5rem}

/* ── HERO ── */
.hero{
  background:linear-gradient(150deg,#1a1530 0%,#2d2660 60%,#1e3060 100%);
  border-radius:20px;padding:2.75rem 2.5rem;margin-bottom:2rem;
  position:relative;overflow:hidden;
}
.hero::before{
  content:'';position:absolute;inset:0;
  background:radial-gradient(ellipse at 80% 20%,rgba(120,100,255,.25) 0%,transparent 60%),
             radial-gradient(ellipse at 20% 80%,rgba(60,120,255,.15) 0%,transparent 50%);
}
.hero-inner{position:relative;z-index:1}
.hero-badge{display:inline-flex;align-items:center;gap:6px;
  background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.15);
  border-radius:20px;padding:5px 14px;font-size:11px;font-weight:600;
  color:rgba(255,255,255,.7);letter-spacing:.1em;text-transform:uppercase;margin-bottom:1.25rem}
.hero h1{font-size:30px;color:#fff;margin-bottom:.6rem;line-height:1.25}
.hero .sub{font-size:15px;color:rgba(255,255,255,.65);line-height:1.65;max-width:460px}
.stress-dots{display:flex;gap:6px;margin-top:1.5rem}
.stress-dot{width:8px;height:8px;border-radius:50%;opacity:.6}

/* ── INFO CARD ── */
.info-card{background:var(--card);border:1px solid var(--border);border-radius:14px;
  padding:1.35rem 1.6rem;margin-bottom:1.75rem;box-shadow:0 1px 4px rgba(0,0,0,.04)}
.info-row{display:flex;align-items:flex-start;gap:10px;font-size:14px;
  color:var(--ink2);margin-bottom:.75rem;line-height:1.6}
.info-row:last-child{margin-bottom:0}
.info-dot{width:5px;height:5px;border-radius:50%;background:var(--accent);flex-shrink:0;margin-top:7px}

/* ── PROGRESS ── */
.prog-wrap{margin-bottom:2rem}
.prog-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:.5rem}
.prog-label{font-size:12px;font-weight:700;color:var(--ink3);letter-spacing:.08em;text-transform:uppercase}
.prog-count{font-size:13px;font-weight:700;color:var(--accent)}
.prog-bar{height:4px;background:var(--border);border-radius:2px}
.prog-fill{height:100%;background:var(--accent);border-radius:2px;transition:width .4s ease}

/* ── QUESTION CARD ── */
.section-label{font-size:11px;font-weight:700;color:var(--ink3);letter-spacing:.1em;
  text-transform:uppercase;padding:.5rem 0 .75rem;border-top:1px solid var(--border);
  margin-top:1.5rem;margin-bottom:.5rem}
.section-label:first-child{border-top:none;margin-top:0}

.qcard{background:var(--card);border:1px solid var(--border);border-radius:14px;
  padding:1.5rem 1.6rem;margin-bottom:.85rem;box-shadow:0 1px 4px rgba(0,0,0,.04);
  transition:border-color .2s}
.qcard.answered{border-color:#c8c4f0}
.qcard-top{display:flex;align-items:flex-start;gap:10px;margin-bottom:1.25rem}
.qnum{font-size:11px;font-weight:700;color:var(--ink3);min-width:24px;padding-top:3px;flex-shrink:0}
.qtext{font-size:15px;line-height:1.7;color:var(--ink);font-weight:500}
.reverse-tag{display:inline-block;font-size:10px;font-weight:700;color:#c07010;
  background:#fdf0dc;border-radius:4px;padding:1px 6px;margin-left:6px;vertical-align:middle}

/* ── LIKERT SCALE ── */
.likert{display:flex;flex-direction:column;gap:0}
.likert-labels{display:flex;justify-content:space-between;font-size:10.5px;
  color:var(--ink3);margin-bottom:.6rem;padding:0 2px}
.likert-row{display:flex;gap:6px}
.lopt{flex:1;background:var(--bg);border:1.5px solid var(--border);border-radius:10px;
  padding:.65rem .3rem;cursor:pointer;font-size:14px;font-weight:600;color:var(--ink2);
  text-align:center;transition:all .15s;line-height:1}
.lopt:hover{border-color:var(--accent);background:#eeedfc;color:var(--accent)}
.lopt.sel{border-color:var(--accent);background:var(--accent);color:#fff;
  box-shadow:0 2px 8px rgba(90,79,204,.3)}

/* ── BUTTONS ── */
.btn-row{display:flex;gap:12px;margin-top:2rem;padding-bottom:3rem}
.btnP{background:var(--accent);color:#fff;border:none;border-radius:11px;
  padding:.9rem 2rem;font-size:15px;font-weight:600;cursor:pointer;flex:1;
  transition:all .15s;font-family:inherit}
.btnP:hover{background:#4a3fb0;transform:translateY(-1px);box-shadow:0 4px 16px rgba(90,79,204,.35)}
.btnP:disabled{opacity:.35;cursor:not-allowed;transform:none;box-shadow:none}
.btnS{background:var(--card);color:var(--ink2);border:1px solid var(--border);
  border-radius:11px;padding:.85rem 1.5rem;font-size:14px;cursor:pointer;font-family:inherit;
  transition:all .15s}
.btnS:hover{background:var(--bg)}
.btnFull{width:100%;font-size:16px;padding:1.1rem;margin-top:.25rem}

/* ── RESULTS ── */
.r-header{margin-bottom:2rem}
.r-header .eyebrow{font-size:11px;color:var(--ink3);letter-spacing:.1em;
  text-transform:uppercase;font-weight:700;margin-bottom:.4rem}
.r-header h2{font-size:26px;color:var(--ink);margin-bottom:.35rem}
.r-header p{font-size:13px;color:var(--ink3)}

.rcard{background:var(--card);border:1px solid var(--border);border-radius:14px;
  padding:1.5rem 1.6rem;margin-bottom:1.1rem;box-shadow:0 1px 4px rgba(0,0,0,.04)}
.card-label{font-size:11px;color:var(--ink3);letter-spacing:.08em;text-transform:uppercase;
  font-weight:700;margin-bottom:1rem}

.primary-row{display:flex;align-items:center;gap:14px}
.p-icon{width:58px;height:58px;border-radius:15px;display:flex;align-items:center;
  justify-content:center;font-size:27px;flex-shrink:0}
.p-name{font-size:22px;font-weight:700}
.p-desc{font-size:12.5px;color:var(--ink3);margin-top:3px;line-height:1.45}
.p-score{font-size:34px;font-weight:700;margin-left:auto;flex-shrink:0;font-family:'DM Serif Display',serif}

.level-badge{display:inline-block;padding:5px 16px;border-radius:20px;
  font-size:12px;font-weight:700;margin:1rem 0 .5rem}

.bar-row{margin-bottom:1.1rem}
.bar-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:.4rem}
.bar-track{height:9px;background:#f0ede8;border-radius:5px;overflow:hidden}
.bar-fill{height:100%;border-radius:5px;transition:width 1.1s cubic-bezier(.4,0,.2,1)}

.interpret-box{background:#fafaf7;border:1px solid #edeae4;border-radius:11px;
  padding:1.35rem;font-size:14.5px;line-height:1.9;color:#2a2a2a;white-space:pre-wrap}

.sys-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:1rem}
.sys-item{border-radius:11px;padding:1rem 1.1rem}
.sys-item .sys-name{font-size:13px;font-weight:700;margin-bottom:3px}
.sys-item .sys-desc{font-size:11px;opacity:.8;line-height:1.45}

.score-chip{display:inline-flex;align-items:center;gap:5px;font-size:12px;
  font-weight:600;padding:3px 10px;border-radius:12px}

@media(max-width:480px){
  .wrap{padding:1.25rem 1rem}
  .hero{padding:2rem 1.5rem}
  .hero h1{font-size:25px}
  .likert-labels{font-size:9.5px}
  .p-score{font-size:28px}
  .sys-grid{grid-template-columns:1fr}
}
</style>
</head>
<body>

<!-- PAGE 0: INTRO -->
<div id="p0" class="page active">
<div class="wrap">
  <div class="hero">
    <div class="hero-inner">
      <div class="hero-badge">Z5S Stress · Version 1</div>
      <h1>压力启动<br>倾向量表</h1>
      <p class="sub">在困难或高压情境下，你的心理系统会如何自动启动？<br>这不是性格测试，而是压力下的反应模式扫描。</p>
      <div class="stress-dots">
        <div class="stress-dot" style="background:#3e7c22"></div>
        <div class="stress-dot" style="background:#2060b0"></div>
        <div class="stress-dot" style="background:#c07010"></div>
        <div class="stress-dot" style="background:#7050c8"></div>
        <div class="stress-dot" style="background:#c03820"></div>
      </div>
    </div>
  </div>
  <div class="info-card">
    <div class="info-row"><div class="info-dot"></div>共 <strong>25 道题</strong>，每题按符合程度评 1–5 分，约需 4–6 分钟</div>
    <div class="info-row"><div class="info-dot"></div>请根据你在<strong>压力或困难情境下的真实反应</strong>作答，不是日常状态</div>
    <div class="info-row"><div class="info-dot"></div>1 = 非常不同意 &nbsp;→&nbsp; 5 = 非常同意</div>
    <div class="info-row"><div class="info-dot"></div>完成后揭晓你在压力下最容易启动的心理系统</div>
  </div>
  <button class="btnP btnFull" onclick="goTo(1)">开始测评</button>
</div>
</div>

<!-- PAGE 1: QUESTIONS -->
<div id="p1" class="page">
<div class="wrap">
  <div class="prog-wrap">
    <div class="prog-top">
      <span class="prog-label">Z5S Stress V1</span>
      <span class="prog-count" id="qcount">0 / 30</span>
    </div>
    <div class="prog-bar"><div class="prog-fill" id="qbar" style="width:0%"></div></div>
  </div>
  <div id="questions"></div>
  <div class="btn-row">
    <button class="btnS" onclick="goTo(0)">← 返回</button>
    <button class="btnP" id="qnext" disabled onclick="showResults()">查看结果 →</button>
  </div>
</div>
</div>

<!-- PAGE 2: RESULTS -->
<div id="p2" class="page">
<div class="wrap" id="results"></div>
</div>

<script>
const SYS={
  A:{name:'Interpretation',zh:'解释系统',color:'#3e7c22',bg:'#eef6e6',tc:'#2a5a14',icon:'🔍',
     desc:'通过分析和理解来应对压力，本能追问"为什么"'},
  B:{name:'Execution',zh:'执行系统',color:'#2060b0',bg:'#e4eef8',tc:'#144080',icon:'⚡',
     desc:'通过行动和推进来应对压力，本能进入"下一步"模式'},
  C:{name:'Emotion',zh:'情绪系统',color:'#c07010',bg:'#fdf0dc',tc:'#8a4e08',icon:'💛',
     desc:'通过情感感受来接收压力信号，情绪是最早出现的反应'},
  D:{name:'Identity',zh:'认同系统',color:'#7050c8',bg:'#eeebfc',tc:'#4a34a0',icon:'🪞',
     desc:'通过自我评价和价值认定来处理压力，压力触发身份感'},
  E:{name:'Play',zh:'游戏系统',color:'#c03820',bg:'#fce8e4',tc:'#902010',icon:'🎮',
     desc:'通过保持弹性和心理空间来应对压力，本能逃离被锁住的感觉'},
};

// questions: sys=system, r=reverse
const QS=[
  // 解释系统 A
  {q:'在压力出现时，我会立刻开始思考事情为什么会变成这样。',sys:'A'},
  {q:'当局面混乱时，我本能地想把事情的逻辑关系理清。',sys:'A'},
  {q:'压力来临时，我通常先试图理解问题结构，而不是马上行动。',sys:'A'},
  {q:'当事情出错时，我会反复推想哪里出现了因果问题。',sys:'A'},
  {q:'即使情绪已经出现，我仍会优先试图搞清楚事情的逻辑。',sys:'A'},
  // 执行系统 B
  {q:'压力出现时，我很快进入"下一步该做什么"的思考。',sys:'B'},
  {q:'当事情开始失控时，我会自动寻找可以立刻采取的行动。',sys:'B'},
  {q:'在困难情境中，我更倾向于处理问题，而不是停留在理解上。',sys:'B'},
  {q:'当事情出错时，我首先考虑的是如何修正局面。',sys:'B'},
  {q:'面对问题时，我通常会迅速进入解决或补救状态。',sys:'B'},
  // 情绪系统 C
  {q:'当压力出现时，我通常首先注意到自己的情绪变化。',sys:'C'},
  {q:'很多时候，我的身体和情绪会比思考更快作出反应。',sys:'C'},
  {q:'在被批评或冲突时，我会先感到明显的情绪波动。',sys:'C'},
  {q:'当事情出问题时，我往往先体验到情绪上的冲击。',sys:'C'},
  {q:'情绪感受通常是我面对压力时最早出现的信号。',sys:'C'},
  // 认同系统 D
  {q:'在压力情境中，我很快会想到这件事对我意味着什么。',sys:'D'},
  {q:'当被否定时，我会立刻联想到自己的价值或能力。',sys:'D'},
  {q:'某些压力情境会让我思考自己在他人眼中的位置。',sys:'D'},
  {q:'在失败或冲突中，我会很快联想到自我评价的问题。',sys:'D'},
  {q:'当事情出问题时，我会思考这是否影响我是谁。',sys:'D'},
  // 游戏系统 E
  {q:'当压力出现时，我会本能地试图让自己不要被困在一种状态里。',sys:'E'},
  {q:'在困难情境中，我会寻找让自己保持心理空间的方法。',sys:'E'},
  {q:'即使局面紧张，我仍会试着给自己留一点弹性。',sys:'E'},
  {q:'压力来临时，我会本能地避免让自己被一种框架完全锁住。',sys:'E'},
  {q:'面对压力时，我通常会试图保留一些心理上的活动空间。',sys:'E'},
];

const INTERPRET={
  A:{
    high:'你的压力主导系统是解释系统，且激活程度很高。当压力来临时，你的心理第一反应是分析——你几乎无法在不弄清楚原因的情况下平静下来。这让你在复杂问题上有极强的洞察力，但也可能让你在需要快速行动的时候陷入过度思考。压力对你来说，既是信息输入，也是认知负荷。',
    mid:'你的压力主导系统是解释系统。面对困难时，你的本能是先理解——事情为什么发生、逻辑在哪里。这让你能从压力中提炼洞见，但有时可能需要提醒自己：不是所有事情都需要先搞清楚才能行动。',
    low:'你的压力倾向轻微偏向解释系统。遇到压力时你会有分析的冲动，但不会被它主导。你在理解和行动之间相对灵活。',
  },
  B:{
    high:'你的压力主导系统是执行系统，且激活程度很高。压力来临时，你几乎立刻进入"做"的模式——大脑会跳过情绪和分析，直接寻找下一步行动。这让你在危机中极其高效，但也可能在需要停下来感受或理解的时候显得过于推进。',
    mid:'你的压力主导系统是执行系统。困难情境里，你更愿意做点什么来找回控制感，而不是坐在那里想。这是很实用的压力应对方式，只是有时值得检查：行动是在解决问题，还是在回避感受？',
    low:'你的压力倾向轻微偏向执行系统。压力下你会想行动，但不是纯粹的行动导向——你也会停下来想想或感受一下。',
  },
  C:{
    high:'你的压力主导系统是情绪系统，且激活程度很高。压力来临时，情绪是你最早也最强烈的信号——身体和感受往往先于思考和行动出现。这让你对自己和他人的情感状态有极高的感知力，但在高压下也需要有意识地为情绪留出处理空间。',
    mid:'你的压力主导系统是情绪系统。遇到困难时，情绪会先出现，成为你理解状况的重要信息。你能感受到别人没注意到的东西，压力后需要一些时间来处理情绪再继续前进。',
    low:'你的压力倾向轻微偏向情绪系统。你有情绪敏感度，但在压力下不会被情绪完全淹没，通常能较快切换到理性或行动模式。',
  },
  D:{
    high:'你的压力主导系统是认同系统，且激活程度很高。压力来临时，你几乎本能地把它和"我是谁"联系起来——失败感、被否定、冲突，都会触发你对自我价值和身份感的审视。这让你有很深的内省能力，但也意味着压力对你的自我感威胁最大。',
    mid:'你的压力主导系统是认同系统。困难情境里，你会想：这件事对我意味着什么？这是否影响了我对自己的看法？这种内在参照让你决策有原则，但也需要注意不要让外部压力过度影响你的自我叙事。',
    low:'你的压力倾向轻微偏向认同系统。压力下你会偶尔联想到自我评价，但不会完全被它主导。',
  },
  E:{
    high:'你的压力主导系统是游戏系统，且激活程度很高。压力来临时，你最抗拒的是被"困住"——你会本能地寻找弹性空间、替代出口、新的可能性。这让你有极强的心理韧性，不容易被单一框架压垮，但有时可能需要允许自己在某件事上多停留一会儿。',
    mid:'你的压力主导系统是游戏系统。困难时你会寻找呼吸的空间，不让自己被某一种状态完全吞没。这是一种宝贵的弹性，让你能在混乱中保持一定的心理自由。',
    low:'你的压力倾向轻微偏向游戏系统。你有保持弹性的倾向，但在压力下也能认真投入、不总是想"逃出框架"。',
  },
};

const SECONDARY={
  A:'副系统是解释系统：压力来临时，理解和分析是你的重要辅助——即便主系统先启动，分析思维会紧接着介入，帮你建立对局势的掌握感。',
  B:'副系统是执行系统：你在主系统之外有较强的行动驱动，需要时能快速切换到推进模式，不会在压力下长期原地不动。',
  C:'副系统是情绪系统：情绪感知是你重要的辅助信号——即便主系统先启动，情绪信息也会持续进入处理，影响你的判断和反应。',
  D:'副系统是认同系统：压力下你的自我感知会作为辅助层出现——即使主系统在运转，你仍会关注"这件事是否影响我是谁"。',
  E:'副系统是游戏系统：弹性和心理活动空间是你应对压力的辅助资源——当主系统遇到瓶颈，你会本能地寻找新出口和可能性。',
};

const ans={};

function buildQuestions(){
  const c=document.getElementById('questions');
  QS.forEach((q,i)=>{
    c.innerHTML+=`
    <div class="qcard" id="qcard_${i}">
      <div class="qcard-top">
        <div class="qnum">${i+1}</div>
        <div class="qtext">${q.q}</div>
      </div>
      <div class="likert">
        <div class="likert-labels">
          <span>1 非常不同意</span>
          <span>5 非常同意</span>
        </div>
        <div class="likert-row">
          ${[1,2,3,4,5].map(v=>`
            <button class="lopt" id="lopt_${i}_${v}" onclick="setAns(${i},${v})">${v}</button>
          `).join('')}
        </div>
      </div>
    </div>`;
  });
}

function setAns(qi,val){
  [1,2,3,4,5].forEach(v=>{
    const b=document.getElementById(`lopt_${qi}_${v}`);
    if(b)b.classList.toggle('sel',v===val);
  });
  ans[qi]=val;
  document.getElementById(`qcard_${qi}`).classList.add('answered');
  const done=Object.keys(ans).length;
  document.getElementById('qcount').textContent=`${done} / 25`;
  document.getElementById('qbar').style.width=`${done/25*100}%`;
  const btn=document.getElementById('qnext');
  btn.disabled=done<25;
  btn.textContent=done<25?`还有 ${25-done} 题未选`:'查看结果 →';
}

function goTo(n){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.getElementById('p'+n).classList.add('active');
  window.scrollTo(0,0);
}

function showResults(){
  const rawScores={A:0,B:0,C:0,D:0,E:0};
  QS.forEach((q,i)=>{
    if(ans[i]===undefined)return;
    rawScores[q.sys]+=ans[i];
  });

  // pct: (score-5)/20*100 (range 5-25 per system)
  const pct=k=>Math.round((rawScores[k]-5)/20*100);
  const sorted=Object.keys(rawScores).sort((a,b)=>rawScores[b]-rawScores[a]);
  const pk=sorted[0],sk=sorted[1];
  const pv=rawScores[pk];

  let domLevel;
  if(pv>=20)domLevel='high';
  else if(pv>=14)domLevel='mid';
  else domLevel='low';

  const levelLabels={high:{t:'High Activation',c:'#2a5a14',bg:'#eef6e6'},mid:{t:'Moderate Activation',c:'#144080',bg:'#e4eef8'},low:{t:'Mild Activation',c:'#4a34a0',bg:'#eeebfc'}};
  const ll=levelLabels[domLevel];

  const interpret=(INTERPRET[pk][domLevel])+'\n\n'+(SECONDARY[sk]);

  document.getElementById('results').innerHTML=`
    <div class="r-header">
      <div class="eyebrow">Z5S Stress V1 · 压力启动结果</div>
      <h2>你的压力启动图谱</h2>
      <p>基于 30 道量表题的压力反应分析</p>
    </div>

    <div class="rcard" style="border-left:4px solid ${SYS[pk].color}">
      <div class="card-label">Primary Activation · 主导启动系统</div>
      <div class="primary-row">
        <div class="p-icon" style="background:${SYS[pk].bg}">${SYS[pk].icon}</div>
        <div style="flex:1">
          <div class="p-name" style="color:${SYS[pk].tc}">${SYS[pk].zh}</div>
          <div class="p-desc">${SYS[pk].name} · ${SYS[pk].desc}</div>
        </div>
        <div class="p-score" style="color:${SYS[pk].color}">${pct(pk)}<span style="font-size:15px;font-weight:400;color:var(--ink3)">%</span></div>
      </div>
      <div>
        <span class="level-badge" style="background:${ll.bg};color:${ll.c}">${ll.t}</span>
        <div style="font-size:13px;color:var(--ink3);line-height:1.6">Secondary: <strong style="color:${SYS[sk].tc}">${SYS[sk].zh}</strong> (${SYS[sk].name}) &nbsp;·&nbsp; ${pct(sk)}%</div>
      </div>
    </div>

    <div class="rcard">
      <div class="card-label">五系统压力激活分布</div>
      ${sorted.map((k,i)=>`
        <div class="bar-row">
          <div class="bar-head">
            <span style="font-size:13px;font-weight:600;color:${SYS[k].color}">
              ${SYS[k].icon} ${SYS[k].zh}
              ${i===0?'<span style="font-size:11px;color:var(--ink3);font-weight:400;margin-left:5px">Primary</span>':''}
              ${i===1?'<span style="font-size:11px;color:var(--ink3);font-weight:400;margin-left:5px">Secondary</span>':''}
            </span>
            <span style="font-size:13px;color:var(--ink2);font-weight:600">${rawScores[k]}<span style="font-size:11px;color:var(--ink3);font-weight:400">/25 &nbsp;(${pct(k)}%)</span></span>
          </div>
          <div class="bar-track">
            <div class="bar-fill" style="width:${pct(k)}%;background:${SYS[k].color}"></div>
          </div>
        </div>`).join('')}
    </div>

    <div class="rcard">
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:1rem">
        <div style="width:26px;height:26px;border-radius:7px;background:${SYS[pk].bg};display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0">${SYS[pk].icon}</div>
        <div class="card-label" style="margin-bottom:0">系统解读</div>
      </div>
      <div class="interpret-box">${interpret}</div>
    </div>

    <div class="rcard">
      <div class="card-label">计分说明</div>
      <p style="font-size:13px;color:var(--ink2);line-height:1.7;margin-bottom:.85rem">
        每个系统共 5 道题，原始分范围 5–25。
        转换为百分比：<code style="background:#f0ede8;padding:2px 6px;border-radius:4px;font-size:12px">(得分 − 5) ÷ 20 × 100%</code>
      </p>
      <div style="display:grid;grid-template-columns:repeat(5,1fr);gap:6px">
        ${sorted.map(k=>`
          <div style="background:${SYS[k].bg};border-radius:10px;padding:.7rem .6rem;text-align:center">
            <div style="font-size:18px;margin-bottom:3px">${SYS[k].icon}</div>
            <div style="font-size:12px;font-weight:700;color:${SYS[k].tc}">${rawScores[k]}</div>
            <div style="font-size:10px;color:${SYS[k].tc};opacity:.7">${pct(k)}%</div>
          </div>`).join('')}
      </div>
    </div>

    <div class="rcard">
      <div class="card-label">五个系统在压力下是什么？</div>
      <p style="font-size:13px;color:var(--ink2);margin-bottom:1rem;line-height:1.6">每个人在压力下五个系统都会被激活，但有先后顺序——得分最高的就是你最先启动的系统。</p>
      <div class="sys-grid">
        ${Object.entries(SYS).map(([k,s])=>`
          <div class="sys-item" style="background:${s.bg};${k===pk?'outline:2px solid '+s.color+';outline-offset:1px':''}">
            <div class="sys-name" style="color:${s.tc}">${s.icon} ${s.zh}${k===pk?' ★':''}</div>
            <div class="sys-desc" style="color:${s.tc}">${s.desc}</div>
          </div>`).join('')}
      </div>
    </div>

    <div style="text-align:center;margin-top:2rem;padding-bottom:3rem">
      <button style="background:var(--card);color:var(--ink2);border:1px solid var(--border);
        border-radius:11px;padding:.9rem 2.5rem;font-size:14px;cursor:pointer;font-family:inherit"
        onclick="resetAll()">重新测评</button>
    </div>`;

  goTo(2);
  // animate bars after render
  setTimeout(()=>{
    sorted.forEach(k=>{
      const fills=document.querySelectorAll('.bar-fill');
      fills.forEach(f=>{if(f.style.width==='0%')f.style.width=f.dataset.target||f.style.width});
    });
  },100);
}

function resetAll(){
  Object.keys(ans).forEach(k=>delete ans[k]);
  QS.forEach((_,i)=>[1,2,3,4,5].forEach(v=>{
    const b=document.getElementById(`lopt_${i}_${v}`);if(b)b.classList.remove('sel');
    const card=document.getElementById(`qcard_${i}`);if(card)card.classList.remove('answered');
  }));
  document.getElementById('qcount').textContent='0 / 25';
  document.getElementById('qbar').style.width='0%';
  const btn=document.getElementById('qnext');
  btn.disabled=true;
  btn.textContent='还有 25 题未选';
  goTo(0);
}

buildQuestions();
</script>
</body>
</html>
